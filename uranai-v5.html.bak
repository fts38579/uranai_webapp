function getLenCategoryKey(cat='邱丞粋'){
  return cat==='諱区・'?'love':cat==='莉穂ｺ・||cat==='驥鷹°'?'work':'rel';
}

function getLenSpreadLabels(){
  if(SEL_LEN.length===9) return LEN_POSITION_LABELS;
  if(SEL_LEN.length===FREE_LEN_COUNT) return LEN_FREE_POSITION_LABELS;
  return ['蠑輔＞縺溘き繝ｼ繝・];
}

function getOrcSpreadLabels(){
  return SEL_ORC.length===3?ORC_POSITION_LABELS:['蠑輔＞縺溘き繝ｼ繝・];
}

function getLenSpreadLabel(index,total=SEL_LEN.length){
  if(total===9) return LEN_POSITION_LABELS[index]||`${index+1}譫夂岼`;
  if(total===FREE_LEN_COUNT) return LEN_FREE_POSITION_LABELS[index]||`${index+1}譫夂岼`;
  if(total===1) return '蠑輔＞縺溘き繝ｼ繝・;
  return `${index+1}譫夂岼`;
}

function getOrcSpreadLabel(index,total=SEL_ORC.length){
  if(total===3) return ORC_POSITION_LABELS[index]||`${index+1}譫夂岼`;
  return '蠑輔＞縺溘き繝ｼ繝・;
}

function pickLenFacetText(...values){
  for(const raw of values){
    const text=String(raw||'')
      .split(/[縲・・圭/・上・]/)
      .map(part=>part.trim())
      .find(Boolean);
    if(text) return text;
  }
  return '';
}

function buildLenPairInference(leftCard,rightCard){
  if(!leftCard||!rightCard) return '';
  const leftLead=pickLenFacetText(leftCard.themeText,leftCard.data?.pos,leftCard.data?.kw,leftCard.name);
  const rightLead=pickLenFacetText(rightCard.themeText,rightCard.data?.pos,rightCard.data?.kw,rightCard.name);
  const rightStops=hasLenGroup([rightCard.id],'ending')||hasLenGroup([rightCard.id],'burden')||hasLenGroup([rightCard.id],'hidden');
  const rightSupports=hasLenGroup([rightCard.id],'support')||hasLenGroup([rightCard.id],'stability')||hasLenGroup([rightCard.id],'relationship');
  const rightChoice=hasLenGroup([rightCard.id],'choice');
  let direction='蟾ｦ縺ｮ豬√ｌ繧貞承縺ｮ繧ｫ繝ｼ繝峨′譚｡莉ｶ縺･縺代ｋ荳ｦ縺ｳ縲・;
  if(rightStops) direction='蜿ｳ縺ｮ繧ｫ繝ｼ繝峨′蟾ｦ縺ｮ豬√ｌ繧呈ｭ｢繧√ｋ繝ｻ蜑翫ｋ譁ｹ蜷代↓蜒阪″繧・☆縺・ｸｦ縺ｳ縲・;
  else if(rightSupports) direction='蜿ｳ縺ｮ繧ｫ繝ｼ繝峨′蟾ｦ縺ｮ豬√ｌ繧呈髪縺医ｋ繝ｻ螳夂捩縺輔○繧区婿蜷代↓蜒阪″繧・☆縺・ｸｦ縺ｳ縲・;
  else if(rightChoice) direction='蜿ｳ縺ｮ繧ｫ繝ｼ繝峨′蟾ｦ縺ｮ豬√ｌ縺ｫ蛻・ｲ舌ｄ驕ｸ謚槭ｒ謖√■霎ｼ繧荳ｦ縺ｳ縲・;
  return `- ${leftCard.label} ${leftCard.name} 竊・${rightCard.label} ${rightCard.name}・・{leftLead} 縺・${rightLead} 縺ｸ縺､縺ｪ縺後ｋ縲・{direction}`;
}

function buildLenChainInference(cards,label=''){
  if(!Array.isArray(cards)||cards.length<3) return '';
  const leads=cards.map(card=>pickLenFacetText(card.themeText,card.data?.pos,card.data?.kw,card.name));
  const chainLabel=label?`${label}・彖:'';
  return `- ${chainLabel}${cards.map(card=>`${card.label} ${card.name}`).join(' 竊・')}・・{leads[0]} 縺九ｉ ${leads[1]} 繧堤ｵ後※ ${leads[2]} 縺ｸ蜍輔￥豬√ｌ縲Ａ;
}

function buildLenSpreadPromptContext(cat='邱丞粋'){
  const catKey=getLenCategoryKey(cat);
  const cards=SEL_LEN.map((id,index)=>{
    const data=LENORMAND[id]||{};
    const label=getLenSpreadLabel(index,SEL_LEN.length);
    const themeText=data[catKey]||data.love||data.rel||'';
    const moneyText=cat==='驥鷹°'?(data.work||data.kw||''):'';
    return{
      id,
      index,
      data,
      name:data.name||'',
      label,
      themeText,
      detail:[
        `${label}・哢o.${id}縲・{data.name||''}縲港,
        `  繧ｭ繝ｼ繝ｯ繝ｼ繝会ｼ・{data.kw||''}`,
        `  繝昴ず繝・ぅ繝厄ｼ・{data.pos||''}`,
        `  繝阪ぎ繝・ぅ繝厄ｼ・{data.neg||''}`,
        `  ${cat}髱｢・・{themeText}`,
        moneyText?`  驥鷹°繝ｻ縺企≡髱｢・・{moneyText}`:'',
        data.special?`  縲千音谿翫Ν繝ｼ繝ｫ縲・{data.special}`:'',
      ].filter(Boolean).join('\n'),
    };
  });
  const describeCard=card=>`${card.label} No.${card.id}縲・{card.name}縲港;
  const describeGroup=group=>`- ${group.title}・・{group.meaning}\n  ${group.indexes.map(index=>describeCard(cards[index])).join(' / ')}`;
  const pairDetails=cards.slice(0,-1).map((card,index)=>buildLenPairInference(card,cards[index+1])).filter(Boolean);
  const coreDetails=cards.length===9
    ?[
      buildLenPairInference(cards[3],cards[4]),
      buildLenPairInference(cards[4],cards[5]),
      buildLenPairInference(cards[1],cards[4]),
      buildLenPairInference(cards[4],cards[7]),
      buildLenChainInference([cards[3],cards[4],cards[5]],'荳ｭ蠢・ｨｪ蛻・),
      buildLenChainInference([cards[1],cards[4],cards[7]],'荳ｭ蠢・ｸｦ蛻・),
    ].filter(Boolean)
    :cards.length===FREE_LEN_COUNT
      ?[
        buildLenPairInference(cards[0],cards[1]),
        buildLenPairInference(cards[1],cards[2]),
        buildLenChainInference(cards,'3譫壼・菴・),
      ].filter(Boolean)
      :pairDetails.slice(0,1);
  const flowDetails=cards.length===9
    ?[
      buildLenChainInference([cards[0],cards[1],cards[2]],'荳頑ｮｵ'),
      buildLenChainInference([cards[3],cards[4],cards[5]],'荳ｭ谿ｵ'),
      buildLenChainInference([cards[6],cards[7],cards[8]],'荳区ｮｵ'),
    ].filter(Boolean)
    :coreDetails;
  return{
    catKey,
    cards,
    cardDetails:cards.map(card=>card.detail).join('\n'),
    rowDetails:cards.length===9?LEN_ROW_GUIDES.map(describeGroup).join('\n'):'',
    columnDetails:cards.length===9?LEN_COLUMN_GUIDES.map(describeGroup).join('\n'):'',
    diagonalDetails:cards.length===9?LEN_DIAGONAL_GUIDES.map(describeGroup).join('\n'):'',
    pairDetails:pairDetails.join('\n'),
    coreDetails:coreDetails.join('\n'),
    flowDetails:flowDetails.join('\n'),
    pairHighlights:coreDetails.slice(0,2),
  };
}

function renderDossierProofRow(cards,type,title){
  if(!cards.length) return '';
  return`
    <div class="dossier-proof-section">
      <div class="dossier-proof-section-title">${escapeHtml(title)}</div>
      <div class="dossier-proof-grid">
        ${cards.map(card=>`
          <div class="dossier-mini-card">
            <div class="dossier-mini-thumb">
              <img src="${escapeHtml(card.img)}" alt="${escapeHtml(card.name)}">
            </div>
            <div class="dossier-mini-label">${escapeHtml(card.label)}</div>
            <div class="dossier-mini-name">No.${escapeHtml(card.id)} ${escapeHtml(card.name)}</div>
          </div>
        `).join('')}
      </div>
    </div>`;
}

function buildDossierProof(){
  const input=getCurrentInputSnapshot();
  const basisTags=[];
  if(input.cat) basisTags.push(`逶ｸ隲・ユ繝ｼ繝・${input.cat}`);
  if(input.theme) basisTags.push('譛ｬ莠ｺ縺ｮ謔ｩ縺ｿ繧堤峩謗･蜿肴丐');
  if(MEIMEI) basisTags.push('逕溘∪繧後・蛯ｾ蜷・);
  if(NAMEJUDGE) basisTags.push('蜷榊燕縺九ｉ莨昴ｏ繧句魂雎｡');
  if(REACTION_PROFILE?.label) basisTags.push('菴馴ｨ薙お繝斐た繝ｼ繝峨・蜿榊ｿ・);
  if(hasClarifyAnswers()) basisTags.push('霑ｽ蜉繝偵い繝ｪ繝ｳ繧ｰ');

  return`
    <div class="dossier-proof">
      <div class="dossier-proof-head">
        <div>
          <div class="dossier-proof-eyebrow">隕九◆隕ｳ轤ｹ</div>
          <div class="dossier-proof-title">莉雁屓縺ｮ髑大ｮ壹〒隕九◆隕ｳ轤ｹ</div>
        </div>
        <div class="dossier-proof-copy">${escapeHtml(input.fullname||'縺ゅ↑縺・)}縺輔ｓ縺ｮ逶ｸ隲・・螳ｹ縲∫函縺ｾ繧後ｄ蜷榊燕縺九ｉ莨昴ｏ繧句だ蜷代∽ｽ馴ｨ薙お繝斐た繝ｼ繝峨・蜿榊ｿ懊ｒ驥阪・縲∝愛譁ｭ譚先侭縺ｨ縺励※隱ｭ縺ｿ霑斐＠繧・☆縺・ｽ｢縺ｸ蜀咲ｷｨ髮・＠縺滄荘螳壽嶌縺ｧ縺吶・/div>
      </div>
      <div class="dossier-proof-meta">
        ${basisTags.filter(Boolean).map(tag=>`<div class="dossier-proof-pill">${escapeHtml(tag)}</div>`).join('')}
      </div>
    </div>`;
}

function getDossierDiagnosticSections(){
  const namePlain=buildNamePlainInsight(NAMEJUDGE);
  const birthPlain=buildBirthPlainInsight(MEIMEI);
  const lifeText=buildLifePatternPlainText();
  const reaction=REACTION_PROFILE;
  return[
    {
      eyebrow:'險ｺ譁ｭ',
      title:'蜷榊燕縺九ｉ隕九∴繧句だ蜷・,
      body:namePlain
        ?[namePlain.overview,namePlain.timing,namePlain.advice].filter(Boolean).join('\n\n')
        :'蜷榊燕縺梧悴蜈･蜉帙・縺溘ａ縲√％縺ｮ驛ｨ蛻・・莉雁屓縺ｯ逵∫払縺励※縺・∪縺吶・
    },
    {
      eyebrow:'險ｺ譁ｭ',
      title:'逕溘∪繧後°繧芽ｦ九∴繧句だ蜷・,
      body:[
        birthPlain?[birthPlain.overview,birthPlain.timing,birthPlain.advice].filter(Boolean).join('\n\n'):'逕溘∪繧後・諠・ｱ縺御ｸ崎ｶｳ縺励※縺・ｋ縺溘ａ縲√％縺ｮ驛ｨ蛻・・莉雁屓縺ｯ邁｡譏楢｡ｨ遉ｺ縺ｧ縺吶・,
        lifeText&&!/菴ｿ縺｣縺ｦ縺・∪縺帙ｓ/.test(lifeText)?`隱慕函譌･縺九ｉ隕九∴繧玖｡悟虚縺ｮ縺上○・・{lifeText}`:''
      ].filter(Boolean).join('\n\n')
    },
    {
      eyebrow:'險ｺ譁ｭ',
      title:'菴馴ｨ薙お繝斐た繝ｼ繝峨°繧芽ｦ九∴繧句だ蜷・,
      body:reaction
        ?[
          reaction.summary,
          `蜿榊ｿ懊′蜃ｺ繧・☆縺・ｴ髱｢・・{reaction.stress}`,
          `蜉帙′蜃ｺ繧・☆縺・虚縺搾ｼ・{reaction.power}`,
          reaction.handling,
        ].filter(Boolean).join('\n\n')
        :'菴馴ｨ薙お繝斐た繝ｼ繝峨・蝗樒ｭ斐′縺ｾ縺縺ｪ縺・◆繧√√％縺ｮ驛ｨ蛻・・邁｡譏楢｡ｨ遉ｺ縺ｧ縺吶・
    }
  ];
}

