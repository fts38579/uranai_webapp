function getEmptyElementCounter(){
  return{譛ｨ:0,轣ｫ:0,蝨・0,驥・0,豌ｴ:0};
}

function addElementWeight(counter,element,weight=1){
  if(!element) return;
  counter[element]=Number(((counter[element]||0)+weight).toFixed(2));
}

function getRankedEntries(counter,limit=5){
  return Object.entries(counter||{})
    .map(([key,value])=>({key,value:Number(value||0)}))
    .sort((a,b)=>b.value-a.value||String(a.key).localeCompare(String(b.key),'ja'))
    .slice(0,limit);
}

function formatElementRanking(counter,limit=2){
  return getRankedEntries(counter,limit)
    .filter(item=>item.value>0)
    .map(item=>`${item.key}(${item.value.toFixed(1)})`)
    .join('繝ｻ');
}

function getWeakElements(counter,limit=2){
  return getRankedEntries(counter,5)
    .slice()
    .reverse()
    .slice(0,limit)
    .map(item=>item.key);
}

function accumulatePillarElements(counter,pillar,weight=1){
  if(!pillar) return;
  addElementWeight(counter,pillar.stemElement,1*weight);
  (pillar.hidden||[]).forEach(item=>addElementWeight(counter,item.element,(item.weight||0.1)*weight));
}

function countTenGodsFromPillars(pillars){
  const counts={};
  (pillars||[]).forEach(pillar=>{
    if(pillar.tenGod&&pillar.tenGod!=='譌･荳ｻ') counts[pillar.tenGod]=(counts[pillar.tenGod]||0)+1;
    (pillar.hidden||[]).forEach(item=>{
      if(item.tenGod&&item.tenGod!=='譌･荳ｻ') counts[item.tenGod]=(counts[item.tenGod]||0)+(item.weight||0.1);
    });
  });
  return Object.entries(counts)
    .map(([key,value])=>({key,value:Number(value.toFixed(2))}))
    .sort((a,b)=>b.value-a.value||a.key.localeCompare(b.key,'ja'));
}

function formatCandidateDays(days){
  if(!days||!days.length) return '';
  if(days.length===1) return `${days[0]}譌･`;
  return `${days[0]}譌･縲・{days[days.length-1]}譌･`;
}

function incrementPillarCandidate(store,pillar,day){
  const key=`${pillar.kan}${pillar.zhi}`;
  if(!store[key]) store[key]={key,kan:pillar.kan,zhi:pillar.zhi,count:0,days:[]};
  store[key].count+=1;
  store[key].days.push(day);
}

function getCandidateList(store){
  return Object.values(store||{})
    .sort((a,b)=>b.count-a.count||a.key.localeCompare(b.key,'ja'));
}

function getGanzhiIndex(kan,zhi){
  for(let i=0;i<60;i++){
    if(TG[i%10]===kan&&DZ[i%12]===zhi) return i;
  }
  return 0;
}

function shiftGanzhiPillar(pillar,step=0){
  if(!pillar?.kan||!pillar?.zhi) return null;
  const idx=getGanzhiIndex(pillar.kan,pillar.zhi);
  const nextIdx=mod(idx+step,60);
  return{
    kan:TG[nextIdx%10],
    zhi:DZ[nextIdx%12],
    key:`${TG[nextIdx%10]}${DZ[nextIdx%12]}`,
  };
}

function toJsDate(y,m,d){
  return new Date(Number(y),Number(m)-1,Number(d),12,0,0,0);
}

function diffDaysBetween(dateA,dateB){
  return Math.round((dateA.getTime()-dateB.getTime())/86400000);
}

function formatAgeValue(value){
  const num=Number(value||0);
  return Number.isInteger(num)?String(num):num.toFixed(1);
}

function calcAgeDecimal(y,m,d,refDate=new Date()){
  const birth=toJsDate(y,m,d);
  const current=new Date(refDate.getFullYear(),refDate.getMonth(),refDate.getDate(),12,0,0,0);
  return Number(((current.getTime()-birth.getTime())/31556952000).toFixed(1));
}

function getFortuneBoundaryList(year){
  const prev=getSolarTermBoundaries(year-1);
  const current=getSolarTermBoundaries(year);
  const next=getSolarTermBoundaries(year+1);
  return[
    {key:'heavySnow',label:FORTUNE_BOUNDARY_LABELS.heavySnow,date:prev.heavySnow},
    {key:'minorCold',label:FORTUNE_BOUNDARY_LABELS.minorCold,date:current.minorCold},
    {key:'springCommences',label:FORTUNE_BOUNDARY_LABELS.springCommences,date:current.springCommences},
    {key:'insectsWaken',label:FORTUNE_BOUNDARY_LABELS.insectsWaken,date:current.insectsWaken},
    {key:'brightAndClear',label:FORTUNE_BOUNDARY_LABELS.brightAndClear,date:current.brightAndClear},
    {key:'summerCommences',label:FORTUNE_BOUNDARY_LABELS.summerCommences,date:current.summerCommences},
    {key:'cornOnEar',label:FORTUNE_BOUNDARY_LABELS.cornOnEar,date:current.cornOnEar},
    {key:'moderateHeat',label:FORTUNE_BOUNDARY_LABELS.moderateHeat,date:current.moderateHeat},
    {key:'autumnCommences',label:FORTUNE_BOUNDARY_LABELS.autumnCommences,date:current.autumnCommences},
    {key:'whiteDew',label:FORTUNE_BOUNDARY_LABELS.whiteDew,date:current.whiteDew},
    {key:'coldDew',label:FORTUNE_BOUNDARY_LABELS.coldDew,date:current.coldDew},
    {key:'winterCommences',label:FORTUNE_BOUNDARY_LABELS.winterCommences,date:current.winterCommences},
    {key:'heavySnow',label:FORTUNE_BOUNDARY_LABELS.heavySnow,date:current.heavySnow},
    {key:'minorCold',label:FORTUNE_BOUNDARY_LABELS.minorCold,date:next.minorCold},
    {key:'springCommences',label:FORTUNE_BOUNDARY_LABELS.springCommences,date:next.springCommences},
  ].filter(item=>item.date);
}

function findFortuneBoundary(y,m,d,direction){
  const birthKey=toDateKey(y,m,d);
  const boundaries=getFortuneBoundaryList(y);
  if(direction>=0){
    return boundaries.find(item=>item.date>=birthKey)||boundaries[boundaries.length-1]||null;
  }
  const reversed=[...boundaries].reverse();
  return reversed.find(item=>item.date<=birthKey)||reversed[0]||null;
}

function getFortuneDirection(yearStem,gender){
  const isYang=STEM_POLARITY[yearStem]==='yang';
  if(gender==='male'){
    return{
      step:isYang?1:-1,
      label:isYang?'鬆・｡・:'騾・｡・,
      note:'逕ｷ諤ｧ ﾃ・蟷ｴ蟷ｲ縺ｮ髯ｰ髯ｽ縺ｧ襍ｷ驕区婿蜷代ｒ蛻､螳壹＠縺ｦ縺・∪縺吶・,
    };
  }
  if(gender==='female'){
    return{
      step:isYang?-1:1,
      label:isYang?'騾・｡・:'鬆・｡・,
      note:'螂ｳ諤ｧ ﾃ・蟷ｴ蟷ｲ縺ｮ髯ｰ髯ｽ縺ｧ襍ｷ驕区婿蜷代ｒ蛻､螳壹＠縺ｦ縺・∪縺吶・,
    };
  }
  return{
    step:1,
    label:'蜿り・・｡・,
    note:'諤ｧ蛻･驕ｸ謚槭′縲後◎縺ｮ莉悶阪・縺溘ａ縲∝､ｧ驕九・蜿り・､縺ｨ縺励※鬆・｡後〒陦ｨ遉ｺ縺励※縺・∪縺吶・,
  };
}

function getBranchRelationType(leftBranch,rightBranch){
  if(!leftBranch||!rightBranch) return '';
  if(leftBranch===rightBranch) return 'same';
  if(BRANCH_COMBINATIONS[leftBranch]===rightBranch) return 'combine';
  if(BRANCH_CLASHES[leftBranch]===rightBranch) return 'clash';
  if(BRANCH_HARMS[leftBranch]===rightBranch) return 'harm';
  return '';
}

function getBranchRelationList(targetBranch,pillars){
  const typeRank={clash:4,combine:3,harm:2,same:1};
  const labelRank={譌･譟ｱ:4,譛域浤:3,蟷ｴ譟ｱ:2,譎よ浤:1};
  return(pillars||[])
    .map(pillar=>{
      const type=getBranchRelationType(targetBranch,pillar?.zhi);
      if(!type) return null;
      return{
        type,
        label:BRANCH_RELATION_LABELS[type],
        against:pillar.label,
        branch:pillar.zhi,
        summary:`${pillar.label}・・{pillar.zhi}・峨→${BRANCH_RELATION_LABELS[type]}縲・{BRANCH_RELATION_COPY[type]}`,
        priority:(typeRank[type]||0)*10+(labelRank[pillar.label]||0),
      };
    })
    .filter(Boolean)
    .sort((a,b)=>b.priority-a.priority);
}

function summarizeBranchRelations(relations,limit=2){
  return(relations||[])
    .slice(0,limit)
    .map(item=>`${item.against}${item.label}`)
    .join(' / ');
}

function describeTransitCopy(tenGod,relations){
  const base=FORTUNE_TEN_GOD_COPY[tenGod]||'蠖ｹ蜑ｲ繧・髄縺榊粋縺・婿縺ｮ蛻・ｊ譖ｿ縺医′襍ｷ縺薙ｊ繧・☆縺・°豌励〒縺吶・;
  const lead=relations?.[0];
  if(!lead) return base;
  return `${base} 縺ｨ縺上↓${lead.against}縺ｨ縺ｮ${lead.label}縺後≠繧翫・{BRANCH_RELATION_COPY[lead.type]}`;
}

function analyzeNatalBranchDynamics(pillars){
  const typeRank={clash:4,combine:3,harm:2,same:1};
  const relations=[];
  for(let i=0;i<(pillars||[]).length;i++){
    for(let j=i+1;j<(pillars||[]).length;j++){
      const left=pillars[i];
      const right=pillars[j];
      const type=getBranchRelationType(left?.zhi,right?.zhi);
      if(!type) continue;
      relations.push({
        type,
        label:BRANCH_RELATION_LABELS[type],
        left:left.label,
        right:right.label,
        pair:`${left.label}ﾃ・{right.label}`,
        summary:`${left.label}・・{left.zhi}・峨→${right.label}・・{right.zhi}・峨′${BRANCH_RELATION_LABELS[type]}縺ｧ縲・{BRANCH_RELATION_COPY[type]}`,
        priority:typeRank[type]||0,
      });
    }
  }
  relations.sort((a,b)=>b.priority-a.priority||a.pair.localeCompare(b.pair,'ja'));
  return{
    relations,
    summary:relations[0]?.summary||'蝨ｰ謾ｯ蜷悟｣ｫ縺ｮ螟ｧ縺阪↑陦晉ｪ√′蟆代↑縺上∫憾豕√↓蠢懊§縺ｦ蠖ｹ蜑ｲ繧帝°縺ｳ繧・☆縺・多蠑上〒縺吶・,
  };
}

function buildDaiunSummary(meimei,birth,gender){
  if(!meimei?.dm||!Number.isFinite(birth?.day)) return null;
  const direction=getFortuneDirection(meimei.pillars?.[0]?.kan||'',gender);
  const boundary=findFortuneBoundary(birth.year,birth.month,birth.day,direction.step);
  if(!boundary) return null;
  const birthDate=toJsDate(birth.year,birth.month,birth.day);
  const boundaryParts=String(boundary.date).split('-').map(Number);
  const boundaryDate=toJsDate(boundaryParts[0],boundaryParts[1],boundaryParts[2]);
  const diffDays=Math.max(0,Math.abs(diffDaysBetween(boundaryDate,birthDate)));
  const startAge=Number((diffDays/3).toFixed(1));
  const monthPillar=meimei.pillars?.find(p=>p.label==='譛域浤')||meimei.pillars?.[1];
  const currentAge=calcAgeDecimal(birth.year,birth.month,birth.day,new Date());
  const cycles=Array.from({length:8},(_,index)=>{
    const shifted=shiftGanzhiPillar(monthPillar,direction.step*(index+1));
    const ageStart=Number((startAge+index*10).toFixed(1));
    const ageEnd=Number((startAge+(index+1)*10).toFixed(1));
    const tenGod=getTenGod(meimei.dm,shifted.kan);
    const relations=getBranchRelationList(shifted.zhi,meimei.pillars);
    return{
      index:index+1,
      kan:shifted.kan,
      zhi:shifted.zhi,
      pillar:`${shifted.kan}${shifted.zhi}`,
      ageStart,
      ageEnd,
      ageLabel:`${formatAgeValue(ageStart)}縲・{formatAgeValue(ageEnd)}豁ｳ`,
      tenGod,
      relations,
      relationText:summarizeBranchRelations(relations),
      copy:describeTransitCopy(tenGod,relations),
      isCurrent:currentAge>=ageStart&&currentAge<ageEnd,
    };
  });
  const currentCycle=cycles.find(item=>item.isCurrent)||null;
  const nextCycle=currentCycle?cycles[cycles.indexOf(currentCycle)+1]||null:cycles[0]||null;
  return{
    directionLabel:direction.label,
    directionNote:direction.note,
    startAge,
    startText:`${formatAgeValue(startAge)}豁ｳ縺斐ｍ`,
    currentAge,
    boundaryLabel:boundary.label,
    boundaryDate:boundary.date,
    boundaryText:`${direction.step>0?'谺｡縺ｮ':'逶ｴ蜑阪・'}遽蜈･繧翫・{boundary.label}縲搾ｼ・{boundary.date}・峨∪縺ｧ繧定ｵｷ驕玖ｨ育ｮ励・蝓ｺ貅悶↓縺励※縺・∪縺吶Ａ,
    cycles,
    currentCycle,
    nextCycle,
  };
}

function buildAnnualFortunes(meimei,centerYear=new Date().getFullYear()){
  if(!meimei?.dm) return[];
  return Array.from({length:6},(_,index)=>{
    const year=centerYear-1+index;
    const yearPillar=getGanzhiYear(year,7,1);
    const tenGod=getTenGod(meimei.dm,yearPillar.kan);
    const relations=getBranchRelationList(yearPillar.zhi,meimei.pillars);
    return{
      year,
      kan:yearPillar.kan,
      zhi:yearPillar.zhi,
      pillar:`${yearPillar.kan}${yearPillar.zhi}`,
      tenGod,
      relations,
      relationText:summarizeBranchRelations(relations),
      copy:describeTransitCopy(tenGod,relations),
      isCurrent:year===centerYear,
    };
  });
}

function attachAdvancedMeimeiData(meimei,birth,gender=GENDER){
  if(!meimei) return meimei;
  meimei.branchDynamics=analyzeNatalBranchDynamics(meimei.pillars||[]);
  if(meimei.mode==='full'&&Number.isFinite(birth?.day)){
    meimei.fortune=buildDaiunSummary(meimei,birth,gender);
    if(meimei.fortune) meimei.fortune.annual=buildAnnualFortunes(meimei);
  }else{
    meimei.fortune=null;
  }
  return meimei;
}

function guessNameSplitByLength(compact,splitPoint){
  const chars=Array.from(compact||'');
  if(chars.length<2) return null;
  const point=Number.isInteger(splitPoint)
    ?splitPoint
    :(chars.length===2?1:(chars.length===3?1:2));
  if(point<=0||point>=chars.length) return null;
  return{sei:chars.slice(0,point).join(''),mei:chars.slice(point).join('')};
}

function scoreNameSplitCandidate(sei,mei,source){
  const seiLen=Array.from(sei||'').length;
  const meiLen=Array.from(mei||'').length;
  let score=0;
  if(COMMON_SURNAMES.includes(sei)) score+=40;
  if(source==='dictionary') score+=24;
  else if(source==='heuristic') score+=8;
  if(seiLen===2) score+=8;
  else if(seiLen===1||seiLen===3) score+=4;
  if(meiLen===2) score+=8;
  else if(meiLen===1||meiLen===3) score+=4;
  if(/[縲・/u.test(sei)) score+=2;
  if(/[蟄千ｾ手干鬥呵除螂井ｹ・浹]/u.test(Array.from(mei).slice(-1)[0]||'')) score+=2;
  return score;
}

function buildNameSplitCandidates(compact){
  const chars=Array.from(compact||'');
  if(chars.length<2) return[];
  const candidates=[];
  const seen=new Set();
  const pushCandidate=(sei,mei,source)=>{
    if(!sei||!mei) return;
    const key=`${sei}|${mei}`;
    if(seen.has(key)) return;
    seen.add(key);
    candidates.push({
      sei,mei,source,
      score:scoreNameSplitCandidate(sei,mei,source),
    });
  };
  COMMON_SURNAMES
    .filter(surname=>compact.startsWith(surname)&&chars.length>Array.from(surname).length)
    .sort((a,b)=>b.length-a.length)
    .forEach(surname=>pushCandidate(surname,compact.slice(surname.length),'dictionary'));
  const maxPoint=Math.min(3,chars.length-1);
  for(let point=1;point<=maxPoint;point++){
    const guessed=guessNameSplitByLength(compact,point);
    if(guessed) pushCandidate(guessed.sei,guessed.mei,'heuristic');
  }
  return candidates.sort((a,b)=>b.score-a.score||b.sei.length-a.sei.length||a.sei.localeCompare(b.sei,'ja'));
}

function splitJapaneseFullname(fullname){
  const raw=String(fullname||'').trim().replace(/\u3000/g,' ');
  if(!raw) return null;
  const spaced=raw.split(/\s+/).filter(Boolean);
  if(spaced.length>=2){
    return{
      sei:spaced[0],
      mei:spaced.slice(1).join(''),
      source:'space',
      confidence:'high',
      original:raw,
      alternatives:[],
    };
  }
  const compact=raw.replace(/\s+/g,'');
  if(Array.from(compact).length<2) return null;
  const candidates=buildNameSplitCandidates(compact);
  if(!candidates.length) return null;
  const [best,...rest]=candidates;
  const gap=(best?.score||0)-(rest[0]?.score||0);
  const confidence=best.source==='dictionary'
    ?(gap>=10?'high':'medium')
    :(gap>=8?'medium':'low');
  return{
    sei:best.sei,
    mei:best.mei,
    source:best.source,
    confidence,
    original:raw,
    alternatives:rest.slice(0,2).map(item=>({sei:item.sei,mei:item.mei,source:item.source})),
  };
}

function getNameElement(num){
  const last=mod(Number(num)||0,10);
  if(last===1||last===2) return '譛ｨ';
  if(last===3||last===4) return '轣ｫ';
  if(last===5||last===6) return '蝨・;
  if(last===7||last===8) return '驥・;
  return '豌ｴ';
}

function getElementFlow(from,to){
  if(from===to) return{type:'same',label:'蜷梧ｰ・};
  if(GENERATES[from]===to) return{type:'generate',label:'逶ｸ逕・};
  if(GENERATED_BY[from]===to) return{type:'receive',label:'蜿礼函'};
  if(CONTROLS[from]===to) return{type:'control',label:'逶ｸ蜑・};
  if(CONTROLLED_BY[from]===to) return{type:'controlled',label:'陲ｫ蜑・};
  return{type:'neutral',label:'荳ｭ遶・};
}

function getLuckTone(label){
  if(label==='螟ｧ蜷・) return'蜍｢縺・′荵励ｊ繧・☆縺上∫ｵ先棡縺ｫ縺､縺ｪ縺後ｊ繧・☆縺・;
  if(label==='蜷・) return'逹螳溘↓閧ｲ縺ｦ繧・☆縺上∽ｿ｡逕ｨ縺ｸ螟峨ｏ繧翫ｄ縺吶＞';
  if(label==='豕ｨ諢・||label==='蟷ｳ') return'菴ｿ縺・婿谺｡隨ｬ縺ｧ蠑ｷ縺ｿ縺ｫ繧りｪｲ鬘後↓繧よ険繧後ｄ縺吶＞';
  if(label==='蟆丞・') return'諢滓ュ繧・愛譁ｭ縺ｮ豕｢縺悟・繧・☆縺・;
  if(label==='荳ｭ蜃ｶ') return'辟｡逅・ｒ驥阪・繧九→豁ｪ縺ｿ縺悟・繧・☆縺・;
  return'譌ｩ繧√↓謨ｴ縺医ｋ縺ｻ縺ｩ螳牙ｮ壹＠繧・☆縺・;
}

function evaluateThreeTalents(nameJudge){
  const tenElem=getNameElement(nameJudge?.kakus?.[0]?.num);
  const jinElem=getNameElement(nameJudge?.kakus?.[1]?.num);
  const chiElem=getNameElement(nameJudge?.kakus?.[2]?.num);
  const flow1=getElementFlow(tenElem,jinElem);
  const flow2=getElementFlow(jinElem,chiElem);
  const scoreMap={generate:2,same:1.2,receive:0.5,neutral:0,controlled:-1,control:-2};
  const score=(scoreMap[flow1.type]||0)+(scoreMap[flow2.type]||0);
  let label='隱ｿ謨ｴ蝙・;
  let summary='蠑ｷ縺ｿ縺ｯ縺ゅｊ縺ｾ縺吶′縲∝・縺玲婿繧呈紛縺医ｋ縺ｻ縺ｩ邨先棡縺ｮ雉ｪ縺御ｸ翫′繧矩・鄂ｮ縺ｧ縺吶・;
  if(score>=3){
    label='蜷蛾・';
    summary='蝨溷床縺九ｉ陦悟虚縺ｾ縺ｧ豬√ｌ縺碁壹ｊ繧・☆縺上∝巻蜉帙′蠖｢縺ｫ縺ｪ繧翫ｄ縺吶＞驟咲ｽｮ縺ｧ縺吶・;
  }else if(score>=1){
    label='螳牙ｮ壼梛';
    summary='讌ｵ遶ｯ縺ｪ陦晉ｪ√′蟆代↑縺上∫ｩ阪∩荳翫￡繧堤ｶ咏ｶ壹☆繧九→蠑ｷ縺ｿ縺瑚ご縺｡繧・☆縺・・鄂ｮ縺ｧ縺吶・;
  }else if(score<=-2){
    label='闡幄陸蝙・;
    summary='蜀・擇縺ｨ迴ｾ螳溘・蝎帙∩蜷医ｏ縺帙↓雋闕ｷ縺悟・繧・☆縺上∫腸蠅・∈縺ｳ縺碁㍾隕√↓縺ｪ繧矩・鄂ｮ縺ｧ縺吶・;
  }
  return{
    pattern:`${tenElem}-${jinElem}-${chiElem}`,
    label,
    summary,
    score:Number(score.toFixed(1)),
    flows:[flow1,flow2],
    elements:{ten:tenElem,jin:jinElem,chi:chiElem},
  };
}

function evaluateYinYangBalance(nameJudge){
  const chars=[...(nameJudge?.seiChars||[]),...(nameJudge?.meiChars||[])];
  let odd=0,even=0;
  chars.forEach(entry=>((entry.count||0)%2===0?even++:odd++));
  let label='蝮・｡｡蝙・;
  let summary='謚ｼ縺怜・縺励→蜿励￠豁｢繧√・蛻・ｊ譖ｿ縺医′縺励ｄ縺吶￥縲∝ｴ縺ｫ蠢懊§縺ｦ陦ｨ諠・ｒ螟峨∴繧・☆縺・・蛻励〒縺吶・;
  if(odd-even>=2){
    label='髯ｽ蜆ｪ蜍｢';
    summary='閾ｪ蛻・°繧牙虚縺丞鴨縺悟ｼｷ縺上∽ｸｻ蟆取ｨｩ繧呈升繧九⊇縺ｩ譛ｬ譚･縺ｮ蜉帙′蜃ｺ繧・☆縺・・蛻励〒縺吶・;
  }else if(even-odd>=2){
    label='髯ｰ蜆ｪ蜍｢';
    summary='蜿励￠豁｢繧√※謨ｴ縺医ｋ蜉帙′蠑ｷ縺上∫憾豕√ｒ隕ｳ蟇溘＠縺ｦ縺九ｉ蜍輔￥縺ｻ縺ｩ邊ｾ蠎ｦ縺御ｸ翫′繧矩・蛻励〒縺吶・;
  }
  return{odd,even,label,summary};
}

function calcMeimeiPartial(y,m,gender=GENDER){
  const yearCandidatesMap={};
  const monthCandidatesMap={};
  const cnt=getEmptyElementCounter();
  const maxDay=new Date(y,m,0).getDate();
  for(let day=1;day<=maxDay;day++){
    const yearPillar=getGanzhiYear(y,m,day);
    const monthOrder=getSolarMonthOrder(y,m,day);
    const monthPillar=getGanzhiMonth(yearPillar.kan,monthOrder);
    incrementPillarCandidate(yearCandidatesMap,yearPillar,day);
    incrementPillarCandidate(monthCandidatesMap,monthPillar,day);
    accumulatePillarElements(cnt,getPillarDetail('蟷ｴ譟ｱ',yearPillar.kan,yearPillar.zhi,''),0.9);
    accumulatePillarElements(cnt,getPillarDetail('譛域浤',monthPillar.kan,monthPillar.zhi,''),1.15);
  }
  const yearCandidates=getCandidateList(yearCandidatesMap);
  const monthCandidates=getCandidateList(monthCandidatesMap);
  const yearMain=yearCandidates[0];
  const monthMain=monthCandidates[0];
  const seasonBranch=monthMain?.zhi||'';
  const seasonStem=(HIDDEN_STEMS[seasonBranch]||[ZE[seasonBranch]])[0];
  return attachAdvancedMeimeiData({
    mode:'partial',
    precision:'year-month',
    pillars:[
      getPillarDetail('蟷ｴ譟ｱ',yearMain.kan,yearMain.zhi,''),
      getPillarDetail('譛域浤',monthMain.kan,monthMain.zhi,''),
    ],
    dm:null,
    elem:null,
    cnt,
    total:Number(Object.values(cnt).reduce((a,b)=>a+b,0).toFixed(2)),
    birthHour:null,
    useApproxSolarTerms:!SOLAR_TERM_DATA_READY,
    seasonBranch,
    seasonElement:EM[seasonStem]||ZE[seasonBranch],
    strengthLabel:'蟷ｴ譛医・繝ｼ繧ｹ',
    strengthScore:null,
    favorableElements:getWeakElements(cnt,3),
    resourceElement:null,
    outputElement:null,
    wealthElement:null,
    officerElement:null,
    yearCandidates,
    monthCandidates,
  },{
    year:y,month:m,day:null,hour:null,
  },gender);
}

function buildMeimeiInsights(meimei){
  if(!meimei) return null;
  const dominantElements=formatElementRanking(meimei.cnt,2)||'蝨・;
  const weakElements=getWeakElements(meimei.cnt,2).join('繝ｻ');
  const seasonCopy=MONTH_BRANCH_COPY[meimei.seasonBranch]||'蟄｣遽縺ｮ豌苓ｳｪ縺瑚牡豼・￥蜃ｺ繧・☆縺・・鄂ｮ縺ｧ縺吶・;
  if(meimei.mode==='partial'){
    const yearLead=meimei.yearCandidates?.[0];
    const monthLead=meimei.monthCandidates?.[0];
    return{
      core:`譌･縺梧悴蜈･蜉帙・縺溘ａ蟷ｴ譟ｱ繝ｻ譛域浤荳ｭ蠢・・隱ｭ縺ｿ縺ｧ縺吶′縲・{yearLead?.kan||''}${yearLead?.zhi||''}縺ｨ${monthLead?.kan||''}${monthLead?.zhi||''}縺瑚｡ｨ縺ｫ蜃ｺ繧・☆縺・ｪｨ譬ｼ縺ｧ縺吶・{seasonCopy}`,
      timing:meimei.monthCandidates?.length>1
        ?`縺薙・譛医・遽蜈･繧翫ｒ縺ｾ縺溘＄縺溘ａ縲∵怦譟ｱ縺・${meimei.monthCandidates.map(item=>`${item.kan}${item.zhi}`).join(' / ')} 縺ｫ蛻・°繧後ｋ蜿ｯ閭ｽ諤ｧ縺後≠繧翫∪縺吶よ怦蛻昴°譛域忰縺九〒蜃ｺ譁ｹ縺悟ｰ代＠螟峨ｏ繧翫∪縺吶Ａ
        :`縺薙・譛医・譛域浤縺悟ｮ牙ｮ壹＠縺ｦ縺翫ｊ縲・{monthLead?.kan||''}${monthLead?.zhi||''}縺ｮ豌苓ｳｪ縺梧ｯ碑ｼ・噪縺ｾ縺｣縺吶＄蜃ｺ繧・☆縺・怦縺ｧ縺吶Ａ,
      advice:`蟷ｴ譛医・繝ｼ繧ｹ縺ｧ縺ｯ ${dominantElements} 縺悟ｼｷ縺丞・繧・☆縺上・・↓ ${weakElements} 繧呈э隴倥☆繧九→繝舌Λ繝ｳ繧ｹ縺梧紛縺・ｄ縺吶＞蛯ｾ蜷代〒縺吶りｪ慕函譌･縺ｮ譌･縺後ｏ縺九ｋ縺ｨ縲∵律譟ｱ繝ｻ騾壼､画弌繝ｻ霄ｫ蠑ｷ蠑ｱ縺ｾ縺ｧ荳谿ｵ豺ｱ縺冗音螳壹〒縺阪∪縺吶Ａ,
      insightCards:[
        {kicker:'CLIMATE',title:'陦ｨ縺ｫ蜃ｺ繧・☆縺・ｰ苓ｳｪ',body:`${seasonCopy} 蟷ｴ譛医□縺代〒繧ゅ∝､悶°繧芽ｦ九∴繧句魂雎｡縺ｨ閧ｲ縺｣縺ｦ縺阪◆迺ｰ蠅・・逋悶・縺九↑繧願ｪｭ繧√∪縺吶Ａ},
        {kicker:'DOMINANT',title:'蠑ｷ縺丞・繧・☆縺・ｺ碑｡・,body:`縺薙・譛医↓蠑ｷ縺丞・繧・☆縺・・縺ｯ ${dominantElements} 縺ｧ縺吶ょｽｹ蜑ｲ縺ｨ縺励※縺ｯ縲∫岼縺ｮ蜑阪・豬√ｌ繧貞虚縺九☆繧医ｊ縲後←縺・紛縺医ｋ縺九阪′骰ｵ縺ｫ縺ｪ繧翫ｄ縺吶＞驟咲ｽｮ縺ｧ縺吶Ａ},
        {kicker:'PRECISION',title:'隱ｭ縺ｿ縺ｮ繝悶Ξ繧・☆縺・せ',body:meimei.monthCandidates?.length>1?`譛域浤蛟呵｣懊′隍・焚縺ゅｋ縺溘ａ縲∵怦蛻昴→譛域忰縺ｧ縺ｯ蜊ｰ雎｡繧・ｾ玲э蠖ｹ蜑ｲ縺ｮ蜃ｺ譁ｹ縺悟ｰ代＠螟峨ｏ繧句庄閭ｽ諤ｧ縺後≠繧翫∪縺吶Ａ:`縺薙・譛医・蛟呵｣懊・謠ｺ繧後′蟆代↑縺上∝ｹｴ譛医□縺代〒繧るｪｨ譬ｼ縺梧ｯ碑ｼ・噪縺ｯ縺｣縺阪ｊ隱ｭ繧√∪縺吶Ａ},
        {kicker:'NEXT',title:'邊ｾ蠎ｦ繧剃ｸ翫￡繧句・蜿｣',body:'譌･縺後ｏ縺九ｋ縺ｨ縲瑚・蛻・・闃ｯ縲阪→縲御ｽ輔↓雋闕ｷ縺後°縺九ｊ繧・☆縺・°縲阪′譏守｢ｺ縺ｫ縺ｪ繧翫∪縺吶ゆｻ翫・蟷ｴ譟ｱ繝ｻ譛域浤縺九ｉ螟悶↓迴ｾ繧後ｄ縺吶＞蛯ｾ蜷代ｒ驥崎ｦ悶＠縺ｦ隱ｭ繧薙〒縺・∪縺吶・},
      ],
      tags:[
        `蟷ｴ譟ｱ蛟呵｣・${meimei.yearCandidates.map(item=>item.key).join(' / ')}`,
        `譛域浤蛟呵｣・${meimei.monthCandidates.map(item=>item.key).join(' / ')}`,
        `蠑ｷ縺丞・繧・☆縺・ｺ碑｡・${dominantElements}`,
      ],
      candidateCards:[
        {label:'蟷ｴ譟ｱ蛟呵｣・,value:meimei.yearCandidates.map(item=>item.key).join(' / '),copy:meimei.yearCandidates.map(item=>`${formatCandidateDays(item.days)}縺ｫ蜃ｺ繧・☆縺Я).join('・・)},
        {label:'譛域浤蛟呵｣・,value:meimei.monthCandidates.map(item=>item.key).join(' / '),copy:meimei.monthCandidates.map(item=>`${formatCandidateDays(item.days)}縺ｫ蜃ｺ繧・☆縺Я).join('・・)},
      ],
      note:`莠碑｡後・蛛上ｊ縺ｯ ${dominantElements} 縺悟━蜍｢縺ｧ縺吶・{weakElements} 縺ｮ蜍輔″繧堤函豢ｻ縺ｫ雜ｳ縺吶→縲∝ｹｴ譛医・繝ｼ繧ｹ縺ｧ繧りｪｭ縺ｿ縺ｮ螳滓─縺悟・繧・☆縺上↑繧翫∪縺吶Ａ,
    };
  }

  const topGods=countTenGodsFromPillars(meimei.pillars).slice(0,2);
  const branchLead=meimei.branchDynamics?.relations?.[0]||null;
  const godText=topGods.length?topGods.map(item=>TEN_GOD_SHORT[item.key]||item.key).join('繝ｻ'):'繝舌Λ繝ｳ繧ｹ蝙九・雉・ｳｪ';
  const currentCycle=meimei.fortune?.currentCycle||null;
  const strengthText=meimei.strengthLabel==='霄ｫ蠑ｷ'
    ?'閾ｪ蜉帙〒螻髱｢繧貞虚縺九☆蜉帙′蠑ｷ縺上∵款縺怜・縺励ｒ豢ｻ縺九☆縺ｻ縺ｩ謇句ｿ懊∴繧貞叙繧翫ｄ縺吶＞蜻ｽ蠑上〒縺吶・
    :meimei.strengthLabel==='繧・ｄ霄ｫ蠑ｷ'
      ?'謚ｼ縺怜・縺励→螳牙ｮ壽─繧剃ｸ｡遶九＠繧・☆縺上∽ｸｻ蟆取ｨｩ繧呈升繧九→豬√ｌ縺梧紛縺・ｄ縺吶＞蜻ｽ蠑上〒縺吶・
      :meimei.strengthLabel==='霄ｫ蠑ｱ'
        ?'迺ｰ蠅・ｄ逶ｸ謇九・蠖ｱ髻ｿ繧貞女縺代ｄ縺吶＞縺ｶ繧薙∵─蜿玲ｧ縺ｨ隕ｳ蟇溘・邊ｾ蠎ｦ縺碁ｫ倥＞蜻ｽ蠑上〒縺吶・
        :meimei.strengthLabel==='繧・ｄ霄ｫ蠑ｱ'
          ?'蜉ｩ縺代ｄ豬√ｌ繧貞叙繧願ｾｼ繧縺ｻ縺ｩ蜉帙′蜃ｺ繧・☆縺上∝腰迢ｬ繧医ｊ騾｣謳ｺ縺ｧ莨ｸ縺ｳ繧・☆縺・多蠑上〒縺吶・
          :'蛛上ｊ縺悟ｼｷ縺吶℃縺壹∫憾豕√↓蠢懊§縺ｦ蠖ｹ蜑ｲ繧貞・繧頑崛縺医ｄ縺吶＞蜻ｽ蠑上〒縺吶・;
  return{
    core:`${STEM_ARCHETYPES[meimei.dm]||''}縲・{seasonCopy}${strengthText}`,
    timing:`蜻ｽ蠑丞・菴薙〒縺ｯ ${dominantElements} 縺悟燕縺ｫ蜃ｺ繧・☆縺上・壼､画弌縺ｧ縺ｯ ${godText} 縺悟ｼｷ縺ｿ縺ｨ縺励※陦ｨ繧後ｄ縺吶＞豬√ｌ縺ｧ縺吶Ａ,
    advice:`菴ｿ縺・ｄ縺吶＞縺ｮ縺ｯ ${meimei.favorableElements.join('繝ｻ')} 縺ｮ蜍輔″縺ｧ縺吶る・↓ ${weakElements} 縺瑚埋縺上↑繧九→蛛上ｊ縺悟ｼｷ縺ｾ繧翫ｄ縺吶＞縺ｮ縺ｧ縲∬｡悟虚繧・腸蠅・〒陬懊≧縺ｨ螳牙ｮ壹＠縺ｾ縺吶・{currentCycle?` 莉翫・螟ｧ驕・${currentCycle.pillar} 縺碁㍾縺ｪ繧翫ｄ縺吶￥縲・{currentCycle.copy}`:''}`,
    insightCards:[
      {kicker:'CORE',title:`${meimei.dm}譌･荳ｻ縺ｮ霆ｸ`,body:`${STEM_ARCHETYPES[meimei.dm]||''}縲・{seasonCopy}`},
      {kicker:'STRENGTH',title:'蜃ｺ繧・☆縺・ｼｷ縺ｿ',body:`${strengthText} 蜻ｽ蠑上〒縺ｯ ${dominantElements} 縺梧ｿ・￥縲・{godText} 縺ｨ縺励※陦ｨ縺ｫ蜃ｺ繧・☆縺・だ蜷代〒縺吶Ａ},
      {kicker:'RISK',title:'蛛上ｊ繧・☆縺・・繧､繝ｳ繝・,body:meimei.strengthLabel.includes('霄ｫ蠑ｷ')?`閾ｪ蜉帙〒謚ｼ縺怜・繧後ｋ蜿埼擇縲∝捉蝗ｲ縺ｮ繝壹・繧ｹ繧貞ｾ・◆縺壹↓騾ｲ繧√☆縺弱ｋ縺ｨ鞫ｩ謫ｦ縺悟・繧・☆縺・多蠑上〒縺吶Ａ:`蜿励￠豁｢繧√ｋ蜉帙′鬮倥＞蜿埼擇縲∫腸蠅・ｄ莠ｺ縺ｮ蠖ｱ髻ｿ繧呈干縺郁ｾｼ縺ｿ縺吶℃繧九→豸郁励＠繧・☆縺・多蠑上〒縺吶Ａ},
      {kicker:'BALANCE',title:'謨ｴ縺域婿',body:`蝟懃･槫呵｣懊・ ${meimei.favorableElements.join('繝ｻ')} 縺ｧ縺吶ら函豢ｻ繧・ｻ穂ｺ九〒縺昴・隕∫ｴ繧定ｶｳ縺吶⊇縺ｩ縲∝多蠑上・濶ｯ縺輔′螳牙ｮ壹＠縺ｦ蜃ｺ繧・☆縺上↑繧翫∪縺吶Ａ},
      ...(branchLead?[{kicker:'DYNAMICS',title:'蝨ｰ謾ｯ縺ｮ髢｢菫よｧ',body:branchLead.summary}]:[]),
    ],
    tags:[
      `${meimei.dm}譌･荳ｻ`,
      `霄ｫ蠑ｷ蠑ｱ ${meimei.strengthLabel}`,
      `蜆ｪ蜍｢莠碑｡・${dominantElements}`,
      topGods.length?`蠑ｷ縺丞・繧・☆縺・弌 ${topGods.map(item=>item.key).join('繝ｻ')}`:'',
      branchLead?`蝨ｰ謾ｯ髢｢菫・${branchLead.left}${branchLead.label}${branchLead.right}`:'',
    ].filter(Boolean),
    candidateCards:[],
    note:`${dominantElements} 縺悟ｼｷ縺上・{weakElements} 繧定｣懊≧諢剰ｭ倥′繝舌Λ繝ｳ繧ｹ隱ｿ謨ｴ縺ｫ蠖ｹ遶九■縺ｾ縺吶・{branchLead?` 蜻ｽ蠑丞・縺ｧ縺ｯ ${branchLead.left} 縺ｨ ${branchLead.right} 縺ｮ ${branchLead.label} 縺悟・縺ｦ縺翫ｊ縲・{BRANCH_RELATION_COPY[branchLead.type]}`:''}${meimei.birthHour===null?' 蜃ｺ逕滓凾蛻ｻ縺ｯ荳肴・縺ｨ縺励※譎よ浤繧剃ｻｮ鄂ｮ縺阪＠縺ｦ縺・∪縺吶・:''}`,
  };
}

function buildNameJudgeInsights(nameJudge){
  if(!nameJudge) return null;
  const jin=nameJudge.kakus[1];
  const gai=nameJudge.kakus[3];
  const sou=nameJudge.kakus[4];
  const chi=nameJudge.kakus[2];
  const jinLuck=getKakuLuck(jin.num);
  const gaiLuck=getKakuLuck(gai.num);
  const souLuck=getKakuLuck(sou.num);
  const chiLuck=getKakuLuck(chi.num);
  const jinElem=getNameElement(jin.num);
  const gaiElem=getNameElement(gai.num);
  const souElem=getNameElement(sou.num);
  const chiElem=getNameElement(chi.num);
  const threeTalent=evaluateThreeTalents(nameJudge);
  const yinYang=evaluateYinYangBalance(nameJudge);
  const splitNotes={
    space:'蟋灘錐縺ｯ繧ｹ繝壹・繧ｹ蛹ｺ蛻・ｊ縺ｧ蛻､螳壹＠縺ｦ縺・∪縺吶・,
    dictionary:'繧ｹ繝壹・繧ｹ縺ｪ縺怜・蜉帙ｒ荳闊ｬ逧・↑蟋薙・霎樊嶌縺九ｉ蛻・牡縺励※縺・∪縺吶・,
    heuristic:'繧ｹ繝壹・繧ｹ縺ｪ縺怜・蜉帙ｒ譁・ｭ玲焚縺九ｉ莉ｮ蛻・牡縺励※縺・∪縺吶ょｧ薙→蜷阪ｒ蛹ｺ蛻・ｋ縺ｨ邊ｾ蠎ｦ縺御ｸ翫′繧翫∪縺吶・,
  };
  const alternativeText=(nameJudge.split?.alternatives||[])
    .map(item=>`${item.sei} ${item.mei}`)
    .join(' / ');
  return{
    core:`莠ｺ譬ｼ${jin.num}逕ｻ縺ｯ ${NAME_ELEMENT_COPY[jinElem]} 繧貞昇繧区ｼ縺ｧ縲・{NAME_ELEMENT_DETAIL[jinElem]}蛯ｾ蜷代′縺ゅｊ縺ｾ縺吶・{getLuckTone(jinLuck.lbl)}縺ｮ縺ｧ縲√％縺ｮ蜷榊燕縺ｧ縺ｯ縲後←縺・官繧貞・縺吶°縲阪′驥崎ｦ√↓縺ｪ繧翫∪縺吶Ａ,
    timing:`蝨ｰ譬ｼ${chi.num}逕ｻ縺ｯ ${NAME_ELEMENT_COPY[chiElem]} 縺ｮ蜃ｺ譁ｹ繧堤､ｺ縺励・{getLuckTone(chiLuck.lbl)}縺溘ａ縲∬凶縺・凾譛溘ｄ譁ｰ縺励＞迺ｰ蠅・〒縺ｮ遶九■荳翫′繧頑婿縺ｫ迚ｹ蠕ｴ縺悟・繧・☆縺・〒縺吶Ａ,
    advice:`邱乗ｼ${sou.num}逕ｻ縺ｯ ${NAME_ELEMENT_COPY[souElem]} 繧剃ｺｺ逕溷ｾ悟濠縺ｸ驕九・縺ｾ縺吶・{getLuckTone(souLuck.lbl)}縺ｮ縺ｧ縲・聞譛溘〒縺ｯ ${NAME_ELEMENT_DETAIL[souElem]}蜍輔″譁ｹ縺悟錐蜑阪・蠑ｷ縺ｿ繧呈ｴｻ縺九＠繧・☆縺上＠縺ｾ縺吶Ａ,
    insightCards:[
      {kicker:'PERSONA',title:'莠ｺ譬ｼ縺檎､ｺ縺呎ｸ蠢・,body:`莠ｺ譬ｼ${jin.num}逕ｻ繝ｻ${jinLuck.lbl}縲・{NAME_ELEMENT_DETAIL[jinElem]}縺溘ａ縲√％縺ｮ蜷榊燕縺ｧ縺ｯ縲瑚・蛻・・霆ｸ縺ｮ蜃ｺ縺玲婿縲阪′譛繧る㍾隕√↓縺ｪ繧翫∪縺吶Ａ},
      {kicker:'SOCIAL',title:'螟匁ｼ縺檎､ｺ縺吝ｯｾ莠ｺ髱｢',body:`螟匁ｼ${gai.num}逕ｻ繝ｻ${gaiLuck.lbl}縲・{NAME_ELEMENT_DETAIL[gaiElem]}縺溘ａ縲∫ｬｬ荳蜊ｰ雎｡繧・ｺｺ縺ｨ縺ｮ霍晞屬諢溘↓縺薙・蛯ｾ蜷代′蜃ｺ繧・☆縺上↑繧翫∪縺吶Ａ},
      {kicker:'THREE TALENTS',title:'荳画燕驟咲ｽｮ縺ｮ豬√ｌ',body:`${threeTalent.pattern}縺ｮ${threeTalent.label}縲・{threeTalent.summary}`},
      {kicker:'YIN / YANG',title:'髯ｰ髯ｽ縺ｮ荳ｦ縺ｳ',body:`髯ｽ${yinYang.odd} / 髯ｰ${yinYang.even} 縺ｮ${yinYang.label}縲・{yinYang.summary}`},
    ],
    tags:[
      `莠ｺ譬ｼ${jin.num}逕ｻ ${jinLuck.lbl}`,
      `邱乗ｼ${sou.num}逕ｻ ${souLuck.lbl}`,
      `荳画燕 ${threeTalent.pattern} ${threeTalent.label}`,
      `髯ｰ髯ｽ ${yinYang.label}`,
    ],
    splitNote:[splitNotes[nameJudge.split?.source]||'',alternativeText?`蛻･蛟呵｣・ ${alternativeText}`:''].filter(Boolean).join(' '),
    threeTalent,
    yinYang,
  };
}

function getElementThemeList(counter,limit=2){
  return getRankedEntries(counter,limit)
    .filter(item=>item.value>0)
    .map(item=>NAME_ELEMENT_COPY[item.key]||item.key);
}

function getBirthStyleCopy(strengthLabel=''){
  if(strengthLabel==='霄ｫ蠑ｷ') return '閾ｪ蛻・°繧画ｵ√ｌ繧剃ｽ懊ｋ縺ｻ縺・′隱ｿ蟄舌ｒ荳翫￡繧・☆縺・ち繧､繝励〒縺吶・;
  if(strengthLabel==='繧・ｄ霄ｫ蠑ｷ') return '蜑阪↓蜃ｺ繧句ｴ髱｢縺ｧ縺ｯ迚ｹ縺ｫ蜉帙ｒ蜃ｺ縺励ｄ縺吶＞繧ｿ繧､繝励〒縺吶・;
  if(strengthLabel==='霄ｫ蠑ｱ') return '蜻ｨ蝗ｲ縺ｮ豬√ｌ繧貞女縺大叙繧翫↑縺後ｉ蜍輔￥縺ｨ邊ｾ蠎ｦ縺御ｸ翫′繧翫ｄ縺吶＞繧ｿ繧､繝励〒縺吶・;
  if(strengthLabel==='繧・ｄ霄ｫ蠑ｱ') return '荳莠ｺ縺ｧ謚ｱ縺医ｋ繧医ｊ縲∝勧縺代ｄ豬√ｌ繧貞叙繧雁・繧後ｋ縺ｨ謖√■蜻ｳ縺悟・繧・☆縺・ち繧､繝励〒縺吶・;
  return '蜑阪↓蜃ｺ繧句ｽｹ縺ｨ謾ｯ縺医ｋ蠖ｹ繧貞・繧頑崛縺医↑縺後ｉ蜉帙ｒ蜃ｺ縺励ｄ縺吶＞繧ｿ繧､繝励〒縺吶・;
}

function getFortuneToneText(item){
  if(!item) return '';
  return FORTUNE_TEN_GOD_COPY[item.tenGod]||'蠖ｹ蜑ｲ繧・髄縺榊粋縺・婿縺ｮ蛻・ｊ譖ｿ縺医′襍ｷ縺薙ｊ繧・☆縺・凾譛溘〒縺吶・;
}

function buildBirthPlainInsight(meimei){
  if(!meimei) return null;
  const seasonCopy=MONTH_BRANCH_COPY[meimei.seasonBranch]||'蟄｣遽縺ｮ蠖ｱ髻ｿ縺瑚牡豼・￥蜃ｺ繧・☆縺・函縺ｾ繧後〒縺吶・;
  const strongThemes=getElementThemeList(meimei.cnt,2);
  const supportThemes=getWeakElements(meimei.cnt,2).map(key=>NAME_ELEMENT_COPY[key]||key).filter(Boolean);
  const strongText=strongThemes.join('繝ｻ')||'螳牙ｮ・;
  const supportText=supportThemes.join('繝ｻ')||'莨第・繧・ｪｿ謨ｴ';
  if(meimei.mode==='partial'){
    return{
      overview:`${seasonCopy} 莉雁屓縺ｯ逕溘∪繧後◆譌･縺梧悴蜈･蜉帙・縺溘ａ縲∝､悶°繧我ｼ昴ｏ繧翫ｄ縺吶＞髮ｰ蝗ｲ豌励ｄ縲∬ご縺｣縺ｦ縺阪◆迺ｰ蠅・→縺ｮ逶ｸ諤ｧ繧剃ｸｭ蠢・↓隕九※縺・∪縺吶Ａ,
      timing:meimei.monthCandidates?.length>1
        ?'逕溘∪繧後◆譌･縺ｮ菴咲ｽｮ縺ｫ繧医▲縺ｦ縲∝魂雎｡繧・ｾ玲э縺ｪ蜍輔″譁ｹ縺ｫ蟆代＠蟷・′蜃ｺ繧・☆縺・凾譛溘〒縺吶・
        :'螟悶↓蜃ｺ繧・☆縺・峅蝗ｲ豌励・豈碑ｼ・噪縺ｾ縺｣縺吶＄隱ｭ縺ｿ蜿悶ｊ繧・☆縺・函縺ｾ繧後〒縺吶・,
      advice:`蠕玲э縺輔・ ${strongText} 縺ｫ蜃ｺ繧・☆縺上・{supportText} 繧呈э隴倥＠縺ｦ雜ｳ縺吶→蜈ｨ菴薙・繝舌Λ繝ｳ繧ｹ縺梧紛縺・ｄ縺吶￥縺ｪ繧翫∪縺吶Ａ,
    };
  }
  const longFlow=getFortuneToneText(meimei.fortune?.currentCycle);
  const yearFlow=getFortuneToneText(meimei.fortune?.annual?.find(item=>item.isCurrent));
  return{
    overview:`${STEM_ARCHETYPES[meimei.dm]||'閾ｪ蛻・↑繧翫・蛟区ｧ縺後・縺｣縺阪ｊ蜃ｺ繧・☆縺・函縺ｾ繧後〒縺吶・} ${seasonCopy} ${getBirthStyleCopy(meimei.strengthLabel)}`,
    timing:[longFlow?`蟆代＠髟ｷ縺・岼縺ｧ隕九ｋ縺ｨ縲・{longFlow}`:'',yearFlow?`縺薙・1蟷ｴ縺ｯ縲・{yearFlow}`:''].filter(Boolean).join(' '),
    advice:`蠕玲э縺輔・ ${strongText} 縺ｫ蜃ｺ繧・☆縺上・{supportText} 繧呈э隴倥＠縺ｦ陬懊≧縺ｨ螳牙ｮ壹＠繧・☆縺上↑繧翫∪縺吶・{meimei.birthHour===null?' 逕溘∪繧後◆譎る俣縺御ｸ肴・縺ｪ縺溘ａ縲∫ｴｰ縺九↑蜃ｺ譁ｹ縺ｫ縺ｯ蟆代＠蟷・ｒ謖√◆縺帙※縺・∪縺吶・:''}`,
  };
}

function buildNamePlainInsight(nameJudge){
  if(!nameJudge) return null;
  const jinElem=getNameElement(nameJudge.kakus[1].num);
  const gaiElem=getNameElement(nameJudge.kakus[3].num);
  const souElem=getNameElement(nameJudge.kakus[4].num);
  const threeTalent=evaluateThreeTalents(nameJudge);
  const yinYang=evaluateYinYangBalance(nameJudge);
  const notes=[];
  if(nameJudge.split?.confidence==='low') notes.push('蜷榊燕縺ｮ蛹ｺ蛻・ｊ縺ｯ莉ｮ鄂ｮ縺阪↑縺ｮ縺ｧ縲∝ｧ薙→蜷阪ｒ蛻・￠繧九→縺輔ｉ縺ｫ螳牙ｮ壹＠縺ｾ縺吶・);
  if(nameJudge.approxChars.length) notes.push('荳驛ｨ縺ｮ迴阪＠縺・ｭ励・縲∬ｿ代＞謨ｰ縺域婿縺ｧ陬懊▲縺ｦ縺・∪縺吶・);
  return{
    overview:`蜷榊燕縺九ｉ蜿励￠繧句魂雎｡縺ｯ縲・{NAME_ELEMENT_DETAIL[jinElem]}蛯ｾ蜷代′縺ゅｊ縲∬・蛻・・霆ｸ繧貞・縺吶⊇縺ｩ濶ｯ縺輔′莨昴ｏ繧翫ｄ縺吶＞繧ｿ繧､繝励〒縺吶Ａ,
    timing:`隨ｬ荳蜊ｰ雎｡繧・ｺｺ縺ｨ縺ｮ霍晞屬諢溘〒縺ｯ縲・{NAME_ELEMENT_DETAIL[gaiElem]}蜃ｺ譁ｹ縺悟燕縺ｫ蜃ｺ繧・☆縺・だ蜷代′縺ゅｊ縺ｾ縺吶・{threeTalent.summary}`,
    advice:`蜈ｨ菴薙→縺励※縺ｯ縲・{yinYang.summary} 髟ｷ縺剰ｦ九ｋ縺ｨ縲・{NAME_ELEMENT_DETAIL[souElem]}蜍輔″譁ｹ縺悟錐蜑阪・濶ｯ縺輔ｒ豢ｻ縺九＠繧・☆縺上↑繧翫∪縺吶・{notes.length?` ${notes.join(' ')}`:''}`,
  };
}

function buildLifePatternPlainText(lp=LP){
  if(!lp) return '隱慕函譌･縺ｮ譌･縺梧悴蜈･蜉帙・縺溘ａ縲√％縺ｮ隕ｳ轤ｹ縺ｯ莉雁屓縺ｯ菴ｿ縺｣縺ｦ縺・∪縺帙ｓ縲・;
  const card=ORACLE[lp];
  return `${card?.msg||'閾ｪ蛻・ｉ縺励＆縺悟・繧・☆縺・虚縺肴婿縺後≠繧翫∪縺吶・}${card?.name?` 縺昴・莠ｺ繧峨＠縺輔・霆ｸ縺ｨ縺励※縲・{card.name}縲阪・繝・・繝槭′驥阪↑繧翫ｄ縺吶＞蛯ｾ蜷代〒縺吶Ａ:''}`;
}

