function renderDossierRichBodyHTML(text=''){
  const sections=splitSections(text);
  if(!sections.length) return renderStructuredBlocksHTML(text);
  return sections.map(section=>{
    const parsed=parseStructuredSection(section);
    return`
      <div class="dossier-subsection">
        <div class="dossier-subsection-title">${escapeHtml(parsed.title||'蜀・ｮｹ')}</div>
        ${renderStructuredBlocksHTML(parsed.body||'')}
      </div>`;
  }).join('');
}

function renderDossierIncludedSections(){
  const sections=getDossierIncludedSections();
  if(!sections.length) return '';
  return`
    <div class="dossier-proof">
      <div class="dossier-proof-head">
        <div>
          <div class="dossier-proof-eyebrow">菫晏ｭ伜・螳ｹ</div>
          <div class="dossier-proof-title">縺薙・髑大ｮ壽嶌縺ｫ蜈･繧句・螳ｹ</div>
        </div>
        <div class="dossier-proof-copy">繧ｫ繝ｼ繝牙頃縺・・邨先棡縺縺代〒縺ｪ縺上∝錐蜑阪・逕溘∪繧後・菴馴ｨ薙お繝斐た繝ｼ繝峨°繧芽ｦ九∴縺溷だ蜷代∪縺ｧ蜷ｫ繧√※縲・蝗槫・縺ｮ髑大ｮ壹ｒ縺ｾ縺ｨ繧√※菫晏ｭ倥〒縺阪ｋ蠖｢縺ｫ縺励※縺・∪縺吶・/div>
      </div>
    </div>
    <div class="dossier-grid">
      ${sections.map(section=>`
        <div class="dossier-card wide">
          <div class="dossier-card-eyebrow">${escapeHtml(section.eyebrow||'蜀・ｮｹ')}</div>
          <div class="dossier-card-title">${escapeHtml(section.title||'髑大ｮ壼・螳ｹ')}</div>
          <div class="dossier-card-body rich">${renderDossierRichBodyHTML(section.body||'')}</div>
        </div>
      `).join('')}
    </div>`;
}

function buildDossierPlainText(data){
  const safeData={...buildFallbackDossier(),...(data||{})};
  const blocks=[
    safeData.TITLE||'髑大ｮ壽嶌',
    safeData.SUBTITLE||'',
    `笆 譛蛻昴↓邨占ｫ暴n${safeData.HEADLINE||''}`,
    `笆 縺・∪襍ｷ縺阪※縺・ｋ縺薙→\n${safeData.CORE||''}`,
    `笆 蛻､譁ｭ縺ｮ蛻・°繧檎岼\n${safeData.TIMING||''}`,
    `笆 繧・ｉ縺ｪ縺・⊇縺・′縺・＞縺薙→\n${sectionLines(safeData.WARNING).join('\n')}`,
    `笆 7譌･莉･蜀・↓繧・ｋ縺薙→\n${sectionLines(safeData.ACTION7).map((item,index)=>`${index+1}. ${item}`).join('\n')}`,
    `笆 30譌･縺ｧ謨ｴ縺医ｋ縺薙→\n${sectionLines(safeData.ACTION30).map((item,index)=>`${index+1}. ${item}`).join('\n')}`,
    `笆 騾ｲ縺ｿ繧・☆縺上↑繧九し繧､繝ｳ\n${sectionLines(safeData.LUCK).join('\n')}`,
    `笆 蛻､譁ｭ縺ｮ霆ｸ\n${sectionLines(safeData.KEYWORDS).join('\n')||String(safeData.KEYWORDS||'').split('/').map(item=>item.trim()).filter(Boolean).join('\n')}`,
    `笆 隱ｭ縺ｿ霑斐☆縺ｨ縺阪・險闡噂n${safeData.CLOSING||''}`,
    ...getDossierIncludedSections().map(section=>`笆 ${section.title}\n${section.body}`)
  ];
  return blocks.map(block=>String(block||'').trim()).filter(Boolean).join('\n\n');
}

