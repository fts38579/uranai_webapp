// API KEY MANAGEMENT
// 笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武
function loadApiKey(){
  // 髢狗匱譎ゅ・縺ｿ縲∫峩謗･API謗･邯夂畑縺ｮ繧ｭ繝ｼ繧定ｪｭ縺ｿ霎ｼ繧
  const saved=sessionStorage.getItem('uranai-apikey')||'';
  API_KEY=saved||OPERATOR_API_KEY;
  // 髢狗匱閠・Δ繝ｼ繝画凾縺ｮ縺ｿ險ｭ螳壹・繧ｿ繝ｳ繝ｻ繝舌ャ繧ｸ繧定｡ｨ遉ｺ
  if(DEV_MODE){
    const btn=document.getElementById('settings-btn');
    if(btn) btn.style.display='flex';
    const badge=document.getElementById('dev-badge');
    if(badge) badge.style.display='block';
  }
  updateKeyIndicator();
}

function openSettings(){
  if(!DEV_MODE) return; // 髢狗匱閠・Δ繝ｼ繝我ｻ･螟悶〒縺ｯ髢九°縺ｪ縺・
  document.getElementById('apikey-input').value=API_KEY;
  updateKeyStatus(API_KEY);
  document.getElementById('modal-cancel-btn').style.display='block';
  document.getElementById('settings-modal').classList.add('on');
}

function closeSettings(){
  document.getElementById('settings-modal').classList.remove('on');
}

function saveApiKey(){
  const val=document.getElementById('apikey-input').value.trim();
  if(!val){
    updateKeyStatus('','API繧ｭ繝ｼ繧貞・蜉帙＠縺ｦ縺上□縺輔＞');
    return;
  }
  if(!val.startsWith('sk-ant-')){
    updateKeyStatus('','縲茎k-ant-縲阪°繧牙ｧ九∪繧九く繝ｼ繧貞・蜉帙＠縺ｦ縺上□縺輔＞');
    return;
  }
  API_KEY=val;
  sessionStorage.setItem('uranai-apikey',val);
  updateKeyIndicator();
  closeSettings();
  showToast('API繧ｭ繝ｼ繧剃ｿ晏ｭ倥＠縺ｾ縺励◆');
}

function updateKeyStatus(key,errMsg=''){
  const el=document.getElementById('key-status');
  if(errMsg){el.className='key-status ng';el.textContent='笞 '+errMsg;return;}
  if(key&&key.startsWith('sk-ant-')){
    el.className='key-status ok';
    el.textContent='笨・繧ｭ繝ｼ縺瑚ｨｭ螳壹＆繧後※縺・∪縺呻ｼ・+key.slice(0,12)+'窶ｦ・・;
  }else{
    el.className='key-status ng';
    el.textContent='笨・繧ｭ繝ｼ縺梧悴險ｭ螳壹〒縺・;
  }
}

function updateKeyIndicator(){
  const btn=document.getElementById('settings-btn');
  if(!btn) return;
  btn.classList.toggle('key-ok',!!(API_KEY&&API_KEY.startsWith('sk-ant-')));
}

// 笏笏笏 API蜈ｱ騾壼他縺ｳ蜃ｺ縺冷楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
function canUseProxy(){
  return location.protocol==='http:'||location.protocol==='https:';
}

function canUseDirectApi(){
  return LOCAL_TEST_RUNTIME&&DEV_MODE&&!!(API_KEY&&API_KEY.startsWith('sk-ant-'));
}

function makeAppError(code,userMessage=''){
  const err=new Error(code);
  err.code=code;
  err.userMessage=userMessage;
  return err;
}

async function readJsonSafe(res){
  try{return await res.json();}catch(e){return null;}
}

function getServerHealthViewModel(){
  if(!canUseProxy()){
    return{
      cls:'warn',
      title:'繝ｭ繝ｼ繧ｫ繝ｫ繝輔ぃ繧､繝ｫ陦ｨ遉ｺ荳ｭ',
      detail:'AI謗･邯夂｢ｺ隱阪・ http://127.0.0.1:3000 縺ｮ繧医≧縺ｫ server.js 邨檎罰縺ｧ髢九＞縺溘→縺阪□縺題｡後∴縺ｾ縺吶・
    };
  }
  if(!RUNTIME_HEALTH.checked){
    return{
      cls:'warn',
      title:'辟｡譁僭PT / 譛画侭Claude 縺ｮ謗･邯夂憾諷九ｒ遒ｺ隱阪＠縺ｦ縺・∪縺・,
      detail:'server.js 縺ｮ謗･邯夂憾諷九ｒ遒ｺ隱阪＠縺ｦ縺・∪縺吶・
    };
  }
  if(!RUNTIME_HEALTH.reachable){
    return{
      cls:'bad',
      title:'AI繧ｵ繝ｼ繝舌・縺ｫ謗･邯壹〒縺阪∪縺帙ｓ',
      detail:'`start-uranai.ps1` 縺九ｉ襍ｷ蜍輔＠縺ｦ縺上□縺輔＞縲ら┌譁咏沿縺ｯ `./setup-openai.ps1`縲∵怏譁咏沿縺ｯ `./setup-anthropic.ps1` 縺ｧ `.env` 繧呈紛縺医ｉ繧後∪縺吶・
    };
  }
  if(RUNTIME_HEALTH.openai&&RUNTIME_HEALTH.anthropic){
    return{
      cls:'ok',
      title:'辟｡譁僭PT / 譛画侭Claude 縺ｨ繧ゅ↓貅門ｙOK',
      detail:'辟｡譁咏沿縺ｯ GPT-5.4 mini縲∵怏譁咏沿縺ｯ Claude Opus 邉ｻ縺ｧ蜻ｼ縺ｳ蜃ｺ縺帙ｋ迥ｶ諷九〒縺吶・
    };
  }
  if(RUNTIME_HEALTH.openai&&!RUNTIME_HEALTH.anthropic){
    return{
      cls:'warn',
      title:'辟｡譁僭PT縺ｮ縺ｿ貅門ｙOK',
      detail:'辟｡譁咏沿縺ｮ GPT-5.4 mini 縺ｯ菴ｿ縺医∪縺吶′縲∵怏譁咏沿縺ｮ Claude 縺ｯ譛ｪ謗･邯壹〒縺吶Ａ.env` 縺ｫ `ANTHROPIC_API_KEY` 繧定ｿｽ蜉縺励※縺上□縺輔＞縲・
    };
  }
  if(!RUNTIME_HEALTH.openai&&RUNTIME_HEALTH.anthropic){
    return{
      cls:'warn',
      title:'譛画侭Claude縺ｮ縺ｿ貅門ｙOK',
      detail:'譛画侭迚医・ Claude 縺ｯ菴ｿ縺医∪縺吶′縲∫┌譁咏沿縺ｮ GPT-5.4 mini 縺ｯ譛ｪ謗･邯壹〒縺吶Ａ.env` 縺ｫ `OPENAI_API_KEY` 繧定ｿｽ蜉縺励※縺上□縺輔＞縲・
    };
  }
  return{
    cls:'warn',
    title:'辟｡譁僭PT / 譛画侭Claude 縺ｨ繧ゅ↓譛ｪ謗･邯・,
    detail:'`.\\setup-openai.ps1` 縺ｨ `.\\setup-anthropic.ps1` 繧貞ｮ溯｡後☆繧九°縲～.env` 縺ｫ荳｡譁ｹ縺ｮAPI繧ｭ繝ｼ繧貞・繧後※縺九ｉ `start-uranai.ps1` 縺ｧ襍ｷ蜍輔＠縺ｦ縺上□縺輔＞縲・
  };
}

function applyRuntimeStatus(targetId,viewModel){
  const el=document.getElementById(targetId);
  if(!el||!viewModel) return;
  el.className=`runtime-status ${viewModel.cls||'warn'}`;
  el.innerHTML=`<div class="runtime-status-title">${escapeHtml(viewModel.title||'')}</div><div class="runtime-status-detail">${escapeHtml(viewModel.detail||'')}</div>`;
}

function renderRuntimeStatus(){
  const viewModel=getServerHealthViewModel();
  applyRuntimeStatus('top-ai-status',viewModel);
  applyRuntimeStatus('modal-ai-status',viewModel);
  const guideEl=document.getElementById('modal-ai-guide');
  if(guideEl){
    if(RUNTIME_HEALTH.openai&&RUNTIME_HEALTH.anthropic){
      guideEl.textContent='荳｡譁ｹ縺ｮ繧ｭ繝ｼ險ｭ螳壹・縺ｧ縺阪※縺・∪縺吶Ａstart-uranai.ps1` 縺九ｉ襍ｷ蜍輔☆繧後・縲∫┌譁吶・GPT繝ｻ譛画侭縺ｯClaude縺ｧ蜍輔″縺ｾ縺吶・;
    }else if(RUNTIME_HEALTH.openai){
      guideEl.textContent='OpenAI 蛛ｴ縺ｯ貅門ｙ縺ｧ縺阪※縺・∪縺吶よ怏譁咏沿繧ゆｽｿ縺・↑繧・`.\\setup-anthropic.ps1` 繧貞ｮ溯｡後＠縺ｦ縺上□縺輔＞縲・;
    }else if(RUNTIME_HEALTH.anthropic){
      guideEl.textContent='Anthropic 蛛ｴ縺ｯ貅門ｙ縺ｧ縺阪※縺・∪縺吶ら┌譁咏沿繧ゆｽｿ縺・↑繧・`.\\setup-openai.ps1` 繧貞ｮ溯｡後＠縺ｦ縺上□縺輔＞縲・;
    }else{
      guideEl.textContent='辟｡譁咏沿縺ｯ `.\\setup-openai.ps1`縲∵怏譁咏沿縺ｯ `.\\setup-anthropic.ps1` 繧・蝗槭★縺､螳溯｡後☆繧九→ `.env` 繧呈紛縺医ｉ繧後∪縺吶・;
    }
  }
}

async function loadServerHealth(silent=false){
  if(!silent){
    RUNTIME_HEALTH={checked:false,reachable:false,openai:false,anthropic:false,error:'',mode:''};
    renderRuntimeStatus();
  }
  if(!canUseProxy()){
    RUNTIME_HEALTH={checked:true,reachable:false,openai:false,anthropic:false,error:'LOCAL_FILE',mode:''};
    renderRuntimeStatus();
    return;
  }
  try{
    const res=await fetch('/api/health',{cache:'no-store'});
    const data=await readJsonSafe(res);
    RUNTIME_HEALTH={
      checked:true,
      reachable:!!data?.ok,
      openai:!!data?.openaiKeyConfigured,
      anthropic:!!data?.anthropicKeyConfigured,
      error:'',
      mode:data?.mode||'',
    };
  }catch(e){
    RUNTIME_HEALTH={checked:true,reachable:false,openai:false,anthropic:false,error:'FETCH_FAILED',mode:''};
  }
  renderRuntimeStatus();
}

function getProbeStateSummary(){
  const openaiConfigured=!!RUNTIME_HEALTH.openai;
  const anthropicConfigured=!!RUNTIME_HEALTH.anthropic;
  const openaiOk=RUNTIME_HEALTH.openaiProbe?.ok===true;
  const anthropicOk=RUNTIME_HEALTH.anthropicProbe?.ok===true;
  const openaiFailed=RUNTIME_HEALTH.openaiProbe?.ok===false;
  const anthropicFailed=RUNTIME_HEALTH.anthropicProbe?.ok===false;
  return{openaiConfigured,anthropicConfigured,openaiOk,anthropicOk,openaiFailed,anthropicFailed};
}

function getServerHealthViewModel(){
  if(!canUseProxy()){
    return{
      cls:'warn',
      title:'繝ｭ繝ｼ繧ｫ繝ｫ繝輔ぃ繧､繝ｫ陦ｨ遉ｺ荳ｭ',
      detail:'AI 縺ｮ遒ｺ隱阪・ server.js 邨檎罰縺ｧ縺ｮ縺ｿ陦後∴縺ｾ縺吶・,
    };
  }
  if(!RUNTIME_HEALTH.checked){
    return{
      cls:'warn',
      title:'謗･邯夂憾諷九ｒ遒ｺ隱堺ｸｭ',
      detail:'縺ｾ縺壹・ API 繧ｭ繝ｼ縺ｮ隱ｭ霎ｼ迥ｶ豕√ｒ隕九※縺・∪縺吶・,
    };
  }
  if(!RUNTIME_HEALTH.reachable){
    return{
      cls:'bad',
      title:'繧ｵ繝ｼ繝舌・譛ｪ謗･邯・,
      detail:'`start-uranai.ps1` 縺ｧ server.js 繧定ｵｷ蜍輔＠縺ｦ縺上□縺輔＞縲・,
    };
  }
  const probe=getProbeStateSummary();
  if(!RUNTIME_HEALTH.probeChecked){
    if(probe.openaiConfigured||probe.anthropicConfigured){
      return{
        cls:'warn',
        title:'API繧ｭ繝ｼ縺ｯ隱ｭ繧√※縺・∪縺・,
        detail:'縺ｾ縺螳滄壻ｿ｡縺ｮ遒ｺ隱阪・縺励※縺・∪縺帙ｓ縲よ磁邯壹ユ繧ｹ繝医ｒ螳溯｡後＠縺ｦ縺上□縺輔＞縲・,
      };
    }
    return{
      cls:'warn',
      title:'API繧ｭ繝ｼ譛ｪ險ｭ螳・,
      detail:'`.env` 縺ｫ OpenAI / Anthropic 縺ｮ繧ｭ繝ｼ繧貞・繧後※縺上□縺輔＞縲・,
    };
  }
  if(probe.openaiOk&&probe.anthropicOk){
    return{
      cls:'ok',
      title:'謗･邯壹ユ繧ｹ繝・K',
      detail:'辟｡譁・GPT / 譛画侭 Claude 縺ｮ荳｡譁ｹ縺ｧ螳滄壻ｿ｡繧堤｢ｺ隱阪＠縺ｾ縺励◆縲・,
    };
  }
  if((probe.openaiConfigured&&probe.openaiFailed)||(probe.anthropicConfigured&&probe.anthropicFailed)){
    const failed=[];
    if(probe.openaiConfigured&&probe.openaiFailed) failed.push('OpenAI');
    if(probe.anthropicConfigured&&probe.anthropicFailed) failed.push('Anthropic');
    return{
      cls:'bad',
      title:'荳驛ｨ縺ｮ謗･邯壹ユ繧ｹ繝医′螟ｱ謨・,
      detail:`${failed.join(' / ')} 縺ｮ螳滄壻ｿ｡縺ｫ螟ｱ謨励＠縺ｾ縺励◆縲ゅく繝ｼ螟ｱ蜉ｹ繝ｻ蛻ｩ逕ｨ荳企剞繝ｻ繝｢繝・Ν謖・ｮ壹ｒ遒ｺ隱阪＠縺ｦ縺上□縺輔＞縲Ａ,
    };
  }
  if(probe.openaiOk||probe.anthropicOk){
    const okSide=probe.openaiOk?'OpenAI':'Anthropic';
    const pendingSide=probe.openaiConfigured&&!probe.openaiOk?'OpenAI':'Anthropic';
    return{
      cls:'warn',
      title:`${okSide} 縺ｯ逍朱唹K`,
      detail:`${pendingSide} 縺ｯ譛ｪ遒ｺ隱阪∪縺溘・螟ｱ謨励＠縺ｦ縺・∪縺吶ょｿ・ｦ√↑繧画磁邯壹ユ繧ｹ繝医ｒ蜀榊ｮ溯｡後＠縺ｦ縺上□縺輔＞縲Ａ,
    };
  }
  return{
    cls:'warn',
    title:'繧ｭ繝ｼ險ｭ螳壼ｾ・■',
    detail:'謗･邯壹ユ繧ｹ繝医ｒ陦後≧蜑阪↓ API 繧ｭ繝ｼ險ｭ螳壹′蠢・ｦ√〒縺吶・,
  };
}

function renderRuntimeStatus(){
  const viewModel=getServerHealthViewModel();
  applyRuntimeStatus('top-ai-status',viewModel);
  applyRuntimeStatus('modal-ai-status',viewModel);
  const guideEl=document.getElementById('modal-ai-guide');
  if(!guideEl) return;
  if(!RUNTIME_HEALTH.checked||!RUNTIME_HEALTH.reachable){
    guideEl.textContent='縺ｾ縺・server.js 縺ｮ襍ｷ蜍慕憾諷九ｒ遒ｺ隱阪＠縺ｦ縺上□縺輔＞縲・;
    return;
  }
  if(!RUNTIME_HEALTH.probeChecked){
    guideEl.textContent=canUsePaidTestMode()
      ?'繝ｭ繝ｼ繧ｫ繝ｫ隧ｦ鬨薙〒縺ｯ譛画侭蟆守ｷ壹ｂ菴ｿ縺医∪縺吶り｡ｨ遉ｺ縺ｮ OK 縺ｯ縺ｾ縺縲後く繝ｼ隱ｭ霎ｼ貂医∩縲阪・谿ｵ髫弱〒縺吶よ磁邯壹ユ繧ｹ繝医〒螳滄壻ｿ｡繧堤｢ｺ隱阪＠縺ｦ縺上□縺輔＞縲・
      :'陦ｨ遉ｺ縺ｮ OK 縺ｯ縺ｾ縺縲後く繝ｼ隱ｭ霎ｼ貂医∩縲阪・谿ｵ髫弱〒縺吶よ磁邯壹ユ繧ｹ繝医〒螳滄壻ｿ｡繧堤｢ｺ隱阪＠縺ｦ縺上□縺輔＞縲・;
    return;
  }
  if(RUNTIME_HEALTH.openaiProbe?.ok&&RUNTIME_HEALTH.anthropicProbe?.ok){
    guideEl.textContent='辟｡譁吶・ GPT-5.4 mini縲∵怏譁吶・ Claude Opus 4.6 縺ｧ逍朱夂｢ｺ隱肴ｸ医∩縺ｧ縺吶・;
    return;
  }
  guideEl.textContent='謗･邯壹ユ繧ｹ繝医↓螟ｱ謨励＠縺溷・縺ｯ縲、PI 繧ｭ繝ｼ繝ｻ蛻ｩ逕ｨ荳企剞繝ｻ繝｢繝・Ν蜷阪ｒ遒ｺ隱阪＠縺ｦ縺上□縺輔＞縲・;
}

async function loadServerHealth(silent=false){
  if(!silent){
    RUNTIME_HEALTH={checked:false,reachable:false,openai:false,anthropic:false,error:'',mode:'',paidTestMode:false,probeChecked:false,openaiProbe:null,anthropicProbe:null,probeError:''};
    renderRuntimeStatus();
  }
  if(!canUseProxy()){
    RUNTIME_HEALTH={checked:true,reachable:false,openai:false,anthropic:false,error:'LOCAL_FILE',mode:'',paidTestMode:false,probeChecked:false,openaiProbe:null,anthropicProbe:null,probeError:''};
    renderRuntimeStatus();
    return;
  }
  try{
    const res=await fetch('/api/health',{cache:'no-store'});
    const data=await readJsonSafe(res);
    RUNTIME_HEALTH={
      ...RUNTIME_HEALTH,
      checked:true,
      reachable:!!data?.ok,
      openai:!!data?.openaiKeyConfigured,
      anthropic:!!data?.anthropicKeyConfigured,
      error:'',
      mode:data?.mode||'',
      paidTestMode:!!data?.paidTestMode,
    };
  }catch(e){
    RUNTIME_HEALTH={...RUNTIME_HEALTH,checked:true,reachable:false,openai:false,anthropic:false,error:'FETCH_FAILED',mode:'',paidTestMode:false};
  }
  bootMemberMode();
  await loadMemberStatus({syncLocalPreview:true,render:true});
  renderRuntimeStatus();
}

async function runProviderCheck(){
  if(!canUseProxy()){
    showToast('server.js 邨檎罰縺ｧ縺ｮ縺ｿ謗･邯壹ユ繧ｹ繝医〒縺阪∪縺・);
    return;
  }
  try{
    showToast('謗･邯壹ユ繧ｹ繝医ｒ螳溯｡後＠縺ｦ縺・∪縺・);
    const res=await fetch(PROVIDER_CHECK_ENDPOINT,{cache:'no-store'});
    const data=await readJsonSafe(res);
    RUNTIME_HEALTH={
      ...RUNTIME_HEALTH,
      probeChecked:true,
      openaiProbe:data?.openai||null,
      anthropicProbe:data?.anthropic||null,
      probeError:'',
    };
    renderRuntimeStatus();
    if(data?.openai?.ok||data?.anthropic?.ok){
      showToast('謗･邯壹ユ繧ｹ繝医ｒ譖ｴ譁ｰ縺励∪縺励◆');
    }else{
      showToast('謗･邯壹ユ繧ｹ繝医↓螟ｱ謨励＠縺ｾ縺励◆');
    }
  }catch(e){
    RUNTIME_HEALTH={...RUNTIME_HEALTH,probeChecked:true,openaiProbe:null,anthropicProbe:null,probeError:'PROBE_FAILED'};
    renderRuntimeStatus();
    showToast('謗･邯壹ユ繧ｹ繝医↓螟ｱ謨励＠縺ｾ縺励◆');
  }
}

function getTaskModelConfig(taskKey=''){
  if(taskKey&&AI_MODEL_CONFIG[taskKey]) return AI_MODEL_CONFIG[taskKey];
  return PLAN==='paid'?AI_MODEL_CONFIG.paid:AI_MODEL_CONFIG.free;
}

function buildAiPayload(userPrompt,maxTokens,sys,options={}){
  const taskCfg=getTaskModelConfig(options.taskKey||'');
  return{
    provider:options.provider||taskCfg.provider,
    model:options.model||taskCfg.model,
    max_tokens:maxTokens,
    system:sys,
    messages:[{role:'user',content:userPrompt}],
    reasoning_effort:options.reasoningEffort||taskCfg.reasoningEffort||'',
    fallbackProvider:options.fallbackProvider||taskCfg.fallbackProvider||'',
    fallbackModel:options.fallbackModel||taskCfg.fallbackModel||'',
    images:Array.isArray(options.images)?options.images:[],
  };
}

async function callAIThroughProxy(payload){
  const res=await fetch(API_PROXY_ENDPOINT,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(payload)
  });
  const data=await readJsonSafe(res);
  if(res.ok) return data?.content?.[0]?.text||'';
  if(data?.error==='ANTHROPIC_API_KEY_MISSING'||data?.error==='OPENAI_API_KEY_MISSING'){
    throw makeAppError(data?.error,'繧ｵ繝ｼ繝舌・蛛ｴ縺ｮAPI繧ｭ繝ｼ縺梧悴險ｭ螳壹〒縺吶・);
  }
  if(data?.error==='ANTHROPIC_UPSTREAM_ERROR'){
    throw makeAppError('ANTHROPIC_UPSTREAM_ERROR',data?.message||'AI繧ｵ繝ｼ繝舌・縺ｧ繧ｨ繝ｩ繝ｼ縺檎匱逕溘＠縺ｾ縺励◆縲・);
  }
  if(data?.error==='OPENAI_UPSTREAM_ERROR'){
    throw makeAppError('OPENAI_UPSTREAM_ERROR',data?.message||'AI繧ｵ繝ｼ繝舌・縺ｧ繧ｨ繝ｩ繝ｼ縺檎匱逕溘＠縺ｾ縺励◆縲・);
  }
  if(data?.error==='ANTHROPIC_NETWORK_ERROR'){
    throw makeAppError('ANTHROPIC_NETWORK_ERROR','AI繧ｵ繝ｼ繝舌・縺ｫ謗･邯壹〒縺阪∪縺帙ｓ縺ｧ縺励◆縲・);
  }
  if(data?.error==='PAID_TEST_MODE_ONLY'){
    throw makeAppError('PAID_TEST_MODE_ONLY','譛画侭蟆守ｷ壹・縺ｾ縺繝ｭ繝ｼ繧ｫ繝ｫ隧ｦ鬨鍋腸蠅・・縺ｿ縺ｫ蛻ｶ髯舌＠縺ｦ縺・∪縺・);
  }
  if(data?.error==='PAID_AUTH_REQUIRED'){
    throw makeAppError('PAID_AUTH_REQUIRED','譛画侭髑大ｮ壹ｒ髢九￥縺ｫ縺ｯ莨壼藤隱崎ｨｼ縺悟ｿ・ｦ√〒縺・);
  }
  if(data?.error==='PAID_SESSION_REQUIRED'){
    throw makeAppError('PAID_SESSION_REQUIRED','繝ｭ繝ｼ繧ｫ繝ｫ隧ｦ鬨薙そ繝・す繝ｧ繝ｳ繧堤匱陦後＠縺ｦ縺九ｉ蜀榊ｮ溯｡後＠縺ｦ縺上□縺輔＞');
  }
  if(data?.provider==='openai'){
    throw makeAppError(data?.error||'OPENAI_PROXY_FAILED',data?.message||'OpenAI蛛ｴ縺ｧ繧ｨ繝ｩ繝ｼ縺檎匱逕溘＠縺ｾ縺励◆縲・);
  }
  throw makeAppError('PROXY_REQUEST_FAILED',data?.message||`AI繧ｵ繝ｼ繝舌・縺ｧ繧ｨ繝ｩ繝ｼ縺檎匱逕溘＠縺ｾ縺励◆・・{res.status}・峨Ａ);
}

async function callAIDirect(payload){
  if(!API_KEY){
    if(DEV_MODE) openSettings();
    showToast('髢狗匱閠・Δ繝ｼ繝峨・API繧ｭ繝ｼ縺梧悴險ｭ螳壹〒縺吶・);
    throw makeAppError('API_KEY_MISSING','髢狗匱閠・Δ繝ｼ繝峨・API繧ｭ繝ｼ縺梧悴險ｭ螳壹〒縺吶・);
  }
  const res=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{
      'Content-Type':'application/json',
      'x-api-key':API_KEY,
      'anthropic-version':'2023-06-01',
      'anthropic-dangerous-direct-browser-access':'true'
    },
    body:JSON.stringify({
      model:payload.model,
      max_tokens:payload.max_tokens,
      system:payload.system,
      messages:payload.messages
    })
  });
  if(res.status===401||res.status===403){
    showToast('髢狗匱閠・Δ繝ｼ繝峨・API繧ｭ繝ｼ縺檎┌蜉ｹ縺ｧ縺吶・);
    openSettings();
    throw makeAppError('API_AUTH_ERROR','髢狗匱閠・Δ繝ｼ繝峨・API繧ｭ繝ｼ縺檎┌蜉ｹ縺ｧ縺吶・);
  }
  if(!res.ok){
    throw makeAppError('DIRECT_API_ERROR',`Anthropic API繧ｨ繝ｩ繝ｼ・・{res.status}・荏);
  }
  const data=await res.json();
  return data.content?.[0]?.text||'';
}

async function callAI(userPrompt,maxTokens=500,sys='',options={}){
  // 蜊縺・ｸｫ繝｢繝ｼ繝・縺九▽ 髢狗匱閠・Δ繝ｼ繝峨〒縺ｪ縺・竊・AI繧ｹ繧ｭ繝・・
  if(PLAN==='reader' && !DEV_MODE) throw new Error('FREE_MODE_NO_AI');
  const system=sys||'縺ゅ↑縺溘・縲∝頃縺・ｒ蜀・怐縺ｨ陦悟虚謾ｯ謠ｴ縺ｫ菴ｿ縺・・繝ｭ縺ｮ髑大ｮ夊・〒縺吶よｸｩ縺九∩縺後≠繧翫▽縺､迴ｾ螳溽噪縺ｪ譌･譛ｬ隱槭〒遲斐∴縺ｦ縺上□縺輔＞縲りｶ・ｸｸ逧・・逾樒ｧ倡噪縺ｪ陦ｨ迴ｾ繧・°蜻ｽ隲悶・菴ｿ繧上★縲√Λ繝吶Ν繧・ｦ句・縺励ｂ縺､縺代↑縺・％縺ｨ縲・;
  const payload=buildAiPayload(userPrompt,maxTokens,system,options);

  if(canUseProxy()){
    try{
      return await callAIThroughProxy(payload);
    }catch(error){
      const canFallbackViaDevDirect=canUseDirectApi()&&payload.provider==='anthropic';
      if(canFallbackViaDevDirect){
        showToast('AI繧ｵ繝ｼ繝舌・縺ｫ謗･邯壹〒縺阪↑縺・◆繧√・幕逋ｺ閠・Δ繝ｼ繝峨・逶ｴ謗･謗･邯壹↓蛻・ｊ譖ｿ縺医∪縺吶・);
        return await callAIDirect(payload);
      }
      if(payload.fallbackProvider&&payload.fallbackModel){
      const fallbackPayload={
          ...payload,
          provider:payload.fallbackProvider,
          model:payload.fallbackModel,
          reasoning_effort:'',
          fallbackProvider:'',
          fallbackModel:'',
          images:[],
        };
        showToast('荳ｻ蜉帙Δ繝・Ν縺御ｽｿ縺医↑縺・◆繧√∽ｻ｣譖ｿ繝｢繝・Ν縺ｧ髑大ｮ壹ｒ邯夊｡後＠縺ｾ縺吶・);
        return await callAIThroughProxy(fallbackPayload);
      }
      showToast(error?.userMessage||'AI繧ｵ繝ｼ繝舌・縺ｫ謗･邯壹〒縺阪∪縺帙ｓ縺ｧ縺励◆縲・);
      throw error;
    }
  }

  if(canUseDirectApi()&&payload.provider==='anthropic') return await callAIDirect(payload);

  if(DEV_MODE) openSettings();
  showToast('AI髑大ｮ壹ｒ菴ｿ縺・↓縺ｯ server.js 縺九ｉ襍ｷ蜍輔☆繧九°縲・dev 縺ｧAPI繧ｭ繝ｼ繧定ｨｭ螳壹＠縺ｦ縺上□縺輔＞縲・);
  throw makeAppError('AI_RUNTIME_UNAVAILABLE','AI髑大ｮ壹・螳溯｡檎腸蠅・′譛ｪ險ｭ螳壹〒縺吶・);
}



// 笏笏笏 繝ｪ繝・メ繝輔か繝ｼ繝ｫ繝舌ャ繧ｯ・・PI縺ｪ縺玲凾縺ｮ鬮伜刀雉ｪ繝ｪ繝ｼ繝・ぅ繝ｳ繧ｰ・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
function buildRichLenFallback(name,cat){
  const input=getCurrentInputSnapshot();
  const focus=analyzeConsultationFocus(cat,input.theme||'');
  const lenSpreadContext=buildLenSpreadPromptContext(cat);
  const pairHighlights=(lenSpreadContext.pairHighlights||[]).map(line=>line.replace(/^- /,''));
  const ids=[...SEL_LEN];
  const is9=(SEL_LEN.length===9);
  const is3=(SEL_LEN.length===FREE_LEN_COUNT);
  const coreId=is9?SEL_LEN[4]:(is3?SEL_LEN[1]:SEL_LEN[0]);
  const currentId=is9?SEL_LEN[1]:(is3?SEL_LEN[1]:coreId);
  const futureId=is9?(SEL_LEN[5]||SEL_LEN[2]):(is3?(SEL_LEN[2]||coreId):coreId);
  const backgroundIds=is9?[SEL_LEN[0],SEL_LEN[3],SEL_LEN[6]].filter(Boolean):(is3?[SEL_LEN[0]].filter(Boolean):ids);
  const currentIds=is9?[SEL_LEN[1],SEL_LEN[4],SEL_LEN[7]].filter(Boolean):(is3?[SEL_LEN[1]].filter(Boolean):ids);
  const futureIds=is9?[SEL_LEN[2],SEL_LEN[5],SEL_LEN[8]].filter(Boolean):(is3?[SEL_LEN[2]].filter(Boolean):ids);
  const visibleIds=is9?[SEL_LEN[0],SEL_LEN[1],SEL_LEN[2]].filter(Boolean):ids;
  const hiddenIds=is9?[SEL_LEN[6],SEL_LEN[7],SEL_LEN[8]].filter(Boolean):[];
  const hasHidden=hasLenGroup(ids,'hidden');
  const hasEnding=hasLenGroup(ids,'ending');
  const hasStability=hasLenGroup(ids,'stability');
  const hasValue=hasLenGroup(ids,'value');
  const hasRelationship=hasLenGroup(ids,'relationship');
  const hasBurden=hasLenGroup(ids,'burden');
  const hasSupport=hasLenGroup(ids,'support');
  const hasChoice=hasLenGroup(ids,'choice');
  const backgroundBurden=hasLenGroup(backgroundIds,'burden');
  const backgroundStability=hasLenGroup(backgroundIds,'stability');
  const currentChoice=hasLenGroup(currentIds,'choice');
  const currentHidden=hasLenGroup(currentIds,'hidden');
  const futureEnding=hasLenGroup(futureIds,'ending');
  const futureSupport=hasLenGroup(futureIds,'support');
  const visibleChoice=hasLenGroup(visibleIds,'choice');
  const hiddenBurden=hasLenGroup(hiddenIds,'burden');
  const hiddenRelationship=hasLenGroup(hiddenIds,'relationship');
  const actionPlan=buildThemeSpecificActionPlan(focus);
  const lines=[];
  lines.push('笆 閭梧勹縺ｨ迴ｾ迥ｶ','');
  if(pairHighlights[0]) lines.push(pairHighlights[0]);
  lines.push(getLenCoreFocusText(coreId));
  if(focus.isDualConcern){
    lines.push(`${name}縺輔ｓ縺ｯ縺・∪縲∵°諢帙→莉穂ｺ九・荳｡譁ｹ縺ｧ縲悟､ｱ縺・◆縺上↑縺・ｰ玲戟縺｡縲阪′蠑ｷ縺上∝愛譁ｭ繧貞・騾√ｊ縺励ｄ縺吶＞迥ｶ諷九〒縺吶Ａ);
