function renderMemberFollowupSection(){
  const stateEl=document.getElementById('member-result-state');
  const noteEl=document.getElementById('member-locked-note');
  const actionsEl=document.getElementById('member-followup-actions');
  const outputEl=document.getElementById('member-followup-output');
  const logEl=document.getElementById('member-followup-log');
  const copyEl=document.getElementById('member-panel-copy');
  if(!stateEl||!noteEl||!actionsEl||!outputEl||!logEl||!copyEl) return;

  const followups=LAST_OUTPUTS.followups||{};
  stateEl.className='member-state '+(isMemberActive()?'active':'inactive');
  stateEl.textContent=isMemberActive()
    ?(MEMBER_AUTH.source==='local_preview'?'霑ｽ蜉雉ｪ蝠上ｒ隧ｦ鬨楢｡ｨ遉ｺ荳ｭ':'霑ｽ蜉雉ｪ蝠上ｒ陦ｨ遉ｺ荳ｭ')
    :(canUsePaidTestMode()?'繝ｭ繝ｼ繧ｫ繝ｫ隧ｦ鬨灘ｾ・ｩ滉ｸｭ':(MEMBER_AUTH.codeConfigured?'莨壼藤隱崎ｨｼ蠕・■':'蜈ｬ髢区ｺ門ｙ荳ｭ'));
  copyEl.textContent=isMemberActive()
    ?'邨先棡繧定ｪｭ繧薙□縺ゅ→縺ｫ谿九ｋ縲後≠縺ｨ1縺､縺縺題◇縺阪◆縺・％縺ｨ縲阪ｒ霑ｽ蜉縺ｧ隕九ｉ繧後∪縺吶ゅ◆縺ｨ縺医・逶ｸ謇九・豌玲戟縺｡縲√％縺ｮ7譌･縺ｧ繧・ｋ縺薙→縲∝虚縺乗凾譛溘↑縺ｩ繧堤ｵ槭▲縺ｦ豺ｱ繧√ｋ縺溘ａ縺ｮ谺・〒縺吶・
    :(canUsePaidTestMode()
      ?'縺薙・繝ｭ繝ｼ繧ｫ繝ｫ迺ｰ蠅・〒縺ｯ隧ｦ鬨薙そ繝・す繝ｧ繝ｳ繧堤匱陦後☆繧九→縲∽ｻ雁屓縺ｮ邨先棡繧貞悄蜿ｰ縺ｫ霑ｽ蜉雉ｪ蝠上∪縺ｧ遒ｺ隱阪〒縺阪∪縺吶・
      :((MEMBER_AUTH.googleClientConfigured&&!MEMBER_AUTH.authLoggedIn)
        ?'蜈ｬ髢狗腸蠅・〒縺ｯ Google 繝ｭ繧ｰ繧､繝ｳ縺ｧ譛ｬ莠ｺ繧貞崋螳壹＠縺ｦ縺九ｉ縲ヾtripe 縺ｮ譛磯｡咲匳骭ｲ縺ｸ騾ｲ繧豬√ｌ縺ｧ縺吶・
      :(MEMBER_AUTH.stripeCheckoutReady
        ?'蜈ｬ髢狗腸蠅・〒縺ｯ Stripe 縺ｮ譛磯｡咲匳骭ｲ縺悟ｮ御ｺ・☆繧九→縲∽ｻ雁屓縺ｮ邨先棡繧貞悄蜿ｰ縺ｫ霑ｽ蜉雉ｪ蝠上∪縺ｧ縺昴・縺ｾ縺ｾ髢九￠縺ｾ縺吶・
        :'豺ｱ謗倥ｊ髑大ｮ壹・縺薙・逕ｻ髱｢縺ｾ縺ｧ菴ｿ縺医∪縺吶ょ・髢句ｾ後・縲∽ｻ雁屓縺ｮ邨先棡繧貞悄蜿ｰ縺ｫ縺励※縲√≠縺ｨ1縺､縺縺題◇縺阪◆縺・％縺ｨ繧定ｿｽ蜉縺ｧ隕九ｉ繧後ｋ繧医≧縺ｫ縺ｪ繧翫∪縺吶・)));

  if(!isMemberActive()){
    noteEl.style.display='block';
    noteEl.textContent=canUsePaidTestMode()
      ?'繝ｭ繝ｼ繧ｫ繝ｫ隧ｦ鬨薙そ繝・す繝ｧ繝ｳ繧堤匱陦後☆繧九→縲√＞縺ｾ縺ｮ邨先棡繧貞悄蜿ｰ縺ｫ霑ｽ蜉雉ｪ蝠上∪縺ｧ縺昴・縺ｾ縺ｾ讀懆ｨｼ縺ｧ縺阪∪縺吶・
      :((MEMBER_AUTH.googleClientConfigured&&!MEMBER_AUTH.authLoggedIn)
        ?'縺ｾ縺・Google 縺ｧ繝ｭ繧ｰ繧､繝ｳ縺吶ｋ縺ｨ縲ヾtripe 縺ｮ譛磯｡咲匳骭ｲ縺ｨ莉雁屓縺ｮ髢ｲ隕ｧ讓ｩ髯舌ｒ蜷後§譛ｬ莠ｺ縺ｸ邏舌▼縺代ｉ繧後∪縺吶・
      :(MEMBER_AUTH.stripeCheckoutReady
        ?'Stripe 縺ｮ譛磯｡咲匳骭ｲ縺悟ｮ御ｺ・☆繧九→縲√＞縺ｾ縺ｮ邨先棡繧貞悄蜿ｰ縺ｫ縺励※豌励↓縺ｪ繧・轤ｹ縺縺代ｒ霑ｽ蜉縺ｧ隕九ｉ繧後ｋ繧医≧縺ｫ縺ｪ繧翫∪縺吶・
        :(MEMBER_AUTH.codeConfigured
          ?'譛画侭莨壼藤縺ｮ隱崎ｨｼ縺碁壹ｋ縺ｨ縲√＞縺ｾ縺ｮ邨先棡繧貞悄蜿ｰ縺ｫ縺励※豌励↓縺ｪ繧・轤ｹ縺縺代ｒ霑ｽ蜉縺ｧ隕九ｉ繧後ｋ繧医≧縺ｫ縺ｪ繧翫∪縺吶・
          :'縺・∪縺ｯ縺ｾ縺菴ｿ縺医∪縺帙ｓ縲ゅし繝ｼ繝舌・蛛ｴ縺ｮ隱崎ｨｼ繧ｳ繝ｼ繝芽ｨｭ螳壹′蜈･繧九∪縺ｧ縲∵怏譁呵ｿｽ蜉雉ｪ蝠上・髢峨§縺溘∪縺ｾ縺ｫ縺励※縺・∪縺吶・))));
    actionsEl.innerHTML=canUsePaidTestMode()
      ?`<button class="followup-btn" onclick="toggleMemberPreview()">繝ｭ繝ｼ繧ｫ繝ｫ隧ｦ鬨薙ｒ譛牙柑蛹・/button>`
      :((MEMBER_AUTH.googleClientConfigured&&!MEMBER_AUTH.authLoggedIn)
        ?`<button class="followup-btn" onclick="openMemberAccessModal('upgrade-paid')">Google縺ｧ繝ｭ繧ｰ繧､繝ｳ</button>`
      :(MEMBER_AUTH.manageBillingAvailable
        ?`<button class="followup-btn" onclick="openStripeBillingPortal()">謾ｯ謇輔＞繧堤ｮ｡逅・/button>`
      :(MEMBER_AUTH.stripeCheckoutReady
        ?`<button class="followup-btn" onclick="openStripeCheckout('upgrade-paid')">Stripe縺ｧ譛磯｡咲匳骭ｲ</button>`
        :`<button class="followup-btn" onclick="openMemberAccessModal('upgrade-paid')" ${MEMBER_AUTH.codeConfigured?'':'disabled'}>隱崎ｨｼ縺励※菴ｿ縺・/button>`)));
  }else{
    noteEl.style.display='none';
    actionsEl.innerHTML=Object.entries(FOLLOWUP_PRESETS).map(([key,preset])=>
      `<button class="followup-btn ${ACTIVE_FOLLOWUP_KEY===key?'sel':''}" onclick="runMemberFollowup('${key}')" ${FOLLOWUP_LOADING?'disabled':''}>${preset.label}</button>`
    ).join('');
  }

  const followupKeys=Object.keys(followups);
  if(ACTIVE_FOLLOWUP_KEY&&followups[ACTIVE_FOLLOWUP_KEY]){
    outputEl.classList.add('on');
    outputEl.textContent=followups[ACTIVE_FOLLOWUP_KEY];
  }else if(FOLLOWUP_LOADING){
    outputEl.classList.add('on');
    outputEl.innerHTML='<div class="ai-load"><div class="ai-dots"><span></span><span></span><span></span></div><span>霑ｽ蜉縺ｮ隱ｭ縺ｿ繧偵∪縺ｨ繧√※縺・∪縺吮ｦ</span></div>';
  }else{
    outputEl.classList.remove('on');
    outputEl.textContent='';
  }

  logEl.innerHTML=followupKeys.map(key=>`
    <button class="followup-log-item" onclick="openSavedFollowup('${key}')">${FOLLOWUP_PRESETS[key]?.label||key} 繧帝幕縺・/button>
  `).join('');
}

function openSavedFollowup(key){
  ACTIVE_FOLLOWUP_KEY=key;
  renderMemberFollowupSection();
}

async function runMemberFollowup(key){
  if(!isMemberActive()){
    showToast('縺ゅ→縺九ｉ菴ｿ縺医ｋ霑ｽ蜉雉ｪ蝠上→縺励※貅門ｙ荳ｭ縺ｧ縺・);
    return;
  }
  if(FOLLOWUP_LOADING) return;
  const preset=FOLLOWUP_PRESETS[key];
  if(!preset) return;
  FOLLOWUP_LOADING=true;
  ACTIVE_FOLLOWUP_KEY=key;
  renderMemberFollowupSection();

  const input=getCurrentInputSnapshot();
  const systemPrompt=`縺ゅ↑縺溘・縲∫ｵ先棡繧定ｪｭ繧薙□縺ゅ→縺ｫ谿九ｋ霑ｽ蜉雉ｪ蝠上∈遲斐∴繧句頃縺・ｸｫ縺ｧ縺吶・蜑榊屓縺ｮ髑大ｮ壼・螳ｹ繧堤ｹｰ繧願ｿ斐☆縺縺代〒縺ｯ縺ｪ縺上√＆繧峨↓荳谿ｵ豺ｱ縺・ｧ｣蜒丞ｺｦ縺ｫ荳翫￡縺ｦ縺上□縺輔＞縲・莉･荳九ｒ蠢・★螳医▲縺ｦ縺上□縺輔＞縲・- 謚ｽ雎｡隲悶〒邨ゅｏ繧峨★縲∫樟螳溘・陦悟虚繧・愛譁ｭ縺ｫ關ｽ縺ｨ縺苓ｾｼ繧
- 譁ｭ螳壹＠縺吶℃縺壹∫嶌謇九・豌玲戟縺｡縺ｯ蜿ｯ閭ｽ諤ｧ縺ｨ縺励※荳∝ｯｧ縺ｫ謇ｱ縺・- 蜑榊屓縺ｮ邨ｱ蜷医Γ繝・そ繝ｼ繧ｸ縺ｨ遏帷崟縺励↑縺・- 600縲・00蟄礼ｨ句ｺｦ縺ｧ縲∬ｦ句・縺励・1縺､縺縺代↓縺吶ｋ`;
  const prompt=`${buildFollowupContext()}

縲蝉ｻ雁屓縺ｮ霑ｽ蜉繝・・繝槭・${preset.label}

縲占ｿｽ蜉謖・､ｺ縲・
${preset.intro}

${input.fullname||'縺ゅ↑縺・}縺輔ｓ縺後後ｂ縺・ｸ谿ｵ豺ｱ縺丞・縺九▲縺溘阪梧ｬ｡縺ｫ菴輔ｒ縺吶ｌ縺ｰ縺・＞縺玖ｦ九∴縺溘阪→諢溘§繧玖ｿｽ蜉縺ｮ隱ｭ縺ｿ繧呈嶌縺・※縺上□縺輔＞縲Ａ;

  try{
    const res=await callAI(prompt,1400,systemPrompt,{
      taskKey:'followup',
      images:buildCardImageRefs('all','followup'),
    });
    LAST_OUTPUTS.followups[key]=res;
    persistCurrentReading();
  }catch(e){
    showToast(e?.userMessage||'霑ｽ蜉縺ｮ隱ｭ縺ｿ縺ｮ逕滓・縺ｫ螟ｱ謨励＠縺ｾ縺励◆');
  }finally{
    FOLLOWUP_LOADING=false;
    renderMemberFollowupSection();
  }
}

// 笏笏 X・・witter・峨す繧ｧ繧｢ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
function shareToX(){
  const name=document.getElementById('f-fullname')?.value||'';
  const cat=document.getElementById('f-cat')?.value||'邱丞粋';
  const lenNames=SEL_LEN.slice(0,3).map(id=>LENORMAND[id]?.name).filter(Boolean).join('繝ｻ');
  const orcName=SEL_ORC[0]?ORACLE[SEL_ORC[0]]?.name:'';
  const planLabel=PLAN==='paid'?'12譫夂ｷ丞粋髑大ｮ・:'辟｡譁咎荘螳・;

  const rawLines=[
    `笨ｨ 鄒・・蜊陦薙〒${planLabel}繧偵＠縺ｾ縺励◆`,
    ``,
    `縲舌Ν繝弱Ν繝槭Φ縲・{lenNames}${SEL_LEN.length>3?'窶ｦ':''}`,
    orcName?`縲先焚遘倥が繝ｩ繧ｯ繝ｫ縲・{orcName}`:'',
    `縲舌ユ繝ｼ繝槭・{cat}`,
    ``,
    `縺ゅ↑縺溘ｂ蜊縺｣縺ｦ縺ｿ縺ｦ燥`,
    location.origin+location.pathname,
    ``,
    `#鄒・・蜊陦・#繝ｫ繝弱Ν繝槭Φ蜊縺・#莉頑律縺ｮ驕句兇`,
  ];
  // 遨ｺ陦後・騾｣邯壹ｒ髯､蜴ｻ繝ｻfalsy陦後ｒ髯､蜴ｻ
  const lines=rawLines.filter((l,i)=>l!==false&&!(l===''&&rawLines[i-1]===''));
  const text=lines.join('\n');
  window.open('https://twitter.com/intent/tweet?text='+encodeURIComponent(text),'_blank','noopener,noreferrer');
}

// 笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武
// READER MODE 窶・繧ｫ繝ｼ繝牙盾辣ｧ陦ｨ
// 笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武
function renderReaderRef(){
  // 繝ｫ繝弱Ν繝槭Φ蜿ら・陦ｨ
  const lenPos=getLenSpreadLabels();
  const lenRows=SEL_LEN.map((id,i)=>{
    const c=LENORMAND[id];
    const kws=(c.kw||'').split(',').slice(0,4).map(k=>k.trim()).join(' ﾂｷ ');
    return`<tr>
      <td class="card-ref-pos">${lenPos[i]||''}</td>
      <td class="card-ref-name">No.${id}縲・{c.name}縲・/td>
      <td class="card-ref-kw">${kws}</td>
    </tr>`;
  }).join('');
  const lenRef=document.getElementById('r-len-ref');
  if(lenRef){
    lenRef.style.display='block';
    lenRef.innerHTML=`
      <div class="reader-badge">醗 蜊縺・ｸｫ蜿ら・逕ｨ</div>
      <table class="card-ref-table"><tbody>${lenRows}</tbody></table>
      ${SEL_LEN.length===9?`<div class="card-ref-note">陦鯉ｼ壻ｸ頑ｮｵ=鬘募惠諢剰ｭ・/ 荳ｭ谿ｵ=迴ｾ螳・/ 荳区ｮｵ=貎懷惠諢剰ｭ・br>蛻暦ｼ壼ｷｦ蛻・閭梧勹 / 荳ｭ蛻・迴ｾ迥ｶ / 蜿ｳ蛻・譛ｪ譚･</div>`:''}`;
  }

  // 繧ｪ繝ｩ繧ｯ繝ｫ蜿ら・陦ｨ
  const orcLabels=getOrcSpreadLabels();
  const orcRows=SEL_ORC.map((id,i)=>{
    const o=ORACLE[id];
    return`<tr>
      <td class="card-ref-pos">${orcLabels[i]||''}</td>
      <td class="card-ref-name">No.${id}縲・{o.name}縲・/td>
      <td class="card-ref-kw">${(o.msg||'').slice(0,42)}窶ｦ</td>
    </tr>`;
  }).join('');
  const orcRef=document.getElementById('r-orc-ref');
  if(orcRef){
    orcRef.style.display='block';
    orcRef.innerHTML=`
      <div class="reader-badge" style="margin-top:4px;">笨ｦ 謨ｰ遘伜盾辣ｧ逕ｨ</div>
      <table class="card-ref-table"><tbody>${orcRows}</tbody></table>
      ${SEL_ORC.length===3?`<div class="card-ref-note">蟾ｦ=閭梧勹 / 荳ｭ=迴ｾ迥ｶ / 蜿ｳ=譛ｪ譚･縺ｸ縺ｮ繝偵Φ繝・/div>`:''}`;
  }
}

