async function polishPremiumDossierDraft(draft,sourceContext){
  const systemPrompt=`縺ゅ↑縺溘・譛鬮倡ｴ壹・髑大ｮ壽嶌繧剃ｻ穂ｸ翫￡繧狗ｷｨ髮・聞縺ｧ縺吶・蠖ｹ蜑ｲ縺ｯ縲・荘螳壹・荳ｭ霄ｫ繧定埋繧√★縺ｫ縲∝・髟ｷ縺輔・驥崎､・・遏帷崟繧貞炎繧翫∬ｪｭ縺ｿ霑斐＠繧・☆縺・怙邨らｨｿ縺ｸ逎ｨ縺堺ｸ翫￡繧九％縺ｨ縺ｧ縺吶・
