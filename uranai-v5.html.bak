  '讌・:13,'貉・:12,'闥ｼ':13,'鬚ｯ':14,'關・:11,'荵・:2,'譁・:4,'諷ｧ':15,'邏・:10,'讀ｿ':13,
  '驕･':12,'驕・:14,'隧ｩ':13,'郢・:18,'闔・:10,'蜃ｪ':6,'譛・:10,'鄙・:12,'迹・:12,'貂・:11,'陦｣':6,
  '譟・:9,'髯ｽ':12,'闢ｮ':13,'鬚ｯ':14,'迴':9,'逅･':12,'逅・:11,'諢・:13,'螂・:9,'貉ｧ':12,
  '蟠・:11,'豬・:10,'豐｢':7,'蝣':11,'辭・:14,'霎ｻ':5,'讓・:12,'譚・:7,'豬・:9,'遘・:9,
  '荵・:3,'菫・:9,'譟ｴ':10,'蟯ｸ':8,'蟠・:11,'豼ｱ':17,'豼ｵ':17,'驍・:18,'驍・:19,
};

function getStrokeInfo(char){
  // 貍｢蟄励ユ繝ｼ繝悶Ν縺ｫ縺ゅｌ縺ｰ縺昴・逕ｻ謨ｰ縲√↑縺代ｌ縺ｰ譁・ｭ励さ繝ｼ繝峨°繧画耳螳夲ｼ亥ｹｳ莉ｮ蜷阪・繧ｫ繧ｿ繧ｫ繝顔ｭ会ｼ・  if(Object.prototype.hasOwnProperty.call(VARIANT_STROKES,char)) return {char,count:VARIANT_STROKES[char],source:'variant'};
  if(Object.prototype.hasOwnProperty.call(KANJI_STROKES,char)) return {char,count:KANJI_STROKES[char],source:'table'};
  if(Object.prototype.hasOwnProperty.call(EXTENDED_NAME_STROKES,char)) return {char,count:EXTENDED_NAME_STROKES[char],source:'extended'};
  const code=char.codePointAt(0);
  // 縺ｲ繧峨′縺ｪ
  if(code>=0x3041&&code<=0x3096) return {char,count:((code-0x3041)%10)+1,source:'kana'};
  // 繧ｫ繧ｿ繧ｫ繝・  if(code>=0x30A1&&code<=0x30F6) return {char,count:((code-0x30A1)%10)+1,source:'kana'};
  // 蝓ｺ譛ｬ逧・↑貍｢蟄鈴伜沺
  if(code>=0x4E00&&code<=0x9FFF){
    // 逕ｻ謨ｰ縺ｮ霑台ｼｼ蛟､・郁ｩｳ邏ｰ繝・・繝悶Ν縺ｫ縺ｪ縺・ｴ蜷茨ｼ・
    return {char,count:Math.max(1,Math.min(30,Math.floor((code-0x4E00)/300)+1+(code%7))),source:'approx'};
  }
  return {char,count:1,source:'fallback'};
}

function formatStrokeBreakdown(entries){
  return entries.map(entry=>`${entry.char}(${entry.count})`).join('繝ｻ');
}

function calcNameJudge(fullname){
  const parsed=splitJapaneseFullname(fullname);
  if(!parsed||!parsed.sei||!parsed.mei) return null;
  const sei=parsed.sei, mei=parsed.mei;
  const seiChars=Array.from(sei).map(c=>getStrokeInfo(c));
  const meiChars=Array.from(mei).map(c=>getStrokeInfo(c));
  const seiTotal=seiChars.reduce((sum,entry)=>sum+entry.count,0);
  const meiTotal=meiChars.reduce((sum,entry)=>sum+entry.count,0);

  // 荳蟄怜ｧ薙・荳蟄怜錐縺ｮ陬懈ｭ｣
  const useTenReisu=seiChars.length===1;
  const useChiReisu=meiChars.length===1;
  const tenKaku=seiTotal+(useTenReisu?1:0); // 螟ｩ譬ｼ・壼ｧ薙・蜷郁ｨ茨ｼ井ｸ蟄怜ｧ薙・陬懈ｭ｣1繧貞刈邂暦ｼ・
  const jinKaku=seiChars[seiChars.length-1].count+meiChars[0].count; // 莠ｺ譬ｼ・壼ｧ薙・譛蠕鯉ｼ句錐縺ｮ譛蛻・
  const chiKaku=meiTotal+(useChiReisu?1:0); // 蝨ｰ譬ｼ・壼錐縺ｮ蜷郁ｨ茨ｼ井ｸ蟄怜錐縺ｯ陬懈ｭ｣1繧貞刈邂暦ｼ・
  const gaiKaku=(seiChars.length===1?1:seiChars[0].count)+(meiChars.length===1?1:meiChars[meiChars.length-1].count); // 螟匁ｼ・壼ｧ薙・譛蛻晢ｼ句錐縺ｮ譛蠕・
  const souKaku=seiTotal+meiTotal; // 邱乗ｼ・壼ｧ難ｼ句錐・郁｣懈ｭ｣縺ｪ縺暦ｼ・

  const approxChars=[...seiChars,...meiChars]
    .filter(entry=>entry.source==='approx'||entry.source==='fallback')
    .map(entry=>entry.char);
  const sourceStats=[...seiChars,...meiChars].reduce((acc,entry)=>{
    acc[entry.source]=(acc[entry.source]||0)+1;
    return acc;
  },{});
  const kakus=[
    {name:'螟ｩ譬ｼ',num:tenKaku,desc:'螳ｶ邉ｻ繝ｻ閧ｲ縺｣縺溽腸蠅・°繧牙女縺代ｋ蛯ｾ蜷・,formula:`${formatStrokeBreakdown(seiChars)}${useTenReisu?' + 陬懈ｭ｣1':''}`},
    {name:'莠ｺ譬ｼ',num:jinKaku,desc:'譛ｬ莠ｺ縺ｮ譬ｸ蠢・・譛繧る㍾隕√↑譬ｼ',formula:`${seiChars[seiChars.length-1].char}(${seiChars[seiChars.length-1].count}) + ${meiChars[0].char}(${meiChars[0].count})`},
    {name:'蝨ｰ譬ｼ',num:chiKaku,desc:'蟷ｼ蟆第悄縲憺搨蟷ｴ譛溘・蝨溷床',formula:`${formatStrokeBreakdown(meiChars)}${useChiReisu?' + 陬懈ｭ｣1':''}`},
    {name:'螟匁ｼ',num:gaiKaku,desc:'蟇ｾ莠ｺ繝ｻ遉ｾ莨壹→縺ｮ髢｢繧上ｊ譁ｹ',formula:`${seiChars.length===1?'陬懈ｭ｣1':`${seiChars[0].char}(${seiChars[0].count})`} + ${meiChars.length===1?'陬懈ｭ｣1':`${meiChars[meiChars.length-1].char}(${meiChars[meiChars.length-1].count})`}`},
    {name:'邱乗ｼ',num:souKaku,desc:'莠ｺ逕溷ｾ悟濠繧貞性繧蜈ｨ菴灘だ蜷・,formula:`${formatStrokeBreakdown(seiChars)} + ${formatStrokeBreakdown(meiChars)}`},
  ];
  return{
    sei,mei,kakus,
    seiChars,meiChars,
    reisu:{ten:useTenReisu,chi:useChiReisu,gai:seiChars.length===1||meiChars.length===1},
    approxChars,
    sourceStats,
    split:{
      source:parsed.source,
      confidence:parsed.confidence,
      original:parsed.original,
      alternatives:parsed.alternatives||[],
    },
  };
}

function getKakuLuck(n){
  let num=n;
  while(num>81) num-=80;

  // 莠疲ｼ蟋灘錐蛻､譁ｭ蜷代￠縺ｮ謨ｰ諢丞・鬘橸ｼ育ｰ｡譏灘愛螳夂畑・・
  const daiKichi=[1,3,5,6,7,8,11,13,15,16,17,21,23,24,25,31,32,37,41,45,47,52,63,65,66,81];
  const kichi=[18,35,48,57,58,61,67,68];
  const shoKyo=[26,27,28];
  const chuKyo=[46,49];
  const chui=[29,33,36,38,39,42,43,51,53,55,56,71,73,75,77,78];
  const kyo=[2,4,12,14,22,30,34,40,44,50,54,59,60,62,64,69,70,72,74,76,79,80];
  const daiKyo=[9,10,19,20];
  if(daiKichi.includes(num)) return{cls:'luck-great',lbl:'螟ｧ蜷・};
  if(kichi.includes(num)) return{cls:'luck-good',lbl:'蜷・};
  if(shoKyo.includes(num)) return{cls:'luck-warn',lbl:'蟆丞・'};
  if(chuKyo.includes(num)) return{cls:'luck-warn',lbl:'荳ｭ蜃ｶ'};
  if(chui.includes(num)) return{cls:'luck-mid',lbl:'豕ｨ諢・};
  if(kyo.includes(num)) return{cls:'luck-bad',lbl:'蜃ｶ'};
  if(daiKyo.includes(num)) return{cls:'luck-bad',lbl:'螟ｧ蜃ｶ'};
  return{cls:'luck-mid',lbl:'蟷ｳ'};
}

