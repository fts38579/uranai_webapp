  hidden:[6,7,14,26,32],
  ending:[8,10,17,36],
  stability:[4,25,30,35],
  value:[15,34,35],
  relationship:[24,25,28,29,30],
  burden:[11,19,21,23,36],
  support:[9,16,18,31,33],
  choice:[12,20,22,27],
};

function hasLenGroup(ids,groupKey){
  const group=LEN_FALLBACK_GROUPS[groupKey]||[];
  return ids.some(id=>group.includes(id));
}

