function buildFoundationSummaryOutput(){
  const namePlain=buildNamePlainInsight(NAMEJUDGE);
  const birthPlain=buildBirthPlainInsight(MEIMEI);
  const reactionLines=REACTION_PROFILE
    ?[
      REACTION_PROFILE.summary,
      `蜿榊ｿ懊′蜃ｺ繧・☆縺・ｴ髱｢・・{REACTION_PROFILE.stress}`,
      `蜉帙′蜃ｺ繧・☆縺・虚縺搾ｼ・{REACTION_PROFILE.power}`,
      REACTION_PROFILE.handling,
    ]
    :[
      '菴馴ｨ薙お繝斐た繝ｼ繝峨・蝗樒ｭ斐′縺ｾ縺縺ｪ縺・◆繧√√％縺ｮ谿ｵ髫弱・邁｡譏楢｡ｨ遉ｺ縺ｧ縺吶・,
      '蝗樒ｭ斐ｒ蜈･繧後ｋ縺ｨ縲√せ繝医Ξ繧ｹ縺悟・繧・☆縺・ｴ髱｢縺ｨ謨ｴ縺・ｄ縺吶＞譚｡莉ｶ縺ｾ縺ｧ陬懆ｶｳ縺ｧ縺阪∪縺吶・
    ];
  const sections=[
    {
      title:'蜷榊燕縺九ｉ隕九∴繧句だ蜷・,
      body:namePlain
        ?[namePlain.overview,namePlain.timing,namePlain.advice].filter(Boolean).join('\n\n')
        :'蜷榊燕縺梧悴蜈･蜉帙・縺溘ａ縲√％縺ｮ驛ｨ蛻・・莉雁屓縺ｯ逵∫払縺励※縺・∪縺吶ょ錐蜑阪ｒ蜈･繧後ｋ縺ｨ縲∽ｺｺ縺ｸ縺ｮ莨昴ｏ繧頑婿縺ｨ蟇ｾ莠ｺ髱｢縺ｮ蛯ｾ蜷代ｒ陬懆ｶｳ縺ｧ縺阪∪縺吶・
    },
    {
      title:'逕溘∪繧後°繧芽ｦ九∴繧句だ蜷・,
      body:birthPlain
        ?[birthPlain.overview,birthPlain.timing,birthPlain.advice].filter(Boolean).join('\n\n')
        :'逕溘∪繧後・諠・ｱ縺御ｸ崎ｶｳ縺励※縺・ｋ縺溘ａ縲√％縺ｮ驛ｨ蛻・・莉雁屓縺ｯ邁｡譏楢｡ｨ遉ｺ縺ｧ縺吶ら函蟷ｴ縺ｨ逕滓怦縺悟・繧九→縲∵ｵ√ｌ縺ｮ逋悶→蜉帙・蜃ｺ縺玲婿繧呈紛逅・〒縺阪∪縺吶・
    },
    {
      title:'菴馴ｨ薙お繝斐た繝ｼ繝芽ｨｺ譁ｭ',
      body:reactionLines.filter(Boolean).join('\n\n')
    }
  ];
  return sections.map(section=>`笆 ${section.title}\n${section.body}`).join('\n\n');
}

function joinCompactSentences(...parts){
  return parts.flat().map(part=>String(part||'').trim()).filter(Boolean).join(' ');
}

function summarizeInsightCards(cards=[],limit=2){
  return (cards||[])
    .slice(0,limit)
    .map(item=>`${item.title}・・{item.body}`)
    .join(' / ');
}

function getInsightCardBody(cards=[],kicker=''){
  return (cards||[]).find(item=>item.kicker===kicker)?.body||'';
}

function buildFoundationDeepSourceContext(){
  const input=getCurrentInputSnapshot();
  const focus=analyzeConsultationFocus(input.cat,input.theme);
  const birthPlain=buildBirthPlainInsight(MEIMEI);
  const birthProfile=buildMeimeiInsights(MEIMEI);
  const namePlain=buildNamePlainInsight(NAMEJUDGE);
  const nameProfile=buildNameJudgeInsights(NAMEJUDGE);
  const reaction=REACTION_PROFILE;
  const lifeText=buildLifePatternPlainText();

  const meimeiText=MEIMEI
    ?[
      birthPlain?[birthPlain.overview,birthPlain.timing,birthPlain.advice].filter(Boolean).join(' '):'',
      MEIMEI.mode==='partial'
        ?`蟷ｴ譛亥呵｣・ 蟷ｴ譟ｱ ${(MEIMEI.yearCandidates||[]).map(item=>item.key).join(' / ')||'縺ｪ縺・} / 譛域浤 ${(MEIMEI.monthCandidates||[]).map(item=>item.key).join(' / ')||'縺ｪ縺・}`
        :`蜻ｽ蠑上Γ繝｢: 譌･荳ｻ ${MEIMEI.dm} / 霄ｫ蠑ｷ蠑ｱ ${MEIMEI.strengthLabel} / 蜆ｪ蜍｢莠碑｡・${formatElementRanking(MEIMEI.cnt,2)||'縺ｪ縺・} / 陬懊≧縺ｨ謨ｴ縺・ｄ縺吶＞隕∫ｴ ${(MEIMEI.favorableElements||[]).join('繝ｻ')||'縺ｪ縺・}`,
      birthProfile?.core?`隧ｳ邏ｰ繝｡繝｢: ${birthProfile.core}`:'',
      birthProfile?.timing?`豬√ｌ縺ｮ繝｡繝｢: ${birthProfile.timing}`:'',
      birthProfile?.advice?`謨ｴ縺域婿: ${birthProfile.advice}`:'',
      birthProfile?.note?`陬懆ｶｳ: ${birthProfile.note}`:'',
      summarizeInsightCards(birthProfile?.insightCards)?`蝗帶浤謗ｨ蜻ｽ縺ｮ陬懆ｶｳ: ${summarizeInsightCards(birthProfile?.insightCards)}`:'',
    ].filter(Boolean).join('\n')
    :'縺ｪ縺・;

  const nameText=NAMEJUDGE
    ?[
      namePlain?[namePlain.overview,namePlain.timing,namePlain.advice].filter(Boolean).join(' '):'',
      `荳ｻ隕∵ｼ: 莠ｺ譬ｼ${NAMEJUDGE.kakus[1].num}逕ｻ(${getKakuLuck(NAMEJUDGE.kakus[1].num).lbl}) / 蝨ｰ譬ｼ${NAMEJUDGE.kakus[2].num}逕ｻ(${getKakuLuck(NAMEJUDGE.kakus[2].num).lbl}) / 螟匁ｼ${NAMEJUDGE.kakus[3].num}逕ｻ(${getKakuLuck(NAMEJUDGE.kakus[3].num).lbl}) / 邱乗ｼ${NAMEJUDGE.kakus[4].num}逕ｻ(${getKakuLuck(NAMEJUDGE.kakus[4].num).lbl})`,
      nameProfile?.core?`隧ｳ邏ｰ繝｡繝｢: ${nameProfile.core}`:'',
      nameProfile?.timing?`蟇ｾ莠ｺ繧・ｫ九■荳翫′繧翫・繝｡繝｢: ${nameProfile.timing}`:'',
      nameProfile?.advice?`髟ｷ譛溘〒豢ｻ縺阪ｋ蠖｢: ${nameProfile.advice}`:'',
      nameProfile?.threeTalent?`荳画燕: ${nameProfile.threeTalent.pattern} / ${nameProfile.threeTalent.summary}`:'',
      nameProfile?.yinYang?`髯ｰ髯ｽ: ${nameProfile.yinYang.summary}`:'',
      nameProfile?.splitNote?`陬懆ｶｳ: ${nameProfile.splitNote}`:'',
      summarizeInsightCards(nameProfile?.insightCards)?`蟋灘錐蛻､譁ｭ縺ｮ陬懆ｶｳ: ${summarizeInsightCards(nameProfile?.insightCards)}`:'',
    ].filter(Boolean).join('\n')
    :'縺ｪ縺・;

  const reactionText=reaction
    ?[
      `隕∫ｴ・ ${reaction.summary}`,
      `蜿榊ｿ懊′蜃ｺ繧・☆縺・ｴ髱｢: ${reaction.stress}`,
      `蜉帙′蜃ｺ繧・☆縺・虚縺・ ${reaction.power}`,
      `謇ｱ縺・婿縺ｮ繝｡繝｢: ${reaction.handling}`,
      reaction.evidence?.length?`蝗樒ｭ疲ｹ諡: ${reaction.evidence.join(' / ')}`:'',
      `隱慕函譌･縺九ｉ隕九∴繧玖｡悟虚縺ｮ逋・ ${lifeText}`,
    ].filter(Boolean).join('\n')
    :[
      '菴馴ｨ薙お繝斐た繝ｼ繝芽ｨｺ譁ｭ縺ｯ譛ｪ蜈･蜉帙・縺溘ａ邁｡譏楢｡ｨ遉ｺ縺ｧ縺吶・,
      `隱慕函譌･縺九ｉ隕九∴繧玖｡悟虚縺ｮ逋・ ${lifeText}`,
    ].filter(Boolean).join('\n');

  return{
    input,
    focus,
    contextText:`縲千嶌隲・・・{input.fullname||'縺ゅ↑縺・}縺輔ｓ
縲千嶌隲・ユ繝ｼ繝槭・{input.cat||'邱丞粋'}縲・{input.theme||'蜈ｨ闊ｬ'}縲・縲千嶌隲・・′豎ゅａ縺ｦ縺・ｋ遲斐∴縲・{focus.answerNeed}

縲仙ｧ灘錐蛻､譁ｭ縲・${nameText}

縲仙屁譟ｱ謗ｨ蜻ｽ縲・${meimeiText}

縲蝉ｽ馴ｨ薙お繝斐た繝ｼ繝芽ｨｺ譁ｭ縲・${reactionText}

縲仙渕遉朱荘螳壹・隕∫ｴ・・${LAST_OUTPUTS.about||buildFoundationSummaryOutput()}`,
  };
}

function buildFoundationDeepFallback(){
  const input=getCurrentInputSnapshot();
  const focus=analyzeConsultationFocus(input.cat,input.theme);
  const birthPlain=buildBirthPlainInsight(MEIMEI);
  const birthProfile=buildMeimeiInsights(MEIMEI);
  const namePlain=buildNamePlainInsight(NAMEJUDGE);
  const nameProfile=buildNameJudgeInsights(NAMEJUDGE);
  const reaction=REACTION_PROFILE;
  const lifeText=buildLifePatternPlainText();

  const backgroundAndCurrent=joinCompactSentences(
    `${input.fullname||'縺ゅ↑縺・}縺輔ｓ縺ｯ縲・{focus.shortLabel}縺ｮ蝣ｴ髱｢縺ｧ諢滓ュ縺縺代〒豎ｺ繧√ｋ繧医ｊ縲∬・蛻・′邏榊ｾ励〒縺阪ｋ遲矩％縺瑚ｦ九∴縺溘→縺阪↓蜉帙ｒ蜃ｺ縺励ｄ縺吶＞繧ｿ繧､繝励〒縺吶Ａ,
    birthPlain?.overview,
    namePlain?.overview,
    reaction?.summary?`蜿榊ｿ憺擇縺ｧ縺ｯ縲・{reaction.summary}`:'菴馴ｨ薙お繝斐た繝ｼ繝芽ｨｺ譁ｭ縺ｯ譛ｪ蜈･蜉帙・縺溘ａ縲√％縺ｮ驛ｨ蛻・・邁｡譏楢｡ｨ遉ｺ縺ｧ縺吶・,
    birthPlain?.timing,
    namePlain?.timing,
    reaction?.stress?`莉翫・謔ｩ縺ｿ縺ｧ縺ｯ縲・{reaction.stress} 蝣ｴ髱｢縺ｧ謠ｺ繧後ｄ縺吶￥縺ｪ繧翫∪縺吶Ａ:'',
    /菴ｿ縺｣縺ｦ縺・∪縺帙ｓ縲・/.test(lifeText)?'':`蜍輔″譁ｹ縺ｮ逋悶→縺励※縺ｯ縲・{lifeText}`
  )||'縺・∪縺ｯ遲斐∴縺昴・繧ゅ・繧呈･縺舌ｈ繧翫∬・蛻・↓蜷医≧騾ｲ繧∵婿繧貞・縺ｫ謨ｴ縺医ｋ縺ｻ縺ｩ蛻､譁ｭ縺後・繧後↓縺上￥縺ｪ繧翫∪縺吶・;

  const strengths=joinCompactSentences(
    birthProfile?.advice||birthPlain?.advice,
    namePlain?.advice,
    reaction?.power?`陦悟虚髱｢縺ｧ縺ｯ縲・{reaction.power} 蠖｢縺縺ｨ譛ｬ譚･縺ｮ蜉帙′蜃ｺ繧・☆縺・〒縺吶Ａ:'',
    reaction?.handling?`關ｽ縺｡逹縺・※蜿悶ｊ邨・ａ繧九・縺ｯ縲・{reaction.handling}`:''
  )||'蠑ｷ縺ｿ縺ｯ縲∫┌逅・↓遲斐∴繧呈･縺後★縲∬・蛻・↓蜷医≧鬆・分縺ｧ謨ｴ逅・☆繧九→螳牙ｮ壹＠縺ｦ蜉帙′蜃ｺ繧狗せ縺ｧ縺吶・;

  const risks=joinCompactSentences(
    getInsightCardBody(birthProfile?.insightCards,'RISK'),
    getInsightCardBody(nameProfile?.insightCards,'SOCIAL'),
    reaction?.stress?`迚ｹ縺ｫ ${reaction.stress} 迥ｶ豕√〒縺ｯ蛻､譁ｭ縺後・繧後ｄ縺吶￥縺ｪ繧翫∪縺吶Ａ:'',
    reaction?.handling?`縺昴・縺ｾ縺ｾ謚ｱ縺郁ｾｼ繧縺ｨ縲・{reaction.handling}`:''
  )||'縺､縺ｾ縺壹″繧・☆縺・・縺ｯ縲∫夢繧後◆迥ｶ諷九〒邨占ｫ悶□縺代ｒ諤･縺弱∬・蛻・↓蜷医≧騾ｲ繧∵婿繧帝｣帙・縺励※縺励∪縺・→縺阪〒縺吶・;

  const guidance=joinCompactSentences(
    `莉雁屓縺ｮ${focus.shortLabel}縺ｧ縺ｯ縲∵ｭ｣隗｣謗｢縺励ｈ繧翫ｂ縲瑚・蛻・′辟｡逅・↑縺冗ｶ壹￠繧峨ｌ繧句ｽ｢縲阪ｒ蜈医↓豎ｺ繧√ｋ縺ｻ縺・′邨先棡縺悟ｮ牙ｮ壹＠縺ｾ縺吶Ａ,
    birthProfile?.advice||birthPlain?.advice,
    nameProfile?.advice||namePlain?.advice,
    reaction?.handling?`諢滓ュ縺ｮ謇ｱ縺・婿縺ｯ縲・{reaction.handling}`:'',
    reaction?.power?`蜍輔￥縺ｨ縺阪・縲・{reaction.power} 繧呈э隴倥☆繧九→蝎帙∩蜷医＞繧・☆縺上↑繧翫∪縺吶Ａ:''
  )||'縺ｾ縺壹・閾ｪ蛻・↓蜷医≧騾ｲ繧∵婿繧呈紛縺医√◎縺ｮ縺・∴縺ｧ蟆上＆縺丞虚縺城・分繧剃ｽ懊ｋ縺ｮ縺後＞縺｡縺ｰ繧灘・ｮ溘〒縺吶・;

  return[
    `笆 閭梧勹縺ｨ迴ｾ迥ｶ\n${backgroundAndCurrent}`,
    `笆 蠑ｷ縺ｿ縺ｨ縺励※菴ｿ縺医ｋ縺薙→\n${strengths}`,
    `笆 縺､縺ｾ縺壹″繧・☆縺・せ\n${risks}`,
    `笆 蝨溷床繧呈紛縺医ｋ繝偵Φ繝・n${guidance}`,
  ].join('\n\n');
}

function buildCurrentReadingRecord(){
  const existing=getReadingHistory().find(r=>r.id===CURRENT_READING_ID);
  return{
    id:CURRENT_READING_ID||('rd_'+Date.now().toString(36)),
    createdAt:(existing&&existing.createdAt)||CURRENT_READING_CREATED_AT||new Date().toISOString(),
    updatedAt:new Date().toISOString(),
    plan:PLAN,
    memberSnapshot:isMemberActive(),
    input:getCurrentInputSnapshot(),
    meimei:MEIMEI,
    lp:LP,
    nameJudge:NAMEJUDGE,
    reactionProfile:REACTION_PROFILE?JSON.parse(JSON.stringify(REACTION_PROFILE)):null,
    selLen:[...SEL_LEN],
    selOrc:[...SEL_ORC],
    fixedGenderCard:FIXED_GENDER_CARD,
    clarifyAnswers:CLARIFY_ANSWERS,
    outputs:JSON.parse(JSON.stringify(LAST_OUTPUTS)),
  };
}

function getImageDetail(taskKey=''){
  if(taskKey&&IMAGE_DETAIL_CONFIG[taskKey]) return IMAGE_DETAIL_CONFIG[taskKey];
  return PLAN==='paid'?IMAGE_DETAIL_CONFIG.paid:IMAGE_DETAIL_CONFIG.free;
}

function buildCardImageRefs(kind='all',taskKey=''){
  const detail=getImageDetail(taskKey);
  const refs=[];
  if(kind==='all'||kind==='len'){
    SEL_LEN.forEach((id,index)=>{
      refs.push({
        path:`images/lenormand/${String(id).padStart(2,'0')}.png`,
        detail,
        label:`繝ｫ繝弱Ν繝槭Φ ${index+1}譫夂岼 No.${id} ${LENORMAND[id]?.name||''}`,
      });
    });
  }
  if(kind==='all'||kind==='orc'){
    SEL_ORC.forEach((id,index)=>{
      refs.push({
        path:`images/oracle/${String(id).padStart(2,'0')}.png`,
        detail,
        label:`繧ｪ繝ｩ繧ｯ繝ｫ ${index+1}譫夂岼 No.${id} ${ORACLE[id]?.name||''}`,
      });
    });
  }
  return refs;
}

function persistCurrentReading(){
  if(!CURRENT_READING_ID) return;
  const record=buildCurrentReadingRecord();
  const history=mergeHistoryRecords([record],getReadingHistory().filter(r=>r.id!==CURRENT_READING_ID));
  setReadingHistory(history);
  renderHomeVault();
  const identity=buildVaultIdentitySnapshot(record.input);
  if(identity&&canUseServerVault()){
    saveVaultRecord(record,identity).catch(()=>{});
  }
}

function computeReadingStats(history){
  const lenCounts={};
  const orcCounts={};
  const catCounts={};
  history.forEach(record=>{
    (record.selLen||[]).forEach(id=>{lenCounts[id]=(lenCounts[id]||0)+1;});
    (record.selOrc||[]).forEach(id=>{orcCounts[id]=(orcCounts[id]||0)+1;});
    const cat=record.input?.cat||'邱丞粋';
    catCounts[cat]=(catCounts[cat]||0)+1;
  });
  const pickTop=(counts,labelMap)=>Object.entries(counts)
    .sort((a,b)=>b[1]-a[1])
    .slice(0,3)
    .map(([id,count])=>`${labelMap(id)} ﾃ・{count}`)
    .join(' / ');

  const uniqueDates=[...new Set(history.map(r=>{
    const d=new Date(r.createdAt||r.updatedAt||Date.now());
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  }))];
  let streak=0;
  if(uniqueDates.length){
    let cursor=new Date(uniqueDates[0]+'T00:00:00');
    for(const dateStr of uniqueDates){
      const target=new Date(dateStr+'T00:00:00');
      if(target.getTime()===cursor.getTime()){
        streak++;
        cursor.setDate(cursor.getDate()-1);
      }
    }
  }

  return{
    total:history.length,
    paidCount:history.filter(r=>r.plan==='paid').length,
    topLen:pickTop(lenCounts,id=>`No.${id} ${LENORMAND[id]?.name||id}`),
    topOrc:pickTop(orcCounts,id=>`No.${id} ${ORACLE[id]?.name||id}`),
    topCat:Object.entries(catCounts).sort((a,b)=>b[1]-a[1]).slice(0,2).map(([cat,count])=>`${cat} ﾃ・{count}`).join(' / '),
    streak,
  };
}

function renderHomeVault(){
  renderTopHeroPanels();
  renderRecentHistory();
  renderPatternSummary();
  renderMemberStatusBlock();
  renderPremiumEntrySection();
  renderGoogleAuthShell();
}

function renderRecentHistory(){
  const listEl=document.getElementById('recent-history-list');
  const emptyEl=document.getElementById('recent-history-empty');
  const btnEl=document.getElementById('continue-reading-btn');
  if(!listEl||!emptyEl||!btnEl) return;
  const history=getReadingHistory();
  if(!history.length){
    listEl.innerHTML='';
    emptyEl.style.display='block';
    btnEl.style.display='none';
    return;
  }
  emptyEl.style.display='none';
  btnEl.style.display='inline-flex';
  const latestTheme=history[0]?.input?.theme?truncateText(history[0].input.theme,40):'蜑榊屓縺ｮ繝・・繝・;
  const latestLead=`
    <div class="vault-insight">
      <div class="vault-insight-label">縺・■縺ｰ繧捺眠縺励＞險倬鹸</div>
      <div class="vault-insight-body">縺・∪荳逡ｪ譁ｰ縺励＞險倬鹸縺ｯ縲・{escapeHtml(latestTheme)}縲阪ょ燕蝗槭・貂ｩ蠎ｦ諢溘ｒ蠑輔″邯吶＞縺縺ｾ縺ｾ縲∝酔縺倥ユ繝ｼ繝槭・邯壹″繧呈ｷｱ縺剰ｪｭ繧√∪縺吶・/div>
    </div>`;
  listEl.innerHTML=latestLead+history.slice(0,3).map(record=>{
    const theme=record.input?.theme?truncateText(record.input.theme,34):'蜈ｨ菴薙・豬√ｌ';
    const cardLine=truncateText((record.selLen||[]).map(id=>LENORMAND[id]?.name).filter(Boolean).join('繝ｻ'),42);
    return`
      <button class="history-item" onclick="openHistoryItem('${record.id}')">
        <div class="history-item-top">
          <span class="history-item-date">${formatHistoryDate(record.createdAt)}</span>
          <span class="history-pill ${record.plan==='paid'?'paid':'free'}">${record.plan==='paid'?'12譫夐荘螳・:'辟｡譁咎荘螳・}</span>
        </div>
        <div class="history-item-title">${escapeHtml(record.input?.cat||'邱丞粋')}・・{escapeHtml(theme)}</div>
        <div class="history-item-meta">${escapeHtml(cardLine)}</div>
        <div class="history-item-tail">
          <span>${record.plan==='paid'?'騾ｲ霍ｯ縺ｾ縺ｧ隱ｭ繧薙□險倬鹸':'蜷代″繧堤｢ｺ縺九ａ縺溷・蜿｣'}</span>
          <span class="history-item-link">邯壹″繧定ｪｭ繧</span>
        </div>
      </button>`;
  }).join('');
}

function renderPatternSummary(){
  const listEl=document.getElementById('pattern-summary-list');
  const emptyEl=document.getElementById('pattern-summary-empty');
  if(!listEl||!emptyEl) return;
  const history=getReadingHistory();
  if(history.length<2){
    listEl.innerHTML='';
    emptyEl.style.display='block';
    return;
  }
  const stats=computeReadingStats(history);
  emptyEl.style.display='none';
  const rows=[
    ['遨阪∩荳翫′繧・,`${stats.total}蝗・/ 豺ｱ謗倥ｊ ${stats.paidCount}蝗杼],
    ['縺・∪螟壹＞逶ｸ隲・ユ繝ｼ繝・,stats.topCat||'縺ｾ縺闢・ｩ堺ｸｭ'],
    ['郢ｰ繧願ｿ斐＠蜃ｺ繧句粋蝗ｳ',stats.topLen||'縺ｾ縺闢・ｩ堺ｸｭ'],
    ['閭御ｸｭ繧呈款縺吶き繝ｼ繝・,stats.topOrc||'縺ｾ縺闢・ｩ堺ｸｭ'],
    ['邯壹￠縺ｦ蜷代″蜷医▲縺滓律謨ｰ',stats.streak?`${stats.streak}譌･`:'1譌･'],
  ];
  const patternLead=`險倬鹸縺ｯ${stats.total}蝗槭ゅ＞縺ｾ螟壹＞繝・・繝槭・${truncateText(stats.topCat||'縺ｾ縺闢・ｩ堺ｸｭ',30)}縺ｧ縲∬ｪｭ縺ｿ霑斐☆縺ｻ縺ｩ逶ｸ隲・・霆ｸ縺瑚ｦ九∴繧・☆縺上↑縺｣縺ｦ縺・∪縺吶Ａ;
  listEl.innerHTML=`
    <div class="vault-insight">
      <div class="vault-insight-label">縺・∪隕九∴繧句だ蜷・/div>
      <div class="vault-insight-body">${escapeHtml(patternLead)}</div>
    </div>
    ${rows.map(([label,value])=>`
    <div class="pattern-row">
      <div class="pattern-label">${escapeHtml(label)}</div>
      <div class="pattern-value">${escapeHtml(value)}</div>
    </div>`).join('')}`;
}

