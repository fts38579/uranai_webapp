      if(mode==='reflective') return '縺薙ｌ縺ｾ縺ｧ縺ｮ縺ゅ↑縺溘・縲∫ｯ逶ｮ縺斐→縺ｫ閾ｪ蛻・ｒ譖ｴ譁ｰ縺励↑縺後ｉ縺薙％縺ｾ縺ｧ譚･縺ｦ縺・∪縺吶・;
      if(mode==='present') return '莉翫・蜿､縺・ｄ繧頑婿縺ｮ縺ｾ縺ｾ鬆大ｼｵ繧九ｈ繧翫√ｄ繧頑婿縺昴・繧ゅ・繧定ｦ狗峩縺吶％縺ｨ縺悟､ｧ蛻・〒縺吶・;
      return '螟牙喧繧呈悶′繧翫☆縺弱★縲∝ｰ上＆縺乗峩譁ｰ縺励※縺・￥縺ｻ縺ｩ豬√ｌ縺ｯ霆ｽ縺上↑繧翫∪縺吶・;
    }
    if(/豬√ｌ|荵励ｊ縺薙↑/.test(text)){
      if(mode==='reflective') return '縺薙ｌ縺ｾ縺ｧ縺ｮ縺ゅ↑縺溘・縲∫憾豕√ｒ螢翫＆縺壹≧縺ｾ縺丞粋繧上○縺ｪ縺後ｉ謖√■縺薙◆縺医※縺阪◆縺ｯ縺壹〒縺吶・;
      if(mode==='present') return '莉翫・豬√＆繧後ｋ縺ｾ縺ｾ縺ｧ縺ｯ縺ｪ縺上∬・蛻・′縺ｩ縺薙∪縺ｧ蜷医ｏ縺帙ｋ縺九ｒ豎ｺ繧√ｋ縺薙→縺悟､ｧ蛻・〒縺吶・;
      return '辟｡逅・↓蜈ｨ驛ｨ繧貞虚縺九☆繧医ｊ縲∵ｵ√ｌ縺ｮ荳ｭ縺ｧ驕ｸ縺ｶ蝣ｴ謇繧呈ｱｺ繧√ｋ縺ｻ縺・′騾ｲ縺ｿ繧・☆縺上↑繧翫∪縺吶・;
    }
    if(/邏皮ｲ弓讌ｽ縺励＆|辟｡驍ｪ豌・.test(text)){
      if(mode==='reflective') return '縺ゅ↑縺溘・譛ｬ譚･縲√＠繧薙←縺・ｸｭ縺ｧ繧よｰ玲戟縺｡縺ｮ霆ｽ縺輔ｒ螟ｱ縺・″繧峨↑縺・ｺｺ縺ｧ縺吶・;
      if(mode==='present') return '莉翫・豁｣縺励＆繧医ｊ縲∽ｽ輔ｒ縺励※縺・ｋ縺ｨ縺阪↓豌玲戟縺｡縺瑚ｻｽ縺上↑繧九°繧堤┌隕悶＠縺ｪ縺・％縺ｨ縺悟､ｧ蛻・〒縺吶・;
      return '豌玲戟縺｡縺瑚ｻｽ縺上↑繧区婿蜷代ｒ驕ｸ縺ｶ縺ｻ縺ｩ縲∵ｬ｡縺ｮ蛻､譁ｭ繧よ紛縺・ｄ縺吶￥縺ｪ繧翫∪縺吶・;
    }
    if(mode==='reflective') return '縺薙％縺ｾ縺ｧ縺ｮ縺ゅ↑縺溘・縲∬・蛻・↑繧翫・繧・ｊ譁ｹ縺ｧ菴輔→縺区戟縺｡縺薙◆縺医※縺阪◆縺ｯ縺壹〒縺吶・;
    if(mode==='present') return '莉翫・縺・■縺ｰ繧鍋夢繧後※縺・ｋ驛ｨ蛻・ｒ蠕悟屓縺励↓縺励↑縺・％縺ｨ縺悟､ｧ蛻・〒縺吶・;
    return '蟆代＠蜈医・譎ｯ濶ｲ繧貞・菴鍋噪縺ｫ縺吶ｋ縺ｨ縲∵ｬ｡縺ｮ蜍輔″縺ｯ豎ｺ繧√ｄ縺吶￥縺ｪ繧翫∪縺吶・;
  };
  const reflective=messages[0]?summarizeOracleHint(messages[0],'reflective'):null;
  const currentNeed=messages[1]?summarizeOracleHint(messages[1],'present'):messages[0]?summarizeOracleHint(messages[0],'present'):null;
  const futureNeed=messages[2]?summarizeOracleHint(messages[2],'future'):messages[messages.length-1]?summarizeOracleHint(messages[messages.length-1],'future'):null;
  const actionPlan=buildThemeSpecificActionPlan(focus);
  const lines=[];
  lines.push('笆 縺・∪陬懊ｏ繧後ｋ隕也せ','');
  if(reflective){
    lines.push(`縺薙％縺ｾ縺ｧ縺ｮ${name}縺輔ｓ縺ｯ縲・{reflective}`);
  }else{
    lines.push(`${name}縺輔ｓ縺ｯ縺薙％縺ｾ縺ｧ縲∫憾豕√↓蜷医ｏ縺帙↑縺後ｉ菴輔→縺句ｴｩ繧後★縺ｫ繧・▲縺ｦ縺薙ｈ縺・→縺励※縺阪◆縺ｯ縺壹〒縺吶Ａ);
  }
  if(currentNeed){
    lines.push(`縺溘□莉翫・縲・{currentNeed}`);
  }
  if(LP&&lpCard){
    lines.push(`繧ゅ→繧ゅ→縺ｮ謖√■蜻ｳ縺ｨ縺励※縲・{lpCard.msg.replace(/縺励※縺上□縺輔＞縲・$/,'縺ｧ縺阪ｋ莠ｺ縺ｧ縺吶・)} 縺昴・濶ｯ縺輔ｒ縲√＞縺ｾ縺ｯ莉紋ｺｺ縺ｮ縺溘ａ縺縺代〒縺ｪ縺剰・蛻・・蛻､譁ｭ縺ｫ繧ゆｽｿ縺・ｮｵ髫弱〒縺吶Ａ);
  }

  lines.push('','笆 縺ゅ↑縺溘ｉ縺励＆','');
  if(namePlain){
    lines.push(namePlain.overview);
  }
  if(birthPlain){
    lines.push(birthPlain.overview);
  }
  if(reaction?.power){
    lines.push(`蜿榊ｿ懊・蜃ｺ譁ｹ縺ｧ縺ｯ縲・{reaction.power} 蠖｢縺ｧ蜉帙ｒ蜃ｺ縺励ｄ縺吶＞莠ｺ縺ｧ縺吶Ａ);
  }else if(reaction?.summary){
    lines.push(reaction.summary);
  }
  if(reaction?.handling){
    lines.push(`謚ｱ縺域婿縺ｮ逋悶→縺励※縺ｯ縲・{reaction.handling}`);
  }

  lines.push('','笆 謨ｴ縺域婿縺ｨ谺｡縺ｮ荳謇・,'');
  if(focus.isDualConcern){
    lines.push('諱区・縺ｨ莉穂ｺ九ｒ蜷後§荳榊ｮ峨〒謚ｱ縺医↑縺・％縺ｨ縺梧怙蜆ｪ蜈医〒縺吶よ°諢帙〒縺ｯ縲悟ｮ牙ｿ・〒縺阪ｋ縺九阪∽ｻ穂ｺ九〒縺ｯ縲檎ｶ壹￠繧区э蜻ｳ縺後≠繧九°縲阪→縲∝撫縺・ｒ蛻・￠繧九□縺代〒鬆ｭ縺ｮ豺ｷ荵ｱ縺後°縺ｪ繧頑ｸ帙ｊ縺ｾ縺吶・);
  }else if(focus.hasLove){
    lines.push('逶ｸ謇九・豌玲戟縺｡繧定ｪｭ繧縺薙→繧医ｊ蜈医↓縲∬・蛻・′縺薙・髢｢菫ゅ〒菴輔ｒ謌第・縺励☆縺弱※縺・ｋ縺ｮ縺九ｒ隱阪ａ繧九％縺ｨ縺悟・縺ｧ縺吶・);
  }else if(focus.hasWork){
    lines.push('莉翫・迺ｰ蠅・↓蜷医ｏ縺帷ｶ壹￠繧九％縺ｨ繧医ｊ縲∬・蛻・′縺ｩ繧薙↑譚｡莉ｶ縺ｪ繧牙鴨繧貞・縺励ｄ縺吶＞縺九ｒ縺ｯ縺｣縺阪ｊ縺輔○繧九％縺ｨ縺悟・縺ｧ縺吶・);
  }else{
    lines.push('縺・∪蠢・ｦ√↑縺ｮ縺ｯ縲∵ｭ｣縺励＞遲斐∴繧剃ｸ豌励↓蜃ｺ縺吶％縺ｨ縺ｧ縺ｯ縺ｪ縺上∬・蛻・′菴輔↓蠑輔▲縺九°縺｣縺ｦ縺・ｋ縺ｮ縺九ｒ縺ｯ縺｣縺阪ｊ縺輔○繧九％縺ｨ縺ｧ縺吶・);
  }
  if(futureNeed){
    lines.push(`縺昴・縺・∴縺ｧ縲・{futureNeed}`);
  }
  lines.push('霑ｷ縺・′蠑ｷ縺・律縺ｯ縲・ｭ縺ｮ荳ｭ縺ｧ邨占ｫ悶ｒ蜃ｺ縺昴≧縺ｨ縺励↑縺・〒縺上□縺輔＞縲ゅ∪縺壹梧─諠・阪檎樟螳溘・譚｡莉ｶ縲阪檎嶌謇九ｄ閨ｷ蝣ｴ縺ｫ遒ｺ隱阪☆縺ｹ縺阪％縺ｨ縲阪・3縺､縺ｫ蛻・￠繧九□縺代〒縲∵ｷｷ荵ｱ縺ｯ縺九↑繧翫⊇縺ｩ縺代∪縺吶・);
  lines.push('縺励ｓ縺ｩ縺・律縺ｮ蛻､譁ｭ縺ｯ縲√◎縺ｮ譌･縺ｮ豌怜・繧医ｊ縲∵嶌縺榊・縺励◆蜀・ｮｹ繧堤ｿ梧律縺ｫ隕狗峩縺励◆縺ｨ縺阪↓縺ｾ縺邏榊ｾ励〒縺阪ｋ縺九〒隕九※縺上□縺輔＞縲・);
  if(!futureNeed){
    lines.push('螟ｧ縺阪￥螟峨∴繧医≧縺ｨ縺吶ｋ繧医ｊ縲∫┌逅・↑縺冗ｶ壹￠繧峨ｌ繧句ｰ上＆縺ｪ蜍輔″縺九ｉ譛ｪ譚･繧貞ｯ・○縺ｦ縺・￥縺ｻ縺・′縲√＞縺ｾ縺ｯ迴ｾ螳溘↓蜷医▲縺ｦ縺・∪縺吶・);
  }
  actionPlan.slice(0,3).forEach((item,index)=>lines.push(`${index+1}. ${item}`));
  return lines.join('\n');
}

function buildIntegratedFallback(name,cat,theme=''){
  const focus=analyzeConsultationFocus(cat,theme);
  const ids=[...SEL_LEN];
  const hasHidden=hasLenGroup(ids,'hidden');
  const hasEnding=hasLenGroup(ids,'ending');
  const hasValue=hasLenGroup(ids,'value');
  const hasSupport=hasLenGroup(ids,'support');
  const actionPlan=buildThemeSpecificActionPlan(focus);
  const lines=['笆 譛邨らｵ占ｫ・,''];

  if(focus.isDualConcern){
    lines.push(`${name}縺輔ｓ縺ｮ遲斐∴縺ｯ縲√梧°諢帙→莉穂ｺ九ｒ蜷梧凾縺ｫ迚・▼縺代ｈ縺・→縺励↑縺・％縺ｨ縲阪〒縺吶ゅ＞縺ｾ縺ｯ荳｡譁ｹ繧剃ｸ豌励↓豎ｺ繧√ｋ繧医ｊ縲∵°諢帙〒縺ｯ螳牙ｿ・─縲∽ｻ穂ｺ九〒縺ｯ邏榊ｾ玲─縺ｨ縺・≧蛻･縲・・霆ｸ縺ｧ隕狗峩縺励◆縺ｻ縺・′蜑阪↓騾ｲ繧√∪縺吶Ａ);
  }else if(focus.hasLove){
    lines.push(`${name}縺輔ｓ縺ｮ遲斐∴縺ｯ縲√梧ュ縺ｮ蠑ｷ縺輔阪〒縺ｯ縺ｪ縺上悟髄縺榊粋縺医ｋ髢｢菫ゅ°縲阪〒隕区･ｵ繧√ｋ縺薙→縺ｧ縺吶Ａ);
  }else if(focus.hasWork){
    lines.push(`${name}縺輔ｓ縺ｮ遲斐∴縺ｯ縲√瑚ｾ槭ａ縺溘＞豌怜・縲阪〒縺ｯ縺ｪ縺上檎ｶ壹￠縺溷・縺ｫ諢丞袖縺梧ｮ九ｋ縺九阪〒蛻､譁ｭ縺吶ｋ縺薙→縺ｧ縺吶Ａ);
  }else{
    lines.push(`${name}縺輔ｓ縺ｮ遲斐∴縺ｯ縲∵ｰ玲戟縺｡繧定誠縺｡逹縺九○繧九％縺ｨ繧医ｊ蜈医↓縲∝愛譁ｭ繧呈ｭ｢繧√※縺・ｋ譚｡莉ｶ繧定ｦ九∴繧句ｽ｢縺ｫ縺吶ｋ縺薙→縺ｧ縺吶Ａ);
  }
  if(hasHidden) lines.push('縺ｾ縺隕九∴縺ｦ縺・↑縺・悽髻ｳ繧・擅莉ｶ縺後≠繧九・縺ｧ縲∽ｻ企ｱ縺ｯ邨占ｫ悶ｒ諤･縺舌ｈ繧顔｢ｺ隱阪ｒ蠅励ｄ縺吶⊇縺・′譛牙柑縺ｧ縺吶・);
  if(hasEnding) lines.push('縺溘□縺励∝・騾√ｊ繧堤ｶ壹￠繧九⊇縺ｩ縲∬・蛻・〒驕ｸ縺ｶ蜑阪↓豬√ｌ縺梧ｱｺ縺ｾ繧翫ｄ縺吶￥縺ｪ繧翫∪縺吶・);
  if(hasSupport) lines.push('遒ｺ隱阪・繧､繝ｳ繝医ｒ蜈医↓險闡峨↓縺ｧ縺阪ｌ縺ｰ縲∵ｵ√ｌ縺ｯ遶九※逶ｴ縺帙∪縺吶・);

  lines.push('','笆 蛻､譁ｭ縺ｮ霆ｸ','');
  if(focus.isDualConcern){
    lines.push(`騾ｲ繧√※繧医＞逶ｮ蜊ｰ・壽°諢帙〒縺ｯ縲∽ｸ榊ｮ峨ｒ莨昴∴縺溘→縺阪↓逶ｸ謇九′蜷代″蜷医≧縺薙→縲ゆｻ穂ｺ九〒縺ｯ縲∝濠蟷ｴ蠕後・閾ｪ蛻・↓邨碁ｨ薙・蜿主・繝ｻ蜒阪″繧・☆縺輔・縺ｩ繧後°縺梧ｮ九ｋ縺薙→縲Ａ);
    lines.push(`隕狗峩縺咏岼蜊ｰ・壹←縺｡繧峨ｂ譖匁乂縺ｪ霑皮ｭ斐・縺ｾ縺ｾ雋諡・□縺代′蠅励∴繧九％縺ｨ縲・{hasValue?'謳榊ｾ励ｄ雋諡・・驥｣繧雁粋縺・ｂ縲∽ｻ雁屓縺ｯ隕矩・＆縺ｪ縺・〒縺上□縺輔＞縲・:''}`);
  }else if(focus.hasLove){
    lines.push('騾ｲ繧√※繧医＞逶ｮ蜊ｰ・夊ｩｱ縺怜粋縺・′騾ｲ縺ｿ縲∝､ｧ莠九↑縺薙→縺ｫ逶ｸ謇九′蜷代″蜷医≧縺薙→縲・);
    lines.push('隕狗峩縺咏岼蜊ｰ・壼､ｧ莠九↑縺薙→繧呈尠譏ｧ縺ｫ縺輔ｌ縺溘∪縺ｾ縲∝ｾ・▽蛛ｴ縺ｫ縺縺題ｲ諡・′蠅励∴繧九％縺ｨ縲・);
  }else if(focus.hasWork){
    lines.push('騾ｲ繧√※繧医＞逶ｮ蜊ｰ・壽隼蝟・・隕玖ｾｼ縺ｿ縺後≠繧翫√％縺ｮ蜈医↓谿九ｋ繧ゅ・縺瑚ｦ九∴縺ｦ縺・ｋ縺薙→縲・);
    lines.push('隕狗峩縺咏岼蜊ｰ・壽擅莉ｶ縺悟､峨ｏ繧峨↑縺・∪縺ｾ豸郁励□縺代′蠅励∴縺ｦ縺・ｋ縺薙→縲・);
  }else{
    lines.push('騾ｲ繧√※繧医＞逶ｮ蜊ｰ・夂｢ｺ隱阪＠縺溘＞縺薙→繧堤｢ｺ隱阪＠縺溘≠縺ｨ縺ｧ繧らｴ榊ｾ励′谿九ｋ縺薙→縲・);
    lines.push('隕狗峩縺咏岼蜊ｰ・壽ュ蝣ｱ縺瑚ｶｳ繧翫↑縺・∪縺ｾ縲∝兇縺・ｄ荳榊ｮ峨□縺代〒豎ｺ繧√ｈ縺・→縺励※縺・ｋ縺薙→縲・);
  }

  lines.push('','笆 陦悟虚險育判','');
  actionPlan.slice(0,3).forEach((item,index)=>lines.push(`${index+1}. ${item}`));
  return lines.join('\n');
}

function getBasicFallback(){
  const birthPlain=buildBirthPlainInsight(MEIMEI);
  const namePlain=buildNamePlainInsight(NAMEJUDGE);
  const reactionLead=REACTION_PROFILE?.summary||'';
  return{
    personality:[birthPlain?.overview,namePlain?.overview,reactionLead].filter(Boolean).join(' ')||'縺ゅ↑縺溘・迥ｶ豕√・陦ｨ髱｢縺縺代〒縺ｪ縺上∵ｵ√ｌ縺ｮ逋悶∪縺ｧ諢溘§蜿悶ｌ繧区婿縺ｧ縺吶・,
    timing:[birthPlain?.timing,namePlain?.timing].filter(Boolean).join(' '),
    strengths:[birthPlain?.advice,namePlain?.advice,REACTION_PROFILE?.handling].filter(Boolean).join(' '),
  };
}

function typeText(id,text,delay=0){
  const el=document.getElementById(id);
  if(!el) return;
  const normalized=String(text||'')
    .replace(/\r\n?/g,'\n')
    .replace(/\n{3,}/g,'\n\n')
    .replace(/([^\n])\n(笆)/g,'$1\n\n$2')
    .trim();
  el.innerHTML='';
  setTimeout(()=>{
    if(normalized.length>1800){
      el.textContent=normalized;
      return;
    }
    let i=0;
    const cur=document.createElement('span');
    cur.className='cursor2';
    el.appendChild(cur);
    const speed=normalized.length>900?4:(normalized.length>400?7:12);
    const iv=setInterval(()=>{
      if(i>=normalized.length){clearInterval(iv);cur.remove();return;}
      cur.insertAdjacentText('beforebegin',normalized[i++]);
    },speed);
  },delay);
}

