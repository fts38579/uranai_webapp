        </div>
      `).join('')}
    </div>
    <div class="premium-entry-detail-stack">
      ${MEMBERSHIP_PLAN.features.map(feature=>`
        <div class="premium-entry-card">
          <div class="premium-entry-card-eyebrow">${escapeHtml(feature.eyebrow)}</div>
          <div class="premium-entry-card-title">${escapeHtml(feature.title)}</div>
          <div class="premium-entry-card-kicker">${escapeHtml(feature.problemLabel||'繧医￥縺ゅｋ蜊縺・□縺ｨ')}</div>
          <div class="premium-entry-card-body">${escapeHtml(feature.problem)}</div>
          <div class="premium-entry-card-kicker">${escapeHtml(feature.solutionLabel||'鄒・・蜊陦薙〒縺ｯ縺薙≧隱ｭ繧')}</div>
          <div class="premium-entry-card-body">${escapeHtml(feature.solution)}</div>
          <div class="premium-entry-card-kicker">${escapeHtml(feature.outcomeLabel||'隱ｭ縺ｿ邨ゅｏ繧九％繧阪↓縺ｯ')}</div>
          <div class="premium-entry-card-body">${escapeHtml(feature.outcome)}</div>
        </div>
      `).join('')}
    </div>
    <div class="premium-entry-actions">
      ${primaryAction}
      <button class="premium-entry-subbtn" onclick="startFlow('free')">縺ｾ縺壹・辟｡譁吶〒隧ｦ縺・/button>
    </div>`;
}

async function toggleMemberPreview(){
  if(!canUsePaidTestMode()){
    showToast('莨壼藤繝励Ξ繝薙Η繝ｼ縺ｯ繝ｭ繝ｼ繧ｫ繝ｫ隧ｦ鬨鍋腸蠅・〒縺ｮ縺ｿ譛牙柑縺ｧ縺・);
    return;
  }
  if(isMemberActive()){
    await logoutMemberSession({render:true});
    return;
  }
  rememberMemberPreview(true);
  const ok=await activateMemberSession({mode:'local_preview'},{render:true});
  if(!ok){
    rememberMemberPreview(false);
    showToast('繝ｭ繝ｼ繧ｫ繝ｫ隧ｦ鬨薙そ繝・す繝ｧ繝ｳ繧堤匱陦後〒縺阪∪縺帙ｓ縺ｧ縺励◆');
    return;
  }
  renderHomeVault();
  renderMemberFollowupSection();
}

function isMemberActive(){
  return !!MEMBER_AUTH.active;
}

function resetLatestOutputs(){
  LAST_OUTPUTS={about:'',foundationDeep:'',len:'',orc:'',integration:'',dossier:'',followups:{}};
  ACTIVE_FOLLOWUP_KEY='';
  FOLLOWUP_LOADING=false;
  DOSSIER_LOADING=false;
}

function beginReadingSession(){
  CURRENT_READING_ID='rd_'+Date.now().toString(36)+Math.random().toString(36).slice(2,8);
  CURRENT_READING_CREATED_AT=new Date().toISOString();
  resetLatestOutputs();
}

function escapeHtml(text){
  return String(text||'')
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#39;');
}

function truncateText(text,max=46){
  const raw=String(text||'').trim();
  return raw.length>max?raw.slice(0,max-1)+'窶ｦ':raw;
}

function getReadingHistory(){
  try{
    const parsed=JSON.parse(localStorage.getItem(HISTORY_STORAGE_KEY)||'[]');
    return Array.isArray(parsed)?parsed:[];
  }catch(e){
    return [];
  }
}

function setReadingHistory(records){
  try{
    localStorage.setItem(HISTORY_STORAGE_KEY,JSON.stringify(records.slice(0,48)));
  }catch(e){}
}

function bindVaultIdentityListeners(){
  ['f-fullname','f-year','f-month','f-day','f-hour'].forEach(id=>{
    const el=document.getElementById(id);
    if(!el) return;
    el.addEventListener('change',scheduleVaultHistorySync);
    if(id==='f-fullname') el.addEventListener('blur',scheduleVaultHistorySync);
  });
  const catEl=document.getElementById('f-cat');
  if(catEl) catEl.addEventListener('change',scheduleVaultHistorySync);
  const themeEl=document.getElementById('f-theme');
  if(themeEl) themeEl.addEventListener('blur',scheduleVaultHistorySync);
  ['female','male','other'].forEach(key=>{
    const el=document.getElementById(`gb-${key}`);
    if(el) el.addEventListener('click',()=>setTimeout(scheduleVaultHistorySync,0));
  });
}

function buildVaultIdentitySnapshot(input=getCurrentInputSnapshot()){
  const fullname=String(input?.fullname||'').trim().replace(/\s+/g,' ');
  const year=parseInt(input?.year,10)||null;
  const month=parseInt(input?.month,10)||null;
  const rawDay=input?.day;
  const day=(rawDay===null||rawDay===undefined||rawDay===''||rawDay==='unknown')
    ?'unknown'
    :(parseInt(rawDay,10)||'unknown');
  if(!fullname||!year||!month) return null;
  return{
    fullname,
    gender:String(input?.gender||GENDER||'unknown'),
    year,
    month,
    day,
  };
}

function getVaultIdentityCacheKey(identity){
  if(!identity) return '';
  return[
    String(identity.fullname||'').trim().toLowerCase(),
    String(identity.gender||'unknown').trim().toLowerCase(),
    String(identity.year||''),
    String(identity.month||''),
    String(identity.day??'unknown'),
  ].join('|');
}

function canUseServerVault(){
  return canUseProxy();
}

function mergeHistoryRecords(...lists){
  const merged=new Map();
  lists.flat().forEach(record=>{
    if(!record||!record.id) return;
    const prev=merged.get(record.id);
    const prevTime=new Date(prev?.updatedAt||prev?.createdAt||0).getTime();
    const nextTime=new Date(record.updatedAt||record.createdAt||0).getTime();
    if(!prev||nextTime>=prevTime){
      merged.set(record.id,record);
    }
  });
  return[...merged.values()]
    .sort((a,b)=>new Date(b.updatedAt||b.createdAt||0)-new Date(a.updatedAt||a.createdAt||0))
    .slice(0,48);
}

async function queryVaultHistory(identity){
  const res=await fetch(VAULT_QUERY_ENDPOINT,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({identity}),
  });
  const data=await readJsonSafe(res);
  if(!res.ok) throw new Error(data?.error||'VAULT_QUERY_FAILED');
  return Array.isArray(data?.records)?data.records:[];
}

async function saveVaultRecord(record,identity){
  const res=await fetch(VAULT_SAVE_ENDPOINT,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({identity,record}),
  });
  const data=await readJsonSafe(res);
  if(!res.ok) throw new Error(data?.error||'VAULT_SAVE_FAILED');
  return data;
}

async function clearVaultHistory(identity){
  const res=await fetch(VAULT_CLEAR_ENDPOINT,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({identity}),
  });
  const data=await readJsonSafe(res);
  if(!res.ok) throw new Error(data?.error||'VAULT_CLEAR_FAILED');
  return data;
}

async function syncVaultHistory(options={}){
  const identity=options.identity||buildVaultIdentitySnapshot();
  if(!identity||!canUseServerVault()) return getReadingHistory();
  const cacheKey=getVaultIdentityCacheKey(identity);
  if(VAULT_SYNC_STATE.syncing&&VAULT_SYNC_STATE.lastKey===cacheKey){
    return getReadingHistory();
  }
  VAULT_SYNC_STATE.syncing=true;
  VAULT_SYNC_STATE.ready=true;
  VAULT_SYNC_STATE.lastKey=cacheKey;
  try{
    const remoteRecords=await queryVaultHistory(identity);
    const merged=mergeHistoryRecords(remoteRecords,getReadingHistory());
    setReadingHistory(merged);
    VAULT_SYNC_STATE.source=remoteRecords.length?'server':'local';
    VAULT_SYNC_STATE.error='';
    if(options.render!==false) renderHomeVault();
    return merged;
  }catch(e){
    VAULT_SYNC_STATE.error=e?.message||'VAULT_SYNC_FAILED';
    return getReadingHistory();
  }finally{
    VAULT_SYNC_STATE.syncing=false;
  }
}

function scheduleVaultHistorySync(){
  if(VAULT_SYNC_TIMER) clearTimeout(VAULT_SYNC_TIMER);
  VAULT_SYNC_TIMER=setTimeout(()=>{
    syncVaultHistory({render:true});
  },VAULT_SYNC_DEBOUNCE_MS);
}

function formatHistoryDate(iso){
  if(!iso) return '';
  const d=new Date(iso);
  if(Number.isNaN(d.getTime())) return '';
  const yy=d.getFullYear();
  const mm=String(d.getMonth()+1).padStart(2,'0');
  const dd=String(d.getDate()).padStart(2,'0');
  const hh=String(d.getHours()).padStart(2,'0');
  const mi=String(d.getMinutes()).padStart(2,'0');
  return `${yy}.${mm}.${dd} ${hh}:${mi}`;
}

function getCurrentInputSnapshot(){
  return{
    fullname:document.getElementById('f-fullname')?.value?.trim()||'',
    gender:GENDER,
    year:parseInt(document.getElementById('f-year')?.value,10)||null,
    month:parseInt(document.getElementById('f-month')?.value,10)||null,
    day:getSelectedBirthDay(),
    hour:getSelectedBirthHour(),
    cat:document.getElementById('f-cat')?.value||'邱丞粋',
    theme:document.getElementById('f-theme')?.value?.trim()||'',
    reactionAnswers:getReactionAnswersSnapshot(),
  };
}

function analyzeConsultationFocus(cat='',theme=''){
  const raw=`${cat||''} ${theme||''}`;
  const hasLove=/諱区・|邨仙ｩ嘶蠖ｼ豌楯蠖ｼ螂ｳ|莠､髫斈逶ｸ謇弓蛻･繧芸蛻･繧後ｋ|蠕ｩ邵－繝代・繝医リ繝ｼ|螟ｫ|螯ｻ/.test(raw)||cat==='諱区・';
  const hasWork=/莉穂ｺ弓霆｢閨ｷ|閨ｷ蝣ｴ|莨夂､ｾ|荳雁昇|繧ｭ繝｣繝ｪ繧｢|騾閨ｷ|霎槭ａ|蜍､蜍處蜿主・|縺企≡|驥鷹姦|蜒阪″譁ｹ/.test(raw)||cat==='莉穂ｺ・||cat==='驥鷹°';
  const needsRelationshipDecision=/邯壹￠繧九∋縺鋼蛻･繧後ｋ縺ｹ縺鋼蛻･繧芸霍晞屬繧堤ｽｮ|莠､髫・.test(raw);
  const needsCareerDecision=/邯壹￠繧九∋縺鋼霆｢閨ｷ|霎槭ａ繧弓騾閨ｷ|蜒阪″譁ｹ/.test(raw)||cat==='莉穂ｺ・;
  const needsDecision=/蛻､譁ｭ|豎ｺ繧－霑ｷ|驕ｸ縺ｹ/.test(raw)||needsRelationshipDecision||needsCareerDecision;
  const isDualConcern=hasLove&&hasWork;
  const shortLabel=isDualConcern?'諱区・縺ｨ莉穂ｺ・:hasLove?'諱区・':hasWork?'莉穂ｺ・:(cat||'莉翫・謔ｩ縺ｿ');
  const answerNeed=isDualConcern
    ?'諱区・縺ｨ莉穂ｺ九ｒ豺ｷ縺懊★縺ｫ縲√◎繧後◇繧後・蛻､譁ｭ霆ｸ繧貞・縺代※謨ｴ逅・＠縺ｦ縺ｻ縺励＞'
    :hasLove
      ?'髢｢菫ゅｒ邯壹￠繧九°霍晞屬繧貞叙繧九°縺ｮ蛻､譁ｭ譚先侭縺後⊇縺励＞'
      :hasWork
        ?'莉翫・莉穂ｺ九ｒ邯壹￠繧九°蛻・ｊ譖ｿ縺医ｋ縺九・蛻､譁ｭ譚先侭縺後⊇縺励＞'
        :'縺・∪菴輔ｒ蜆ｪ蜈医＠縺ｦ謨ｴ縺医ｋ縺ｹ縺阪°繧堤衍繧翫◆縺・;
  const dossierTitle=isDualConcern
    ?'諱区・縺ｨ莉穂ｺ九・蛻・°繧檎岼縺ｫ遶九▽縺ｨ縺阪・髑大ｮ壽嶌'
    :hasLove
      ?'髢｢菫ゅｒ隕区･ｵ繧√ｋ縺溘ａ縺ｮ髑大ｮ壽嶌'
      :hasWork
        ?'蜒阪″譁ｹ繧定ｦ狗峩縺吶◆繧√・髑大ｮ壽嶌'
        :'縺・∪縺ｮ騾ｲ霍ｯ繧呈紛縺医ｋ縺溘ａ縺ｮ髑大ｮ壽嶌';
  return{
    raw,
    hasLove,
    hasWork,
    needsRelationshipDecision,
    needsCareerDecision,
    needsDecision,
    isDualConcern,
    shortLabel,
    answerNeed,
    dossierTitle,
  };
}

