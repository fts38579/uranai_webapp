        '莉翫☆縺仙虚縺上→縺励◆繧峨√＞縺｡縺ｰ繧鍋樟螳溽噪縺ｪ蛻ｶ邏・・菴輔〒縺吶°・・,
        ['譎る俣縺瑚ｶｳ繧翫↑縺・,'豌玲戟縺｡縺後∪縺螳壹∪繧峨↑縺・,'逶ｸ謇九ｄ蜻ｨ蝗ｲ縺ｮ蜿榊ｿ懊′豌励↓縺ｪ繧・,'譚｡莉ｶ髱｢縺梧紛縺｣縺ｦ縺・↑縺・]
      );
  }
}

function buildClarifyQuestions(){
  const ctx=buildClarifyCardContext();
  return buildDynamicClarifyQuestions(ctx);
  const questions=[
    buildCoreClarifyQuestion(ctx),
    buildBlockerClarifyQuestion(ctx),
  ];
  if(['諱区・','莠ｺ髢馴未菫・].includes(ctx.category)){
    questions.push(buildFeelingsClarifyQuestion(ctx));
    if(ctx.externalCard||ctx.peopleCard||ctx.themeShort) questions.push(buildExternalClarifyQuestion(ctx));
  }else{
    questions.push(buildExternalClarifyQuestion(ctx));
  }
  questions.push(buildOutcomeClarifyQuestion(ctx));
  if(ctx.themeShort||ctx.blockerCard||ctx.ambiguityCard||['莉穂ｺ・,'驥鷹°'].includes(ctx.category)){
    questions.push(buildConstraintClarifyQuestion(ctx));
  }
  const seen=new Set();
  return questions.filter(question=>{
    if(!question||seen.has(question.id)) return false;
    seen.add(question.id);
    return true;
  }).slice(0,5);
}

function renderFortuneLayer(meimei){
  if(!meimei) return '';
  const branchDynamics=meimei.branchDynamics?.relations||[];
  const fortune=meimei.fortune;
  const dynamicHTML=branchDynamics.length?`
    <div class="fortune-shell">
      <div class="fortune-head">
        <div>
          <div class="fortune-eyebrow">NATAL DYNAMICS</div>
          <div class="fortune-headline">蜻ｽ蠑丞・縺ｮ髢｢菫よｧ</div>
        </div>
        <div class="fortune-meta">蜻ｽ蠑上・荳ｭ縺ｧ縲√←縺ｮ譟ｱ蜷悟｣ｫ縺檎ｵ舌・繧・☆縺・°繝ｻ謠ｺ繧後ｄ縺吶＞縺九ｒ隕九※縺・∪縺吶・/div>
      </div>
      <div class="dynamic-list">
        ${branchDynamics.slice(0,4).map(item=>`
          <div class="dynamic-item">
            <div class="dynamic-label">${item.left} ﾃ・${item.right} / ${item.label}</div>
            <div class="dynamic-copy">${item.summary}</div>
          </div>`).join('')}
      </div>
    </div>`:'';
  if(!fortune) return dynamicHTML;
  const currentCycle=fortune.currentCycle||fortune.cycles?.[0]||null;
  const nextCycle=fortune.nextCycle||fortune.cycles?.[1]||null;
  const currentIndex=Math.max(0,(fortune.cycles||[]).findIndex(item=>item.isCurrent));
  const trackStart=Math.max(0,currentIndex>0?currentIndex-1:0);
  const trackItems=(fortune.cycles||[]).slice(trackStart,trackStart+4);
  const yearItems=(fortune.annual||[]).slice(0,6);
  const makePills=(item)=>[
    item?.tenGod?`蜊∫･・${item.tenGod}`:'',
    item?.relationText?item.relationText:'',
  ].filter(Boolean).map(tag=>`<div class="fortune-pill">${tag}</div>`).join('');
  const fortuneHTML=`
    <div class="fortune-shell">
      <div class="fortune-head">
        <div>
          <div class="fortune-eyebrow">FORTUNE LAYER</div>
          <div class="fortune-headline">譎よ悄驕九・鬪ｨ譬ｼ</div>
        </div>
        <div class="fortune-meta">${fortune.directionLabel} / 襍ｷ驕・${fortune.startText}<br>${fortune.directionNote}</div>
      </div>
      <div class="dm-note">${fortune.boundaryText}${currentCycle?`<br>縺・∪縺ｯ <strong>${currentCycle.pillar}</strong> 縺ｮ螟ｧ驕九↓蜈･繧翫ｄ縺吶￥縲・{currentCycle.copy}`:''}</div>
      <div class="fortune-grid">
        ${currentCycle?`
          <div class="fortune-card current">
            <div class="fortune-kicker">CURRENT DAIUN</div>
            <div class="fortune-title">${currentCycle.ageLabel} / ${currentCycle.pillar}</div>
            <div class="fortune-copy">${currentCycle.copy}</div>
            <div class="fortune-pill-row">${makePills(currentCycle)}</div>
          </div>`:''}
        ${nextCycle?`
          <div class="fortune-card">
            <div class="fortune-kicker">NEXT DAIUN</div>
            <div class="fortune-title">${nextCycle.ageLabel} / ${nextCycle.pillar}</div>
            <div class="fortune-copy">${nextCycle.copy}</div>
            <div class="fortune-pill-row">${makePills(nextCycle)}</div>
          </div>`:''}
      </div>
      ${trackItems.length?`
        <div class="fortune-track">
          ${trackItems.map(item=>`
            <div class="fortune-track-item ${item.isCurrent?'current':''}">
              <div class="fortune-track-age">${item.ageLabel}</div>
              <div class="fortune-track-pillar">${item.pillar}</div>
              <div class="fortune-track-copy">${item.tenGod||'驕句兇'} / ${item.relationText||'螟ｧ縺阪↑蟷ｲ貂峨・蟆代↑繧・}</div>
            </div>`).join('')}
        </div>`:''}
      ${yearItems.length?`
        <div class="fortune-year-grid">
          ${yearItems.map(item=>`
            <div class="fortune-year-item ${item.isCurrent?'current':''}">
              <div class="fortune-year-head">
                <div class="fortune-year-label">${item.year}蟷ｴ</div>
                <div class="fortune-year-pillar">${item.pillar}</div>
              </div>
              <div class="fortune-year-copy">${item.copy}</div>
              <div class="fortune-pill-row">${makePills(item)}</div>
            </div>`).join('')}
        </div>`:''}
    </div>`;
  return dynamicHTML+fortuneHTML;
}

function buildPlainInsightGrid(items=[]){
  const valid=(items||[]).filter(item=>item&&item.body);
  if(!valid.length) return '';
  return `
    <div class="insight-grid">
      ${valid.map(item=>`
        <div class="insight-card">
          ${item.kicker?`<div class="insight-kicker">${escapeHtml(item.kicker)}</div>`:''}
          <div class="insight-title">${escapeHtml(item.title||'繝昴う繝ｳ繝・)}</div>
          <div class="insight-copy">${escapeHtml(item.body)}</div>
        </div>`).join('')}
    </div>`;
}

function renderMeimei(){
  const wrap=document.getElementById('r-meimei-content');
  if(!wrap) return;
  if(!MEIMEI){
    wrap.innerHTML=`<div style="font-size:13px;color:var(--muted);font-family:'Shippori Mincho',serif;line-height:2;padding:16px 0">
      逕溘∪繧後・諠・ｱ縺瑚ｶｳ繧翫↑縺・◆繧√√％縺ｮ驛ｨ蛻・・縺ｾ縺隕九ｉ繧後∪縺帙ｓ縲・br>
      逕溷ｹｴ譛医ｒ蜈･繧後ｋ縺ｨ縲∝鴨縺ｮ蜃ｺ縺玲婿繧・夢繧後ｄ縺吶＞蝣ｴ髱｢縺ｾ縺ｧ隕九ｄ縺吶￥縺ｪ繧翫∪縺吶・    </div>`;
    return;
  }
  const birthPlain=buildBirthPlainInsight(MEIMEI);
  const noteLines=[];
  if(MEIMEI.mode==='partial') noteLines.push('逕溘∪繧後◆譌･縺ｮ諠・ｱ縺後↑縺・◆繧√∽ｻ雁屓縺ｯ螟ｧ縺ｾ縺九↑蛯ｾ蜷代ｒ荳ｭ蠢・↓隕九※縺・∪縺吶・);
  if(MEIMEI.birthHour===null) noteLines.push('逕溘∪繧後◆譎る俣縺後ｏ縺九ｉ縺ｪ縺・◆繧√∫ｴｰ縺九↑蜃ｺ譁ｹ縺ｫ縺ｯ蟆代＠蟷・′縺ゅｊ縺ｾ縺吶・);
  if(MEIMEI.useApproxSolarTerms) noteLines.push('荳驛ｨ縺ｯ縺翫♀縺ｾ縺九↑譎よ悄縺ｨ縺励※隱ｭ繧薙〒縺・∪縺吶・);
  const noteHTML=noteLines.length?`<div class="dm-note">${noteLines.join('<br>')}</div>`:'';
  const lpCard=LP?ORACLE[LP]:null;
  const cards=buildPlainInsightGrid([
    {kicker:'蝨溷床',title:'逕溘∪繧後°繧芽ｦ九∴繧句悄蜿ｰ',body:birthPlain?.overview||'逕溘∪繧後°繧芽ｦ九∴繧句悄蜿ｰ繧定ｪｭ縺ｿ蜿悶ｌ縺ｾ縺帙ｓ縺ｧ縺励◆縲・},
    {kicker:'豬√ｌ',title:'莉翫・豬√ｌ',body:birthPlain?.timing||'莉翫・豬√ｌ縺ｯ縺ｾ縺蜊∝・縺ｫ隱ｭ縺ｿ蜿悶ｌ縺ｦ縺・∪縺帙ｓ縲・},
    {kicker:'豢ｻ縺九＠譁ｹ',title:'蜉帙′蜃ｺ繧・☆縺・虚縺・,body:birthPlain?.advice||'蜉帙′蜃ｺ繧・☆縺・虚縺阪・縺ｾ縺蜊∝・縺ｫ隱ｭ縺ｿ蜿悶ｌ縺ｦ縺・∪縺帙ｓ縲・},
    ...(lpCard?[{kicker:'縺上○',title:'隱慕函譌･縺九ｉ隕九∴繧句虚縺阪・縺上○',body:lpCard.msg||''}]:[])
  ]);

  wrap.innerHTML=noteHTML+cards;
}

function renderNameJudge(){
  const wrap=document.getElementById('r-namejudge-content');
  if(!NAMEJUDGE){
    wrap.innerHTML=`<div style="font-size:13px;color:var(--muted);font-family:'Shippori Mincho',serif;line-height:2;padding:16px 0">
      蜷榊燕縺悟・縺｣縺ｦ縺・↑縺・◆繧√√％縺ｮ驛ｨ蛻・・縺ｾ縺隕九ｉ繧後∪縺帙ｓ縲・br>
      蜷榊燕繧貞・繧後ｋ縺ｨ縲∽ｺｺ縺ｫ縺ｩ縺・ｼ昴ｏ繧翫ｄ縺吶＞縺九∪縺ｧ隕九ｄ縺吶￥縺ｪ繧翫∪縺吶・    </div>`;
    return;
  }
  const plain=buildNamePlainInsight(NAMEJUDGE);
  const nameHead=`
    <div style="font-family:'Shippori Mincho',serif;font-size:18px;letter-spacing:.25em;color:var(--gold-l);text-align:center;margin-bottom:20px">
      ${NAMEJUDGE.sei} <span style="font-size:12px;color:var(--muted);letter-spacing:.1em">笨ｦ</span> ${NAMEJUDGE.mei}
    </div>`;
  const metaNotes=[];
  if(NAMEJUDGE.approxChars.length) metaNotes.push('迴阪＠縺・ｭ励・縲∬ｿ代＞謨ｰ縺域婿縺ｧ隕九※縺・∪縺吶・);
  if(NAMEJUDGE.split?.confidence==='low') metaNotes.push('蜷榊ｭ励→蜷榊燕縺ｮ蛻・ｌ逶ｮ縺後≠縺・∪縺・↑縺ｮ縺ｧ縲√♀縺翫∪縺九↓隕九※縺・∪縺吶・);
  const noteHTML=metaNotes.length?`<div class="dm-note">${metaNotes.join('<br>')}</div>`:'';
  const cards=buildPlainInsightGrid([
    {kicker:'蜊ｰ雎｡',title:'莠ｺ縺ｫ縺ｩ縺・ｼ昴ｏ繧翫ｄ縺吶＞縺・,body:plain?.overview||'蜷榊燕縺九ｉ莨昴ｏ繧句魂雎｡縺ｯ縺ｾ縺隱ｭ縺ｿ蜿悶ｌ縺ｦ縺・∪縺帙ｓ縲・},
    {kicker:'蝣ｴ髱｢',title:'譁ｰ縺励＞蝣ｴ謇縺ｧ蜃ｺ繧・☆縺・だ蜷・,body:plain?.timing||'譁ｰ縺励＞蝣ｴ謇縺ｧ蜃ｺ繧・☆縺・だ蜷代・縺ｾ縺隱ｭ縺ｿ蜿悶ｌ縺ｦ縺・∪縺帙ｓ縲・},
    {kicker:'豢ｻ縺九＠譁ｹ',title:'髟ｷ縺剰ｦ九ｋ縺ｨ豢ｻ縺阪ｄ縺吶＞蜍輔″',body:plain?.advice||'髟ｷ縺剰ｦ九ｋ縺ｨ豢ｻ縺阪ｄ縺吶＞蜍輔″縺ｯ縺ｾ縺隱ｭ縺ｿ蜿悶ｌ縺ｦ縺・∪縺帙ｓ縲・},
  ]);

  wrap.innerHTML=nameHead+noteHTML+cards;
}

function renderReactionProfile(){
  const wrap=document.getElementById('r-reaction-content');
  if(!wrap) return;
  if(!REACTION_PROFILE){
    wrap.innerHTML=`<div style="font-size:13px;color:var(--muted);font-family:'Shippori Mincho',serif;line-height:2;padding:16px 0">
      菴馴ｨ薙お繝斐た繝ｼ繝峨・蝗樒ｭ斐′縺ｪ縺・◆繧√√％縺ｮ繝ｬ繧､繝､繝ｼ縺ｯ逵∫払縺励∪縺励◆縲・br>
      蜈･蜉帷判髱｢縺ｧ遲斐∴繧九→縲√せ繝医Ξ繧ｹ縺悟・繧・☆縺・ｴ髱｢縺ｨ蜉帙・蜃ｺ縺玲婿繧定｣懆ｶｳ縺ｧ縺阪∪縺吶・    </div>`;
    return;
  }
  const evidenceText=REACTION_PROFILE.evidence?.length?REACTION_PROFILE.evidence.join(' / '):'';
  const note=`<div class="dm-note">${REACTION_PROFILE.summary}<br>蜿榊ｿ懊′蜃ｺ繧・☆縺・ｴ髱｢・・{REACTION_PROFILE.stress}<br>蜉帙′蜃ｺ繧・☆縺・虚縺搾ｼ・{REACTION_PROFILE.power}<br>${REACTION_PROFILE.handling}${evidenceText?`<br>蝗樒ｭ斐・謇九′縺九ｊ・・{evidenceText}`:''}</div>`;
  const insightHTML=`
    <div class="insight-grid">
      <div class="insight-card">
        <div class="insight-kicker">蝣ｴ髱｢</div>
        <div class="insight-title">蠑輔▲縺九°繧翫ｄ縺吶＞蝣ｴ髱｢</div>
        <div class="insight-copy">${REACTION_PROFILE.stress}</div>
      </div>
      <div class="insight-card">
        <div class="insight-kicker">蜉・/div>
        <div class="insight-title">蜉帙・蜃ｺ縺玲婿</div>
        <div class="insight-copy">${REACTION_PROFILE.power}</div>
      </div>
      <div class="insight-card">
        <div class="insight-kicker">謨ｴ縺域婿</div>
        <div class="insight-title">謨ｴ縺・ｄ縺吶＞譚｡莉ｶ</div>
        <div class="insight-copy">${REACTION_PROFILE.handling}</div>
      </div>
    </div>`;
  wrap.innerHTML=note+insightHTML;
}

function renderCards(){
  const lr=document.getElementById('r-len-cards');
  const or=document.getElementById('r-orc-cards');
  if(lr) lr.style.display='none';
  if(or) or.style.display='none';
  // 諤ｧ蛻･繧ｫ繝ｼ繝会ｼ井ｺ句燕驟咲ｽｮ・会ｼ句ｼ輔＞縺・譫・  const lenAll=FIXED_GENDER_CARD?[FIXED_GENDER_CARD,...SEL_LEN]:SEL_LEN;
  if(lr) lr.innerHTML=lenAll.map((id,i)=>{
    const isFixed=FIXED_GENDER_CARD&&i===0;
    const base=makeSmCard(id,'len');
    return isFixed?base.replace('class="card-sm"','class="card-sm" style="border-color:rgba(201,149,42,.7)"'):base;
  }).join('');
  if(or) or.innerHTML=SEL_ORC.map(id=>makeSmCard(id,'orc')).join('');
  if(lr&&lenAll.length) lr.style.display='flex';
  if(or&&SEL_ORC.length) or.style.display='flex';
}

function makeSmCard(id,type){
  const d=type==='len'?LENORMAND[id]:ORACLE[id];
  const imgSrc=type==='len'?`images/lenormand/${String(id).padStart(2,'0')}.png`:`images/oracle/${String(id).padStart(2,'0')}.png`;
  return`<div class="card-sm" title="No.${id} ${d.name}" onclick="showToast('No.${id} ${d.name}')">
    <img src="${imgSrc}" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none'" alt="">
    <div class="card-sm-ph" style="position:absolute;inset:0;z-index:-1">
      <div class="card-sm-num">${id}</div>
      <div class="card-sm-name">${d.name}</div>
    </div>
  </div>`;
}

// 笏笏笏 竭縺ゅ↑縺溘→縺・≧莠ｺ・亥屁譟ｱ謗ｨ蜻ｽ・記P・句ｧ灘錐蛻､譁ｭ繧堤ｵｱ蜷医＠縺滉ｺｺ髢楢ｪ橸ｼ俄楳笏笏笏笏笏笏笏笏笏笏笏
function applyCombinedReadingOutputs(bundle,name,cat,theme){
  LAST_OUTPUTS.len=(bundle?.len||'').trim()||buildRichLenFallback(name,cat);
  LAST_OUTPUTS.orc=(bundle?.orc||'').trim()||buildRichOrcFallback(name,cat,SEL_ORC.length===3);
  LAST_OUTPUTS.integration=(bundle?.integration||'').trim()||buildIntegratedFallback(name,cat,theme);
  renderFormattedResultText('r-len-block',LAST_OUTPUTS.len,'len');
  renderFormattedResultText('r-orc-block',LAST_OUTPUTS.orc,'orc');
  const loadEl=document.getElementById('r-aiload');
  const integrationEl=document.getElementById('r-integration');
  if(loadEl) loadEl.style.display='none';
  if(integrationEl) integrationEl.style.display='block';
  renderFormattedResultText('r-integration',LAST_OUTPUTS.integration,'integration');
}

async function runCombinedReading(){
  const stageStartedAt=Date.now();
  setResultStageStatus('len','working');
  setResultStageStatus('orc','working');
  setResultStageStatus('integration','working');

  const name=document.getElementById('f-fullname')?.value||'縺ゅ↑縺・;
  const cat=document.getElementById('f-cat')?.value||'邱丞粋';
  const theme=document.getElementById('f-theme')?.value||'';
  const focus=analyzeConsultationFocus(cat,theme);
  const is9=(SEL_LEN.length===9);
  const isOrc3=(SEL_ORC.length===3);
  const lenSpreadContext=buildLenSpreadPromptContext(cat);
  const orcLabels=getOrcSpreadLabels();
  const orcInfo=SEL_ORC.map((id,i)=>`${orcLabels[i]||''}: No.${id} ${ORACLE[id].name}\n繝｡繝・そ繝ｼ繧ｸ: ${ORACLE[id].msg}`).join('\n');
  const clarifyDetail=buildClarifyPromptText('detail');
  const internalFrame=buildInternalReadingFrame(cat);
  const birthPlain=buildBirthPlainInsight(MEIMEI);
  const namePlain=buildNamePlainInsight(NAMEJUDGE);
  const reactionText=buildReactionPromptSnippet();
  const lifeText=buildLifePatternPlainText();
  const fixedCardText=FIXED_GENDER_CARD
    ?`蝗ｺ螳壹き繝ｼ繝・ No.${FIXED_GENDER_CARD} ${LENORMAND[FIXED_GENDER_CARD].name} (${GENDER==='male'?'逕ｷ諤ｧ':'螂ｳ諤ｧ'}霆ｸ)\n`
    :'';
  const lpCard=LP?ORACLE[LP]:null;
  const lpText=lpCard?`陬懷勧蜿ら・繧ｫ繝ｼ繝・ No.${LP} ${lpCard.name}\n${lpCard.msg}`:'';
  const baseProfileText=[
    birthPlain?[birthPlain.overview,birthPlain.timing,birthPlain.advice].filter(Boolean).join(' '):'',
    namePlain?[namePlain.overview,namePlain.timing,namePlain.advice].filter(Boolean).join(' '):'',
    reactionText,
    lifeText,
  ].filter(Boolean).join('\n');
  const lenPackage=[
    '縲舌Ν繝弱Ν繝槭Φ繧ｫ繝ｼ繝芽ｩｳ邏ｰ縲・,
    lenSpreadContext.cardDetails,
    lenSpreadContext.rowDetails?`縲占｡後・隱ｭ縺ｿ縲曾n${lenSpreadContext.rowDetails}`:'',
    lenSpreadContext.columnDetails?`縲仙・縺ｮ隱ｭ縺ｿ縲曾n${lenSpreadContext.columnDetails}`:'',
    lenSpreadContext.diagonalDetails?`縲仙ｯｾ隗偵・隱ｭ縺ｿ縲曾n${lenSpreadContext.diagonalDetails}`:'',
    lenSpreadContext.pairDetails?`縲宣團謗･繝壹い縺ｮ譁・ｳ輔曾n${lenSpreadContext.pairDetails}`:'',
    lenSpreadContext.coreDetails?`縲先ｸ蠢・∪繧上ｊ縺ｮ邨・∩蜷医ｏ縺帙曾n${lenSpreadContext.coreDetails}`:'',
    lenSpreadContext.flowDetails&&is9?`縲・譫壹メ繧ｧ繝ｼ繝ｳ縺ｮ豬√ｌ縲曾n${lenSpreadContext.flowDetails}`:'',
  ].filter(Boolean).join('\n');

  const systemPrompt=`縺ゅ↑縺溘・縲√き繝ｼ繝峨・荳ｦ縺ｳ繧呈ｹ諡縺ｫ迴ｾ螳溽噪縺ｪ蜀・怐謾ｯ謠ｴ繧定｡後≧隱ｭ縺ｿ謇九〒縺吶・${buildDecisionSupportPromptGuide(cat,theme)}

蠢・医Ν繝ｼ繝ｫ:
- 繝ｫ繝弱Ν繝槭Φ繧剃ｸｻ霆ｸ縲√が繝ｩ繧ｯ繝ｫ繧定｣懷勧邱壹→縺励※謇ｱ縺・- 繝ｫ繝弱Ν繝槭Φ縺ｯ蜊倅ｽ楢ｪｬ譏弱〒縺ｯ縺ｪ縺上・團謗･繝壹い繝ｻ譬ｸ蠢・∪繧上ｊ繝ｻ3譫壹メ繧ｧ繝ｼ繝ｳ繧貞━蜈医＠縺ｦ隱ｭ繧
- 繧ｪ繝ｩ繧ｯ繝ｫ縺ｯ荳ｻ邨占ｫ悶↓縺励↑縺・りｦ也せ陬懈ｭ｣縺ｨ谺｡縺ｮ荳謇九・謨ｴ縺域婿縺ｫ菴ｿ縺・- 蠑ｷ縺・●豁｢繧・ｲ闕ｷ縺ｮ繧ｫ繝ｼ繝峨′蜃ｺ縺ｦ縺・ｋ縺ｨ縺阪・讌ｽ隕ｳ縺ｧ荳頑嶌縺阪＠縺ｪ縺・- 荳闊ｬ隲悶ｄ豌嶺ｼ代ａ縺ｧ縺ｯ縺ｪ縺上√％縺ｮ荳ｦ縺ｳ縺ｧ菴輔ｒ蛻､譁ｭ縺吶∋縺阪°繧呈嶌縺・- 蜃ｺ蜉帙・繧ｿ繧ｰ蜀・・縺ｿ縲ゅち繧ｰ螟悶・譁・ｫ縺ｯ譖ｸ縺九↑縺・
蜃ｺ蜉帛ｽ｢蠑・
[[LEN]]
笆 閭梧勹縺ｨ迴ｾ迥ｶ
...
笆 譬ｸ蠢・・隱ｭ縺ｿ
...
笆 繧ｺ繝舌Μ谺｡縺ｮ陦悟虚
...
[[/LEN]]
