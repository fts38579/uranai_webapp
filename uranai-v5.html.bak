// ORACLE FLOW
// 笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武
function goToOrc(){
  showScreen('s-orc',60);
  startOrcShuffle();
}

function startOrcShuffle(){
  orcShuffling=true;
  orcSelCards=[];
  const deck=document.getElementById('orc-deck');
  deck.style.display='';
  deck.querySelectorAll('.shuffle-card').forEach(c=>{c.style.display='flex';});
  orcInterval=setInterval(()=>{
    deck.querySelectorAll('.shuffle-card').forEach(c=>{
      c.style.transform=`rotate(${(Math.random()-0.5)*12}deg) translate(${(Math.random()-0.5)*20}px,${(Math.random()-0.5)*10}px)`;
    });
  },400);
  document.getElementById('orc-stop-btn').style.display='block';
  document.getElementById('orc-select-area').classList.remove('on');
  document.getElementById('orc-cards-full').classList.remove('on');
  document.getElementById('orc-inst').textContent='關ｽ縺｡逹縺・※縲∵ｭ｢繧√◆縺・→諤昴▲縺溽椪髢薙〒豁｢繧√※縺上□縺輔＞';
}

function stopOrc(){
  clearInterval(orcInterval);
  orcShuffling=false;
  const deck=document.getElementById('orc-deck');
  deck.querySelectorAll('.shuffle-card').forEach(c=>{c.style.transform='';});
  deck.style.display='none';
  document.getElementById('orc-stop-btn').style.display='none';

  const count=(PLAN==='paid'||PLAN==='reader')?3:FREE_ORC_COUNT;
  orcSelCards=[];
  document.getElementById('orc-sel-max').textContent=count;
  document.getElementById('orc-sel-count').textContent=0;
  document.getElementById('orc-confirm-btn').style.display='none';
  document.getElementById('orc-inst').textContent=`莉翫・豌玲戟縺｡縺ｫ霑代＞繧ｫ繝ｼ繝峨ｒ ${count} 譫夐∈繧薙〒縺上□縺輔＞縲り牡繧・ｨ｡讒倥・驕輔＞縺ｧ驕ｸ繧薙〒螟ｧ荳亥､ｫ縺ｧ縺吶Ａ;
  buildOrcCardGrid(count);
  document.getElementById('orc-select-area').classList.add('on');
}

function buildOrcCardGrid(count){
  const pool=shuffle(Array.from({length:33},(_,i)=>i+1));
  const grid=document.getElementById('orc-card-grid');
  grid.innerHTML='';
  const sigils=['笨ｦ','笨ｧ','笨ｶ','笨ｷ','笨ｹ','笨ｺ'];
  pool.forEach((id,index)=>{
    const el=document.createElement('div');
    el.className='sel-card orc-sel-card';
    el.style.setProperty('--card-hue',String((id*37+index*11)%360));
    el.innerHTML=`<span class="sel-card-mark">${sigils[id%sigils.length]}</span><span class="sel-card-index">${String(id).padStart(2,'0')}</span>`;
    el.dataset.id=id;
    el.onclick=()=>selectOrcCard(el,count);
    grid.appendChild(el);
  });
}

function selectOrcCard(el,count){
  const id=parseInt(el.dataset.id);
  if(el.classList.contains('chosen')){
    el.classList.remove('chosen');
    delete el.dataset.order;
    orcSelCards=orcSelCards.filter(x=>x!==id);
    let order=1;
    document.getElementById('orc-card-grid').querySelectorAll('.sel-card.chosen').forEach(c=>{c.dataset.order=order++;});
  }else{
    if(orcSelCards.length>=count) return;
    orcSelCards.push(id);
    el.classList.add('chosen');
    el.dataset.order=orcSelCards.length;
  }
  document.getElementById('orc-sel-count').textContent=orcSelCards.length;
  document.getElementById('orc-confirm-btn').style.display=orcSelCards.length===count?'block':'none';
}

function confirmOrcSelection(){
  SEL_ORC=[...orcSelCards];
  document.getElementById('orc-select-area').classList.remove('on');
  showOrcCards();
}

function showOrcCards(){
  document.getElementById('orc-deck').style.display='none';
  document.getElementById('orc-inst').textContent='縺・∪蜃ｺ縺溘き繝ｼ繝・;
  const full=document.getElementById('orc-cards-full');
  full.classList.add('on');
  const grid=document.getElementById('orc-cards-grid');
  grid.innerHTML='';
  const isSingle=SEL_ORC.length===1;
  if(isSingle){
    // 辟｡譁呻ｼ・譫・螟ｧ陦ｨ遉ｺ
    const wrap=document.createElement('div');
    wrap.className='card-single-wrap';
    const card=makeResultCard(SEL_ORC[0],'orc','clamp(240px,78vw,380px)','clamp(360px,117vw,570px)',0);
    card.classList.add('card-glow');
    wrap.appendChild(card);
    grid.appendChild(wrap);
  }else{
    // 譛画侭・・譫・螟ｧ陦ｨ遉ｺ
    SEL_ORC.forEach((id,i)=>{
      const card=makeResultCard(id,'orc','clamp(104px,31.5vw,200px)','clamp(156px,47.2vw,300px)',i*0.1);
      grid.appendChild(card);
    });
  }
}

// 笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武
// RESULT
// 笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武
function goToResult(){
  CLARIFY_ANSWERS={};
  CLARIFY_ACTIVE_QUESTIONS=[];
  // 辟｡譁吶・蜊縺・ｸｫ繝｢繝ｼ繝峨・蠕・■譎る俣繧貞｢励ｄ縺輔★蜊ｳ邨先棡縺ｸ
  if(PLAN==='reader'||PLAN==='free'){
    showScreen('s-result',90);
    renderResult();
    return;
  }
  // 繝励Ξ繝溘い繝髑大ｮ壹・縺ｿ縲∬ｪｭ縺ｿ縺ｮ辟ｦ轤ｹ繧貞ｮ壹ａ繧狗｢ｺ隱阪∈
  renderClarifyScreen();
  showScreen('s-clarify',85);
}

// 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
// CLARIFY SCREEN
// 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
function renderClarifyScreen(){
  const container=document.getElementById('clarify-questions');
  container.innerHTML='';
  CLARIFY_ACTIVE_QUESTIONS=buildClarifyQuestions();
  if(!CLARIFY_ACTIVE_QUESTIONS.length) return;

  CLARIFY_ACTIVE_QUESTIONS.forEach((qDef,i)=>{
    const block=document.createElement('div');
    block.className='clarify-q';
    block.dataset.qid=qDef.id;
    const taId=`ct-${qDef.id}`;
    const tmplBtns=(qDef.templates||[]).map(t=>
      `<button class="tmpl-btn" data-target="${taId}" data-tmpl="${t.replace(/"/g,'&quot;')}" onclick="setTemplate(this)">${t}</button>`
    ).join('');
    block.innerHTML=`
      <div class="clarify-q-num">FOCUS ${String(i+1).padStart(2,'0')}</div>
      <div class="clarify-q-badge"><span>${escapeHtml(qDef.badge)}</span>${escapeHtml(qDef.anchor||'')}</div>
      <div class="clarify-q-text">${escapeHtml(qDef.q)}</div>
      <div class="tmpl-answers">${tmplBtns}</div>
      <textarea class="clarify-textarea" id="${taId}" placeholder="閾ｪ逕ｱ縺ｫ譖ｸ縺・※縺上□縺輔＞縲ら洒縺上※繧ょ､ｧ荳亥､ｫ縺ｧ縺吶・></textarea>`;
    container.appendChild(block);
  });
}

function setTemplate(btn){
  const taId=btn.dataset.target;
  const text=btn.dataset.tmpl;
  const ta=document.getElementById(taId);
  if(ta) ta.value=text;
  btn.closest('.tmpl-answers').querySelectorAll('.tmpl-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
}

function collectClarifyAnswers(){
  const answers={};
  document.querySelectorAll('.clarify-q').forEach(block=>{
    const qid=block.dataset.qid;
    const ta=block.querySelector('.clarify-textarea');
    if(!ta||!ta.value.trim()) return;
    const def=CLARIFY_ACTIVE_QUESTIONS.find(question=>question.id===qid);
    if(!def) return;
    answers[qid]={
      id:def.id,
      badge:def.badge,
      anchor:def.anchor||'',
      q:def.q,
      a:ta.value.trim(),
    };
  });
  return answers;
}

function submitClarify(){
  CLARIFY_ANSWERS=collectClarifyAnswers();
  CLARIFY_ACTIVE_QUESTIONS=[];
  showScreen('s-result',90);
  renderResult();
}

function skipClarify(){
  CLARIFY_ANSWERS={};
  CLARIFY_ACTIVE_QUESTIONS=[];
  showScreen('s-result',90);
  renderResult();
}

function getClarifyEntries(){
  const values=Object.values(CLARIFY_ANSWERS||{});
  if(!values.length) return[];
  const first=values[0];
  if(first&&Array.isArray(first.qs)){
    return values.flatMap((entry,entryIndex)=>
      (entry.qs||[]).map((qa,qaIndex)=>({
        id:`legacy-${entryIndex}-${qaIndex}`,
        badge:entry.card||'陬懆ｶｳ遒ｺ隱・,
        anchor:'',
        q:qa.q||'',
        a:qa.a||'',
      }))
    ).filter(entry=>entry.a);
  }
  return values.map((entry,index)=>({
    id:entry.id||`clarify-${index}`,
    badge:entry.badge||'陬懆ｶｳ遒ｺ隱・,
    anchor:entry.anchor||'',
    q:entry.q||'',
    a:entry.a||'',
  })).filter(entry=>entry.a);
}

function hasClarifyAnswers(){
  return getClarifyEntries().length>0;
}

function buildClarifyPromptText(mode='detail'){
  const entries=getClarifyEntries();
  if(!entries.length) return mode==='plain'?'縺ｪ縺・:'';
  const summary=`縲千嶌隲・・・陬懆ｶｳ謨ｴ逅・曾n${entries.map(entry=>`- ${entry.badge}・・{entry.a}`).join('\n')}`;
  if(mode==='detail'){
    const detail=entries.map(entry=>`笆ｼ${entry.badge}${entry.anchor?`・・{entry.anchor}`:''}\nQ・・{entry.q}\nA・・{entry.a}`).join('\n');
    return `\n${summary}\n縲千嶌隲・・・陬懆ｶｳ蝗樒ｭ斐曾n${detail}`;
  }
  if(mode==='compact'){
    return `\n${summary}`;
  }
  if(mode==='inline'){
    return '\n縲千嶌隲・・｣懆ｶｳ蝗樒ｭ斐曾n'+entries.map(entry=>`笆ｼ${entry.badge}${entry.anchor?`・・{entry.anchor}`:''}・・{entry.a}`).join('\n');
  }
  return entries.map(entry=>`${entry.badge}${entry.anchor?`(${entry.anchor})`:''}: ${entry.a}`).join('\n');
}

function renderResult(){
  renderCards();
  if(PLAN==='reader'){
    const progressCard=document.getElementById('result-progress-card');
    if(progressCard) progressCard.style.display='none';
    // 蜊縺・ｸｫ繝｢繝ｼ繝会ｼ壹ユ繧ｭ繧ｹ繝磯撼陦ｨ遉ｺ縲√き繝ｼ繝牙盾辣ｧ陦ｨ縺ｮ縺ｿ
    ['rs-integration'].forEach(id=>{
      const el=document.getElementById(id);
      if(el) el.style.display='none';
    });
    const basisEl=document.getElementById('rs-basis');
    if(basisEl) basisEl.style.display='none';
    document.getElementById('r-len-block').style.display='none';
    document.getElementById('r-orc-block').style.display='none';
    renderReaderRef();
    document.getElementById('progress').style.width='100%';
    // 繧ｷ繧ｧ繧｢繝懊ち繝ｳ繧り｡ｨ遉ｺ
    setTimeout(()=>{
      const btn=document.getElementById('share-x-btn');
      if(btn) btn.style.display='inline-flex';
    },400);
    renderPremiumDossier(false);
    renderMemberFollowupSection();
    renderResultUpgradePanel();
  }else{
    // 騾壼ｸｸ繝｢繝ｼ繝会ｼ哂I隱ｭ縺ｿ荳翫￡
    const progressCard=document.getElementById('result-progress-card');
    if(progressCard) progressCard.style.display='block';
    ['rs-integration'].forEach(id=>{
      const el=document.getElementById(id);
      if(el) el.style.display='';
    });
    const basisEl=document.getElementById('rs-basis');
    if(basisEl) basisEl.style.display='';
    document.getElementById('r-len-block').style.display='';
    document.getElementById('r-orc-block').style.display='';
    renderMeimei();
    renderNameJudge();
    renderReactionProfile();
    renderPremiumDossier(PLAN==='paid');
    renderResultUpgradePanel();
    renderMemberFollowupSection();
    startResultGeneration();
  }
}

const LEN_CLARIFY_POS_LABELS=LEN_POSITION_LABELS;
const ORC_CLARIFY_POS_LABELS=ORC_POSITION_LABELS;
const CLARIFY_CARD_GROUPS={
  blocker:[6,7,8,10,11,14,17,18,21,23,36],
  ambiguity:[6,7,18,24,25,26,32],
  external:[15,16,20,24,25,26,27,28,29,34,35],
  people:[15,28,29,30],
};

function getLenClarifyPosLabel(index,total=SEL_LEN.length){
  return getLenSpreadLabel(index,total);
}

function getOrcClarifyPosLabel(index,total=SEL_ORC.length){
  return getOrcSpreadLabel(index,total);
}

function buildClarifyCardContext(){
  const input=getCurrentInputSnapshot();
  const focus=analyzeConsultationFocus(input.cat||'',input.theme||'');
  const spreadContext=buildLenSpreadPromptContext(input.cat||'邱丞粋');
  const len=SEL_LEN.map((id,index)=>({
    source:'len',
    id,
    index,
    name:LENORMAND[id]?.name||'',
    posLabel:getLenClarifyPosLabel(index,SEL_LEN.length),
  }));
  const orc=SEL_ORC.map((id,index)=>({
    source:'orc',
    id,
    index,
    name:ORACLE[id]?.name||'',
    posLabel:getOrcClarifyPosLabel(index,SEL_ORC.length),
  }));
  const findByIds=(cards,ids)=>cards.find(card=>ids.includes(card.id))||null;
  return{
    input,
    category:input.cat||'邱丞粋',
    theme:(input.theme||'').trim(),
    themeShort:((input.theme||'').trim().length<18),
    len,
    orc,
    coreCard:len.find(card=>card.index===4)||len.find(card=>card.index===1)||len[0]||null,
    futureCard:len.find(card=>card.index===5)||len.find(card=>card.index===2)||len[len.length-1]||null,
    blockerCard:findByIds(len,CLARIFY_CARD_GROUPS.blocker),
    ambiguityCard:findByIds(len,CLARIFY_CARD_GROUPS.ambiguity),
    externalCard:findByIds(len,CLARIFY_CARD_GROUPS.external),
    peopleCard:findByIds(len,CLARIFY_CARD_GROUPS.people),
    currentOrc:orc[1]||orc[0]||null,
    futureOrc:orc[2]||orc[orc.length-1]||null,
  };
}

function buildClarifyAnchor(card,prefix='蜿り・き繝ｼ繝・){
  if(!card) return '莉雁屓縺ｮ逶ｸ隲・・菴・;
  return `${prefix}・・{card.posLabel} No.${card.id} ${card.name}`;
}

function makeClarifyQuestion(id,badge,anchor,q,templates){
  return{id,badge,anchor,q,templates};
}

function getClarifyLeadText(card){
  if(!card) return '';
  const data=card.source==='orc'?(ORACLE[card.id]||{}):(LENORMAND[card.id]||{});
  return pickLenFacetText(data.kw,data.pos,data.msg,data.name,card.name);
}

function getClarifyFocus(ctx){
  return ctx?.focus||analyzeConsultationFocus(ctx?.category||ctx?.input?.cat||'',ctx?.theme||ctx?.input?.theme||'');
}

function getClarifySpreadContext(ctx){
  return ctx?.spreadContext||buildLenSpreadPromptContext(ctx?.category||ctx?.input?.cat||'邱丞粋');
}

function getClarifyThemeLabel(ctx){
  const focus=getClarifyFocus(ctx);
  if(focus?.isDualConcern) return '諱区・縺ｨ莉穂ｺ九ｒ縺ｩ縺・ｸ｡遶九＆縺帙ｋ縺・;
  if(focus?.hasLove) return '縺薙・髢｢菫ゅｒ邯壹￠繧九°隕狗峩縺吶°';
  if(focus?.hasWork) return '縺薙・莉穂ｺ九ｒ邯壹￠繧九°蜍輔￥縺・;
  return '莉雁屓縺ｮ霑ｷ縺・ｒ縺ｩ縺・愛譁ｭ縺吶ｋ縺・;
}

function getClarifyChainCards(ctx){
  const cards=getClarifySpreadContext(ctx)?.cards||[];
  if(cards.length===9) return [cards[3],cards[4],cards[5]].filter(Boolean);
  if(cards.length===3) return cards.slice(0,3);
  return cards.slice(0,Math.min(3,cards.length));
}

function buildClarifyChainAnchor(ctx,prefix='譬ｸ蠢・){
  const chain=getClarifyChainCards(ctx);
  if(!chain.length) return buildClarifyAnchor(ctx.coreCard||ctx.currentOrc,prefix);
  return `${prefix}・・{chain.map(card=>`${card.label} No.${card.id} ${card.name}`).join(' 竊・')}`;
}

function inferClarifyLens(card,ctx){
  const focus=getClarifyFocus(ctx);
  if(!card) return focus?.hasWork?'external-work':focus?.hasLove?'relationship':'core';
  if(card.source==='orc') return focus?.hasLove?'relationship':focus?.hasWork?'external-work':'core';
  const id=card.id;
  if(hasLenGroup([id],'choice')) return 'choice';
  if(hasLenGroup([id],'burden')) return 'burden';
  if(hasLenGroup([id],'hidden')) return 'ambiguity';
  if(hasLenGroup([id],'ending')) return 'timing';
  if(hasLenGroup([id],'stability')||hasLenGroup([id],'value')) return 'proof';
  if(CLARIFY_CARD_GROUPS.people.includes(id)) return 'person';
  if(CLARIFY_CARD_GROUPS.external.includes(id)) return focus?.hasWork?'external-work':'external';
  if(hasLenGroup([id],'relationship')) return 'relationship';
  return focus?.hasWork?'external-work':focus?.hasLove?'relationship':'core';
}

function buildClarifyTemplates(kind,lens,ctx){
  const focus=getClarifyFocus(ctx);
  if(kind==='core'){
    if(focus?.isDualConcern) return ['諱区・縺ｯ谿九＠縺溘＞縺御ｻ穂ｺ九ｂ蟠ｩ縺励◆縺上↑縺・,'莉穂ｺ九ｒ蜆ｪ蜈医＠縺溘＞縺碁未菫ゅｂ蛻・ｊ縺溘￥縺ｪ縺・,'縺ｾ縺夂函豢ｻ縺ｮ蝨溷床繧貞ｮ医ｊ縺溘＞','譖匁乂縺ｪ荳｡遶九・繧ゅ≧繧・ａ縺溘＞'];
    if(focus?.hasLove) return ['菫｡鬆ｼ縺ｯ螳医ｊ縺溘＞','譖匁乂縺ｪ髢｢菫ゅ・邨ゅｏ繧峨○縺溘＞','豌玲戟縺｡縺梧ｮ九ｋ縺ｪ繧牙髄縺榊粋縺・◆縺・,'閾ｪ蛻・・逕滓ｴｻ縺ｯ蟠ｩ縺励◆縺上↑縺・];
    if(focus?.hasWork) return ['邏榊ｾ励〒縺阪ｋ蜒阪″譁ｹ縺ｯ螳医ｊ縺溘＞','蜿主・縺ｮ蝨溷床縺ｯ蟠ｩ縺励◆縺上↑縺・,'謌宣聞縺梧ｭ｢縺ｾ繧九↑繧牙虚縺阪◆縺・,'莠ｺ髢馴未菫ゅ・豸郁励・謇区叛縺励◆縺・];
    return ['莉翫・螳牙ｿ・・螳医ｊ縺溘＞','譖匁乂縺輔・謇区叛縺励◆縺・,'縺ｾ縺夂樟螳滓擅莉ｶ繧呈紛縺医◆縺・,'諢滓ュ繧医ｊ莠句ｮ溘〒豎ｺ繧√◆縺・];
  }
  if(kind==='blocker'){
    switch(lens){
      case 'choice': return ['縺ｩ縺｡繧峨ｂ謐ｨ縺ｦ縺ｫ縺上＞','驕ｸ繧薙□蠕後・雋ｬ莉ｻ縺碁㍾縺・,'螟ｱ謨励＠縺溘￥縺ｪ縺・,'荳蠎ｦ豎ｺ繧√ｋ縺ｨ謌ｻ縺帙↑縺・・縺梧悶＞'];
      case 'burden': return ['逍ｲ繧後′蠑ｷ縺・,'譚｡莉ｶ縺碁㍾縺・,'逶ｸ謇句ｯｾ蠢懊〒蜑翫ｉ繧後ｋ','閠・∴繧倶ｽ吝鴨縺後↑縺・];
      case 'ambiguity': return ['逶ｸ謇九・譛ｬ髻ｳ縺瑚ｦ九∴縺ｪ縺・,'閾ｪ蛻・・譛ｬ髻ｳ縺悟崋縺ｾ繧峨↑縺・,'謨ｰ蟄励ｄ譚｡莉ｶ縺瑚ｦ九∴縺ｦ縺・↑縺・,'蜈医・蠖｢縺梧Φ蜒上〒縺阪↑縺・];
      case 'timing': return ['縺ｾ縺貅門ｙ荳崎ｶｳ','逶ｸ謇句ｾ・■縺ｫ霑代＞','迺ｰ蠅・ｾ・■縺ｫ霑代＞','莉頑ｱｺ繧√ｋ縺ｨ譌ｩ縺吶℃繧・];
      case 'relationship': return ['逶ｸ謇九◎縺ｮ繧ゅ・縺悟ｼ輔▲縺九°繧・,'霍晞屬諢溘・鄂ｮ縺肴婿縺碁屮縺励＞','豌玲戟縺｡縺ｫ貂ｩ蠎ｦ蟾ｮ縺後≠繧・,'邯壹￠縺溷・縺梧Φ蜒上＠縺ｫ縺上＞'];
      case 'external-work': return ['遉ｾ蜀・ｺ区ュ縺碁㍾縺・,'蜿主・譚｡莉ｶ縺御ｸ榊ｮ・,'蠖ｹ蜑ｲ雋闕ｷ縺碁㍾縺・,'霆｢閨ｷ蠕後・荳榊ｮ峨′蠑ｷ縺・];
      default: return ['菴輔′蠑輔▲縺九°繧九°謨ｴ逅・＠縺溘＞','譚｡莉ｶ縺梧尠譏ｧ縺ｪ縺ｾ縺ｾ','豌玲戟縺｡縺悟崋縺ｾ繧雁・繧峨↑縺・,'莉翫・縺ｾ縺豎ｺ繧∝・繧後↑縺・];
    }
  }
  if(kind==='feelings'){
    return ['豌玲戟縺｡縺ｯ谿九▲縺ｦ縺・ｋ','螳牙ｿ・ｈ繧翫＠繧薙←縺輔′蜍昴▽','髮｢繧後◆縺・・縺ｫ霑ｷ縺・,'蜷代″蜷医＞縺溘＞縺梧悶＞'];
  }
  if(kind==='external'){
    if(focus?.hasWork) return ['荳雁昇繧・ｼ夂､ｾ縺ｮ驛ｽ蜷医′螟ｧ縺阪＞','蜿主・譚｡莉ｶ縺梧ｱｺ繧∵焔縺ｫ縺ｪ繧・,'螳ｶ譌上ｄ逕滓ｴｻ莠区ュ縺悟ｼｷ縺・,'蟶ょｴ繧・ｻ｢閨ｷ繧ｿ繧､繝溘Φ繧ｰ谺｡隨ｬ'];
    return ['逶ｸ謇九・諷句ｺｦ谺｡隨ｬ','隨ｬ荳芽・ｄ蜻ｨ蝗ｲ縺ｮ遨ｺ豌励′蜉ｹ縺・,'逕滓ｴｻ譚｡莉ｶ縺悟､ｧ縺阪＞','霍晞屬繧・凾髢薙・蛻ｶ邏・′螟ｧ縺阪＞'];
  }
  if(kind==='outcome'){
    if(focus?.hasWork) return ['譚｡莉ｶ縺梧焚蟄励〒隕九∴繧後・豎ｺ繧√ｉ繧後ｋ','7譌･縺ｧ荳蠎ｦ隧ｱ縺帙ｌ縺ｰ蛻､譁ｭ縺ｧ縺阪ｋ','蠖ｹ蜑ｲ繧・悄蠕・､縺瑚ｦ九∴繧後・騾ｲ繧√ｋ','谿九ｋ縺句虚縺上°縺ｮ豈碑ｼ・｡ｨ繧剃ｽ懊ｌ縺ｰ豎ｺ繧√ｄ縺吶＞'];
    return ['逶ｸ謇九・諷句ｺｦ縺御ｸ蠎ｦ隕九∴繧後・蛻､譁ｭ縺ｧ縺阪ｋ','隧ｱ縺怜粋縺・′荳蠎ｦ縺ｧ縺阪ｌ縺ｰ豎ｺ繧√ｄ縺吶＞','霍晞屬繧堤ｽｮ縺・◆譎ゅ・閾ｪ蛻・ｒ隕九◆縺・,'邯壹￠縺溷・縺ｮ蜈ｷ菴灘ワ縺瑚ｦ九∴繧後・豎ｺ繧√ｉ繧後ｋ'];
  }
  if(kind==='constraint'){
    if(focus?.hasWork) return ['逕滓ｴｻ繧ｳ繧ｹ繝医・關ｽ縺ｨ縺帙↑縺・,'蠢・ｺｫ縺ｮ豸郁励・蠅励ｄ縺帙↑縺・,'莠ｺ髢馴未菫ゅ・謔ｪ蛹悶・驕ｿ縺代◆縺・,'谺｡縺ｮ荳豁ｩ縺ｯ辟｡逅・↑縺城ｲ繧√◆縺・];
    return ['閾ｪ蟆雁ｿ・・蜑翫ｊ縺溘￥縺ｪ縺・,'逕滓ｴｻ縺ｮ螳牙ｮ壹・蟠ｩ縺帙↑縺・,'譖匁乂縺輔ｒ髟ｷ蠑輔°縺帙◆縺上↑縺・,'逶ｸ謇九↓蜷医ｏ縺帙☆縺弱◆縺上↑縺・];
  }
  return ['遏ｭ縺上※繧ょ､ｧ荳亥､ｫ','荳險縺ｧ蜊∝・縺ｧ縺・];
}

function buildDynamicClarifyQuestions(ctx){
  const focus=getClarifyFocus(ctx);
  const chain=getClarifyChainCards(ctx);
  const chainLead=chain.map(card=>getClarifyLeadText(card)).filter(Boolean);
  const chainNames=chain.map(card=>card.name).filter(Boolean).join(' 竊・');
  const coreFocus=getClarifyThemeLabel(ctx);
  const blockerAnchor=ctx.blockerCard||ctx.ambiguityCard||ctx.currentOrc||ctx.futureCard;
  const blockerLens=inferClarifyLens(blockerAnchor,ctx);
  const externalAnchor=ctx.externalCard||ctx.peopleCard||ctx.futureCard||ctx.futureOrc||ctx.currentOrc;
  const outcomeAnchor=ctx.futureCard||ctx.futureOrc||ctx.coreCard||ctx.currentOrc;
  const questions=[
    makeClarifyQuestion(
      'core',
      '譬ｸ蠢・・迚ｹ螳・,
      buildClarifyChainAnchor(ctx,'譬ｸ蠢・),
      `${chainNames||'莉雁屓縺ｮ荳ｦ縺ｳ'} 縺九ｉ隕九ｋ縺ｨ縲∽ｻ雁屓縺ｮ譬ｸ縺ｯ縲・{coreFocus}縲阪〒縺吶ゅ＞縺ｾ荳逡ｪ螳医ｊ縺溘＞繧ゅ・縺ｯ菴輔〒縲・・↓莉雁屓縺ｪ繧画焔謾ｾ縺励※繧医＞繧ゅ・縺ｯ菴輔〒縺吶°・歔,
      buildClarifyTemplates('core','core',ctx)
    ),
    makeClarifyQuestion(
      'blocker',
      '豁｢縺ｾ繧翫←縺薙ｍ',
      buildClarifyAnchor(blockerAnchor,'蠑輔▲縺九°繧・),
      blockerLens==='choice'
        ?`${blockerAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲∵ｭ｢縺ｾ繧翫・蜴溷屏縺ｯ縲後←縺｡繧峨ｂ謐ｨ縺ｦ縺ｫ縺上＞縲阪・縺九碁∈繧薙□蠕後・雋ｬ莉ｻ縺碁㍾縺・阪・縺九√←縺｡繧峨↓霑代＞縺ｧ縺吶°・歔
        :blockerLens==='burden'
          ?`${blockerAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲√＞縺ｾ荳逡ｪ蜑翫ｉ繧後※縺・ｋ縺ｮ縺ｯ譎る俣繝ｻ豌怜鴨繝ｻ縺企≡繝ｻ蟇ｾ莠ｺ豸郁励・縺ｩ繧後〒縺吶°・歔
          :blockerLens==='ambiguity'
            ?`${blockerAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲∬ｦ九∴縺ｦ縺・↑縺・・縺ｯ逶ｸ謇九・譛ｬ髻ｳ繝ｻ閾ｪ蛻・・譛ｬ髻ｳ繝ｻ譚｡莉ｶ縺ｮ謨ｰ蟄励・縺ｩ繧後〒縺吶°・歔
            :blockerLens==='timing'
              ?`${blockerAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲∽ｻ翫☆縺先ｱｺ繧∝・繧後↑縺・炊逕ｱ縺ｯ貅門ｙ荳崎ｶｳ繝ｻ逶ｸ謇句ｾ・■繝ｻ迺ｰ蠅・ｾ・■縺ｮ縺ｩ繧後↓霑代＞縺ｧ縺吶°・歔
              :blockerLens==='relationship'
                ?`${blockerAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲∝ｼ輔▲縺九°繧翫・逶ｸ謇九◎縺ｮ繧ゅ・縺ｧ縺吶°縲・未菫ゅ・鄂ｮ縺肴婿縺ｧ縺吶°縲√◎繧後→繧り・蛻・・貂ｩ蠎ｦ蟾ｮ縺ｧ縺吶°・歔
                :blockerLens==='external-work'
                  ?`${blockerAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲∵ｭ｢縺ｾ繧翫・蜴溷屏縺ｯ遉ｾ蜀・ｺ区ュ繝ｻ蜿主・譚｡莉ｶ繝ｻ蠖ｹ蜑ｲ雋闕ｷ繝ｻ蟆・擂荳榊ｮ峨・縺ｩ繧後↓霑代＞縺ｧ縺吶°・歔
                  :`${blockerAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲√＞縺ｾ豎ｺ繧∝・繧後↑縺・怙螟ｧ縺ｮ逅・罰繧剃ｸ縺､縺縺第嫌縺偵ｋ縺ｨ菴輔〒縺吶°・歔,
      buildClarifyTemplates('blocker',blockerLens,ctx)
    ),
  ];

  if(focus?.hasLove||ctx.category==='莠ｺ髢馴未菫・){
    questions.push(
      makeClarifyQuestion(
        'feelings',
        '豌玲戟縺｡縺ｮ譛ｬ髻ｳ',
        buildClarifyAnchor(ctx.currentOrc||ctx.peopleCard||ctx.externalCard,'諢滓ュ縺ｮ貂ｩ蠎ｦ'),
        `${chainLead[1]||getClarifyLeadText(ctx.currentOrc)||'莉雁屓縺ｮ豬√ｌ'} 繧定ｸ上∪縺医ｋ縺ｨ縲∵ｰ玲戟縺｡縺ｯ谿九▲縺ｦ縺・ｋ縺ｮ縺ｫ迴ｾ螳溘′驥阪＞縺ｮ縺九∫樟螳溘・蜍輔￥縺ｮ縺ｫ豌玲戟縺｡縺瑚ｿｽ縺・▽縺九↑縺・・縺九√←縺｡繧峨′譛ｬ髻ｳ縺ｫ霑代＞縺ｧ縺吶°・歔,
        buildClarifyTemplates('feelings','feelings',ctx)
      )
    );
  }else{
    questions.push(
      makeClarifyQuestion(
        'external',
        '螟夜Κ譚｡莉ｶ縺ｮ迚ｹ螳・,
        buildClarifyAnchor(externalAnchor,'螟悶°繧牙柑縺乗擅莉ｶ'),
        `${externalAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲√％縺ｮ莉ｶ縺ｧ螳溯ｳｪ逧・↓蛻､譁ｭ繧貞ｷｦ蜿ｳ縺吶ｋ莠ｺ繝ｻ邨・ｹ斐・譚｡莉ｶ縺ｯ菴輔〒縺吶°・滉ｸ縺､縺ｫ邨槭ｋ縺ｨ縺ｩ繧後〒縺吶°・歔,
        buildClarifyTemplates('external',inferClarifyLens(externalAnchor,ctx),ctx)
      )
    );
  }
  if(focus?.hasLove||ctx.category==='莠ｺ髢馴未菫・){
    questions.push(
      makeClarifyQuestion(
        'external',
        '螟夜Κ譚｡莉ｶ縺ｮ迚ｹ螳・,
        buildClarifyAnchor(externalAnchor,'螟悶°繧牙柑縺乗擅莉ｶ'),
        `${externalAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺悟・縺ｦ縺・ｋ縺ｮ縺ｧ縲√％縺ｮ莉ｶ縺ｧ螳溯ｳｪ逧・↓蛻､譁ｭ繧貞ｷｦ蜿ｳ縺吶ｋ莠ｺ繝ｻ邨・ｹ斐・譚｡莉ｶ縺ｯ菴輔〒縺吶°・滉ｸ縺､縺ｫ邨槭ｋ縺ｨ縺ｩ繧後〒縺吶°・歔,
        buildClarifyTemplates('external',inferClarifyLens(externalAnchor,ctx),ctx)
      )
    );
  }

  questions.push(
    makeClarifyQuestion(
      'outcome',
      '蛻､譁ｭ譚先侭縺ｮ遒ｺ隱・,
      buildClarifyAnchor(outcomeAnchor,'谺｡縺ｫ遒ｺ縺九ａ繧九％縺ｨ'),
      `${outcomeAnchor?.name||'縺薙・繧ｫ繝ｼ繝・} 縺ｾ縺ｧ隱ｭ繧縺ｨ縲∵ｬ｡縺ｮ7譌･縺ｧ荳縺､遒ｺ隱阪〒縺阪ｌ縺ｰ蛻､譁ｭ縺碁ｲ縺ｿ縺昴≧縺ｧ縺吶ゆｽ輔′遒ｺ隱阪〒縺阪ｌ縺ｰ縲・ｲ繧繝ｻ豁｢縺ｾ繧九・蛻､譁ｭ縺後〒縺阪∪縺吶°・歔,
      buildClarifyTemplates('outcome','outcome',ctx)
    )
  );

  questions.push(
    makeClarifyQuestion(
      'constraint',
      '螢翫＠縺溘￥縺ｪ縺・擅莉ｶ',
      buildClarifyAnchor(ctx.futureCard||ctx.blockerCard||ctx.coreCard,'蛻､譁ｭ縺ｮ荳矩剞'),
      `莉雁屓縺ｮ蛻､譁ｭ縺ｧ縲∫ｵｶ蟇ｾ縺ｫ螢翫＠縺溘￥縺ｪ縺・擅莉ｶ繧剃ｸ縺､縺縺第嫌縺偵ｋ縺ｪ繧我ｽ輔〒縺吶°・溘後％繧後′蟠ｩ繧後ｋ縺ｪ繧蛾ｲ縺ｾ縺ｪ縺・阪→縺・≧邱壹ｒ縺ｯ縺｣縺阪ｊ縺輔○縺ｦ縺上□縺輔＞縲Ａ,
      buildClarifyTemplates('constraint','constraint',ctx)
    )
  );

  const seen=new Set();
  return questions.filter(question=>{
    if(!question||seen.has(question.id)) return false;
    seen.add(question.id);
    return true;
  }).slice(0,5);
}

function buildInternalReadingFrame(cat=''){
  const ctx=buildClarifyCardContext();
  const spreadContext=getClarifySpreadContext(ctx)||buildLenSpreadPromptContext(cat||ctx.category||'邱丞粋');
  const focus=getClarifyFocus(ctx);
  const coreChain=getClarifyChainCards(ctx);
  const dynamicQuestions=buildDynamicClarifyQuestions(ctx);
  const observationLines=[
    coreChain.length?`- 譬ｸ蠢・・: ${coreChain.map(card=>`${card.label} No.${card.id} ${card.name}`).join(' 竊・')}`:'',
    ...(spreadContext.coreDetails?spreadContext.coreDetails.split('\n').filter(Boolean).slice(0,4):[]),
    ...(spreadContext.flowDetails?spreadContext.flowDetails.split('\n').filter(Boolean).slice(0,2):[]),
  ].filter(Boolean);
  const interpretationLines=[
    `- 莉雁屓縺ｮ荳ｻ霆ｸ縺ｯ縲・{getClarifyThemeLabel(ctx)}縲阪→縺励※謇ｱ縺・,
    ctx.blockerCard?`- 豁｢縺ｾ繧翫ｄ縺吶＞隲也せ縺ｯ ${ctx.blockerCard.name}`:'',
    ctx.externalCard?`- 螟夜Κ隕∝屏縺ｨ縺励※ ${ctx.externalCard.name} 繧帝㍾縺剰ｦ九ｋ`:'',
    ctx.currentOrc?`- 繧ｪ繝ｩ繧ｯ繝ｫ縺ｯ ${ctx.currentOrc.name} 繧定｣懷勧邱壹→縺励※縺ｮ縺ｿ菴ｿ縺・:'',
    focus?.isDualConcern?'- 諱区・縺ｨ莉穂ｺ九・荳｡譁ｹ縺檎ｵ｡繧蝣ｴ蜷医・縲∫援譁ｹ縺ｮ諢滓ュ縺ｧ迚・婿縺ｮ迴ｾ螳溘ｒ荳頑嶌縺阪＠縺ｪ縺・:'',
  ].filter(Boolean);
  const unknownLines=dynamicQuestions.map(question=>`- ${question.badge}: ${question.q}`);
  return `
縲仙・驛ｨ謨ｴ逅・ Observation縲・${observationLines.join('\n')}
縲仙・驛ｨ謨ｴ逅・ Interpretation縲・${interpretationLines.join('\n')}
縲仙・驛ｨ謨ｴ逅・ Unknown縲・${unknownLines.join('\n')}`;
}

function buildCoreClarifyQuestion(ctx){
  switch(ctx.category){
    case '諱区・':
      return makeClarifyQuestion(
        'core',
        '譬ｸ蠢・｢ｺ隱・,
        buildClarifyAnchor(ctx.coreCard||ctx.currentOrc,'霆ｸ繧ｫ繝ｼ繝・),
        '縺・∪荳逡ｪ縺ｯ縺｣縺阪ｊ縺輔○縺溘＞縺ｮ縺ｯ縲∫嶌謇九・豌玲戟縺｡繝ｻ髢｢菫ゅ・莉雁ｾ後・閾ｪ蛻・′縺ｩ縺・虚縺上∋縺阪°縺ｮ縺ｩ繧後〒縺吶°・・,
        ['逶ｸ謇九・豌玲戟縺｡繧堤衍繧翫◆縺・,'縺薙・髢｢菫ゅ・莉雁ｾ後ｒ謨ｴ逅・＠縺溘＞','閾ｪ蛻・′縺ｩ縺・虚縺上∋縺阪°遏･繧翫◆縺・,'縺ｾ縺譬ｸ蠢・ｒ縺・∪縺剰ｨ闡峨↓縺ｧ縺阪↑縺・]
      );
    case '莉穂ｺ・:
      return makeClarifyQuestion(
        'core',
        '譬ｸ蠢・｢ｺ隱・,
        buildClarifyAnchor(ctx.coreCard||ctx.currentOrc,'霆ｸ繧ｫ繝ｼ繝・),
        '縺・∪荳逡ｪ謨ｴ逅・＠縺溘＞縺ｮ縺ｯ縲∫ｶ壹￠繧九°螟峨∴繧九°繝ｻ莠ｺ髢馴未菫ゅ・隧穂ｾ｡繧・庶蜈･繝ｻ閾ｪ蛻・・驕ｩ諤ｧ縺ｮ縺ｩ繧後〒縺吶°・・,
        ['邯壹￠繧九°螟峨∴繧九°繧呈ｱｺ繧√◆縺・,'閨ｷ蝣ｴ繧・ｺｺ髢馴未菫ゅｒ謨ｴ逅・＠縺溘＞','隧穂ｾ｡繧・庶蜈･縺ｮ隕矩壹＠繧堤衍繧翫◆縺・,'閾ｪ蛻・↓蜷医≧蜒阪″譁ｹ繧堤衍繧翫◆縺・]
      );
    case '驥鷹°':
      return makeClarifyQuestion(
        'core',
        '譬ｸ蠢・｢ｺ隱・,
        buildClarifyAnchor(ctx.coreCard||ctx.currentOrc,'霆ｸ繧ｫ繝ｼ繝・),
        '縺・∪荳逡ｪ謨ｴ逅・＠縺溘＞縺ｮ縺ｯ縲∝庶蜈･縺ｮ豬√ｌ繝ｻ蜃ｺ雋ｻ繧・ｸ榊ｮ峨・莉穂ｺ九→縺ｮ髢｢菫ゅ・遶九※逶ｴ縺玲婿縺ｮ縺ｩ繧後〒縺吶°・・,
        ['蜿主・縺ｮ豬√ｌ繧呈紛縺医◆縺・,'蜃ｺ雋ｻ繧・ｸ榊ｮ峨ｒ謨ｴ逅・＠縺溘＞','莉穂ｺ九→縺ｮ縺､縺ｪ縺後ｊ繧定ｦ九◆縺・,'遶九※逶ｴ縺玲婿繧堤衍繧翫◆縺・]
      );
    case '莠ｺ髢馴未菫・:
      return makeClarifyQuestion(
        'core',
        '譬ｸ蠢・｢ｺ隱・,
        buildClarifyAnchor(ctx.coreCard||ctx.currentOrc,'霆ｸ繧ｫ繝ｼ繝・),
        '縺・∪荳逡ｪ謨ｴ逅・＠縺溘＞縺ｮ縺ｯ縲∫嶌謇九・譛ｬ髻ｳ繝ｻ霍晞屬縺ｮ蜿悶ｊ譁ｹ繝ｻ髢｢菫ゅ・莉雁ｾ後・閾ｪ蛻・・蜿励￠豁｢繧∵婿縺ｮ縺ｩ繧後〒縺吶°・・,
        ['逶ｸ謇九・譛ｬ髻ｳ繧堤衍繧翫◆縺・,'霍晞屬縺ｮ蜿悶ｊ譁ｹ繧呈紛逅・＠縺溘＞','髢｢菫ゅ・莉雁ｾ後ｒ隕九◆縺・,'閾ｪ蛻・・蜿励￠豁｢繧∵婿繧呈紛縺医◆縺・]
      );
    default:
      return makeClarifyQuestion(
        'core',
        '譬ｸ蠢・｢ｺ隱・,
        buildClarifyAnchor(ctx.coreCard||ctx.currentOrc,'霆ｸ繧ｫ繝ｼ繝・),
        '莉雁屓縺ｮ繝・・繝槭〒縲√＞縺ｾ荳逡ｪ謨ｴ逅・＠縺溘＞縺ｮ縺ｯ菴輔〒縺吶°・・,
