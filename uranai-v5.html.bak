function buildPremiumDossierSourceContext(){
  const input=getCurrentInputSnapshot();
  const focus=analyzeConsultationFocus(input.cat,input.theme);
  const lenNames=SEL_LEN.map(id=>`No.${id} ${LENORMAND[id]?.name||''}`).join(' / ');
