// 笏笏笏 竭｡繝ｫ繝弱Ν繝槭Φ繝ｪ繝ｼ繝・ぅ繝ｳ繧ｰ・亥ｮ悟・迚医リ繝ｬ繝・ず繝吶・繧ｹ菴ｿ逕ｨ・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
async function runLenReading(){
  const stageStartedAt=Date.now();
  setResultStageStatus('len','working');
  setReadingBlockLoading('r-len-block','縺・∪襍ｷ縺阪※縺・ｋ縺薙→繧呈紛逅・＠縺ｦ縺・∪縺・,'霑ｷ縺・ｒ蠅励ｄ縺呵ｪｬ譏弱〒縺ｯ縺ｪ縺上∫憾豕√・譬ｸ蠢・→蛻､譁ｭ譚先侭縺縺代ｒ險闡峨↓縺励※縺・∪縺吶・);
  const name=document.getElementById('f-fullname')?.value||'縺ゅ↑縺・;
  const cat=document.getElementById('f-cat')?.value||'邱丞粋';
  const theme=document.getElementById('f-theme')?.value||'';
  const focus=analyzeConsultationFocus(cat,theme);
  const is9=(SEL_LEN.length===9);
  const is3=(SEL_LEN.length===FREE_LEN_COUNT);
  const lenSpreadContext=buildLenSpreadPromptContext(cat);
  const lenInfo=lenSpreadContext.cardDetails;
  const combinationInfo=[
    lenSpreadContext.pairDetails?`縲宣團謗･繝壹い縺ｮ譁・ｳ輔曾n${lenSpreadContext.pairDetails}`:'',
    lenSpreadContext.coreDetails?`縲先ｸ蠢・∪繧上ｊ縺ｮ邨・∩蜷医ｏ縺帙曾n${lenSpreadContext.coreDetails}`:'',
    lenSpreadContext.flowDetails&&is9?`縲・譫壹メ繧ｧ繝ｼ繝ｳ縺ｮ豬√ｌ縲曾n${lenSpreadContext.flowDetails}`:'',
  ].filter(Boolean).join('\n');
  const spreadAxisInfo=is9
    ?`\n縲占｡後・隱ｭ縺ｿ縲曾n${lenSpreadContext.rowDetails}\n縲仙・縺ｮ隱ｭ縺ｿ縲曾n${lenSpreadContext.columnDetails}\n縲占｣懷勧邱壹曾n${lenSpreadContext.diagonalDetails}`
    :is3
      ?`\n縲・譫壹・菴咲ｽｮ縲曾n- 蟾ｦ・夊レ譎ｯ\n- 荳ｭ螟ｮ・夂樟迥ｶ縺ｮ譬ｸ蠢ソn- 蜿ｳ・壽ｬ｡縺ｮ豬√ｌ`
      :'';

  // 繝・・繝槫挨繧ｭ繝ｼ繧ｫ繝ｼ繝臥｢ｺ隱搾ｼ・譫壼ｼ輔″譎ゑｼ・
  const themeKey={諱区・:24,邨仙ｩ・25,莉穂ｺ・35,驥鷹°:34,蛛･蠎ｷ:5,霆｢閨ｷ:17,遘伜ｯ・26,蝠城｡瑚ｧ｣豎ｺ:33,莠ｺ髢馴未菫・20};
  const keyCard=themeKey[cat]||(cat==='莉穂ｺ・?35:cat==='驥鷹°'?34:null);
  const keyCardInSpread=keyCard&&SEL_LEN.includes(keyCard)?`\n窶ｻ繝・・繝槫挨繧ｭ繝ｼ繧ｫ繝ｼ繝峨・{LENORMAND[keyCard]?.name}縲・No.${keyCard})縺悟・縺ｦ縺・∪縺吶ゅ％縺ｮ繧ｫ繝ｼ繝峨ｒ荳ｭ蠢・↓隱ｭ繧薙〒縺上□縺輔＞縲Ａ:'';

  // 譖匁乂繧ｫ繝ｼ繝画､懷・・亥ｯｾ隧ｱ蝙狗ｵ槭ｊ霎ｼ縺ｿ蛟呵｣懶ｼ・
  const ambigIds=SEL_LEN.filter(id=>[6,22,26].includes(id));
